# ============================================
# Phase 9 - Broker Integration Configuration
# ============================================
# Copy this file to .env and fill in your credentials
# Never commit .env to git!

# ============================================
# Alpaca Paper Trading Credentials
# ============================================
# Get your credentials from: https://app.alpaca.markets/paper/dashboard/overview
# Click "Generate API Key" in the API Keys section

ALPACA_API_KEY=REDACTED
ALPACA_SECRET_KEY=REDACTED
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Alpaca Data Feed
ALPACA_DATA_FEED_URL=wss://stream.data.alpaca.markets/v2/iex

# ============================================
# Interactive Brokers (Optional - for later)
# ============================================
IB_HOST=127.0.0.1
IB_PORT=4002
IB_CLIENT_ID=1
IB_ACCOUNT_ID=breakaleg888

# ============================================
# Trading Configuration
# ============================================
# IMPORTANT: Always start with paper trading!
TRADING_MODE=paper

# Trading Hours (ET)
MARKET_OPEN_TIME=09:30
MARKET_CLOSE_TIME=16:00

# ============================================
# Risk Limits (Phase 9 - Conservative)
# ============================================
# Maximum position size per symbol
MAX_POSITION_SIZE=100

# Maximum position value in USD
MAX_POSITION_VALUE=1000.00

# Maximum number of trades per day
MAX_DAILY_TRADES=10

# Maximum daily loss in USD
MAX_DAILY_LOSS=100.00

# Maximum number of open positions
MAX_OPEN_POSITIONS=5

# Require manual approval for trades
REQUIRE_MANUAL_APPROVAL=true

# Paper trading only (safety lock)
PAPER_TRADING_ONLY=true

# ============================================
# Logging & Monitoring
# ============================================
LOG_LEVEL=INFO
ENABLE_DEBUG_LOGGING=true
LOG_FILE_PATH=logs/phase9.log

# Metrics
ENABLE_METRICS=true
METRICS_PORT=9090

# ============================================
# Database (Optional)
# ============================================
DATABASE_URL=sqlite:///data/phase9.db

# ============================================
# Notifications (Optional)
# ============================================
ENABLE_NOTIFICATIONS=false
NOTIFICATION_EMAIL=your_email@example.com

# Slack webhook (optional)
SLACK_WEBHOOK_URL=

# ============================================
# Advanced Settings
# ============================================
# Order timeout in seconds
ORDER_TIMEOUT=30

# Connection retry attempts
MAX_RETRY_ATTEMPTS=3

# Connection timeout in seconds
CONNECTION_TIMEOUT=10

# API rate limit (requests per minute)
API_RATE_LIMIT=200

# Enable kill switch (emergency stop)
ENABLE_KILL_SWITCH=true
