{
  "backtest_name": "Multi-Strategy Portfolio Backtest",
  "backtest_mode": "multi_strategy",
  "data": {
    "symbols": ["NVDA", "TSLA", "AAPL"],
    "start_date": "2024-01-02",
    "end_date": "2024-03-31",
    "interval": "1min",
    "clickhouse_host": "localhost",
    "clickhouse_port": 8123,
    "clickhouse_database": "polygon_data",
    "enable_validation": true,
    "min_data_points": 1000,
    "max_missing_pct": 0.05
  },
  "strategies": [
    {
      "strategy_type": "momentum",
      "strategy_name": "momentum_aggressive",
      "allocation_pct": 0.35,
      "parameters": {
        "lookback_period": 60,
        "momentum_threshold": 0.02,
        "adx_threshold": 25.0
      },
      "max_position_size": 0.10,
      "max_concentration": 0.15
    },
    {
      "strategy_type": "mean_reversion",
      "strategy_name": "mean_reversion_short_term",
      "allocation_pct": 0.30,
      "parameters": {
        "lookback_period": 20,
        "entry_threshold": 2.0,
        "exit_threshold": 0.5,
        "stop_loss_threshold": 3.0
      },
      "max_position_size": 0.08,
      "max_concentration": 0.12
    },
    {
      "strategy_type": "statistical_arbitrage",
      "strategy_name": "stat_arb_pairs",
      "allocation_pct": 0.35,
      "parameters": {
        "cointegration_lookback": 252,
        "entry_zscore_threshold": 2.0,
        "exit_zscore_threshold": 0.5
      },
      "max_position_size": 0.10,
      "max_concentration": 0.15
    }
  ],
  "risk": {
    "initial_capital": 2000000.0,
    "max_position_size": 0.08,
    "max_total_exposure": 1.0,
    "max_concentration": 0.12,
    "max_daily_var": 0.04,
    "max_drawdown": 0.15,
    "max_strategies": 10,
    "min_signal_confidence": 0.65,
    "enable_regime_adjustments": true,
    "regime_risk_multipliers": {
      "low_volatility": 1.2,
      "normal_volatility": 1.0,
      "high_volatility": 0.7,
      "extreme_volatility": 0.4
    }
  },
  "execution": {
    "enable_realistic_fills": true,
    "enable_liquidity_filtering": true,
    "enable_cost_modeling": true,
    "min_liquidity_score": 65.0,
    "max_spread_bps": 20.0,
    "apply_spread_cost": true,
    "apply_market_impact": true,
    "apply_slippage": true,
    "impact_model": "almgren_chriss",
    "linear_coefficient": 0.1,
    "sqrt_coefficient": 0.5,
    "base_slippage_bps": 2.0,
    "volatility_slippage_multiplier": 1.5,
    "default_fill_rate": 0.98,
    "partial_fills_enabled": false
  },
  "analytics": {
    "enable_regime_attribution": true,
    "enable_strategy_attribution": true,
    "enable_factor_attribution": false,
    "generate_html_report": true,
    "generate_json_report": true,
    "generate_csv_trades": true,
    "metrics_calculation_frequency": "end_of_day",
    "enable_charts": true,
    "chart_types": [
      "equity_curve",
      "drawdown",
      "monthly_returns",
      "regime_distribution",
      "strategy_attribution"
    ]
  },
  "output_directory": "backtest_results/multi_strategy",
  "save_intermediate_results": false,
  "parallel_execution": false,
  "max_workers": 4
}

