  "sqrt_coefficient": 0.5,
  "base_slippage_bps": 1.5,
  "volatility_slippage_multiplier": 2.0,
  "default_fill_rate": 0.97,
  "partial_fills_enabled": true,
  "initial_capital": 3000000.0,
  "max_position_size": 0.08,
  "max_total_exposure": 1.0,
  "max_concentration": 0.12,
  "allow_shorts": false,
  "max_daily_var": 0.035,
  "max_drawdown": 0.12,
  "min_signal_confidence": 0.70,
  "enable_regime_adjustments": true,
  "regime_risk_multipliers": {
