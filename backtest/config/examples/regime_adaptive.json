{
  "backtest_name": "Regime-Adaptive Multi-Strategy Backtest",
  "backtest_mode": "regime_adaptive",
  "data": {
    "symbols": ["NVDA", "TSLA", "AAPL", "MSFT"],
    "start_date": "2024-01-02",
    "end_date": "2024-06-30",
    "interval": "1min",
    "clickhouse_host": "localhost",
    "clickhouse_port": 8123,
    "clickhouse_database": "polygon_data",
    "enable_validation": true,
    "min_data_points": 1000,
    "max_missing_pct": 0.05
  },
  "strategies": [
    {
      "strategy_type": "momentum",
      "strategy_name": "momentum_trend_following",
      "allocation_pct": 0.25,
      "parameters": {
        "lookback_period": 60,
        "momentum_threshold": 0.02,
        "adx_threshold": 25.0
      },
      "max_position_size": 0.10,
      "max_concentration": 0.15
    },
    {
      "strategy_type": "mean_reversion",
      "strategy_name": "mean_reversion_range_bound",
      "allocation_pct": 0.25,
      "parameters": {
        "lookback_period": 20,
        "entry_threshold": 2.0,
        "exit_threshold": 0.5,
        "stop_loss_threshold": 3.0
      },
      "max_position_size": 0.08,
      "max_concentration": 0.12
    },
    {
      "strategy_type": "statistical_arbitrage",
      "strategy_name": "stat_arb_cointegration",
      "allocation_pct": 0.25,
      "parameters": {
        "cointegration_lookback": 252,
        "entry_zscore_threshold": 2.0,
        "exit_zscore_threshold": 0.5
      },
      "max_position_size": 0.10,
      "max_concentration": 0.15
    },
    {
      "strategy_type": "volatility",
      "strategy_name": "volatility_crisis_protection",
      "allocation_pct": 0.25,
      "parameters": {
        "vol_lookback_period": 20,
        "vol_threshold": 0.30,
        "hedging_ratio": 0.5
      },
      "max_position_size": 0.08,
      "max_concentration": 0.12
    }
  ],
  "risk": {
    "initial_capital": 3000000.0,
    "max_position_size": 0.08,
    "max_total_exposure": 1.0,
    "max_concentration": 0.12,
    "max_daily_var": 0.035,
    "max_drawdown": 0.12,
    "max_strategies": 10,
    "min_signal_confidence": 0.70,
    "enable_regime_adjustments": true,
    "regime_risk_multipliers": {
      "low_volatility": 1.3,
      "normal_volatility": 1.0,
      "high_volatility": 0.6,
      "extreme_volatility": 0.3
    }
  },
  "execution": {
    "enable_realistic_fills": true,
    "enable_liquidity_filtering": true,
    "enable_cost_modeling": true,
    "min_liquidity_score": 70.0,
    "max_spread_bps": 18.0,
    "apply_spread_cost": true,
    "apply_market_impact": true,
    "apply_slippage": true,
    "impact_model": "almgren_chriss",
    "linear_coefficient": 0.1,
    "sqrt_coefficient": 0.5,
    "base_slippage_bps": 1.5,
    "volatility_slippage_multiplier": 2.0,
    "default_fill_rate": 0.97,
    "partial_fills_enabled": true
  },
  "analytics": {
    "enable_regime_attribution": true,
    "enable_strategy_attribution": true,
    "enable_factor_attribution": true,
    "generate_html_report": true,
    "generate_json_report": true,
    "generate_csv_trades": true,
    "metrics_calculation_frequency": "end_of_day",
    "enable_charts": true,
    "chart_types": [
      "equity_curve",
      "drawdown",
      "monthly_returns",
      "regime_distribution",
      "strategy_attribution",
      "regime_performance",
      "correlation_matrix"
    ]
  },
  "output_directory": "backtest_results/regime_adaptive",
  "save_intermediate_results": true,
  "parallel_execution": false,
  "max_workers": 6
}

