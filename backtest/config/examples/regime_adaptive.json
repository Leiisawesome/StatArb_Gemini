{
  "backtest_name": "Regime-Adaptive Multi-Strategy Backtest",
  "backtest_mode": "regime_adaptive",
  "created_at": "2025-10-27T00:00:00.000000",
  "symbols": ["NVDA", "TSLA", "AAPL", "MSFT"],
  "start_date": "2024-01-02",
