    # Regime-based performance analysis
    regime_performance = portfolio_analytics.analyze_regime_performance(
        backtest_results, processed_data['regime_history']
    )
    
    # Strategy attribution analysis
    strategy_attribution = portfolio_analytics.calculate_strategy_attribution(backtest_results)
    
    return {
        'performance_metrics': performance_metrics,
        'risk_metrics': risk_metrics,
        'regime_performance': regime_performance,
        'strategy_attribution': strategy_attribution,
        'execution_quality': portfolio_analytics.analyze_execution_quality(backtest_results)
    }
```

## Complete Backtest Execution Map

### Master Backtest Function
```python
async def run_institutional_backtest(
    symbols: List[str],
    start_date: str,
    end_date: str,
    strategy_configs: List[Dict],
    risk_config: Dict = None
) -> Dict[str, Any]:
    """
    Complete institutional backtest workflow
    
    This function orchestrates all core_engine components to run
    a comprehensive historical simulation with institutional-grade
    risk management and performance analytics.
    """
    
    try:
        # Phase 1: Initialize system
        logger.info("🔧 Initializing backtest system...")
        orchestrator = await initialize_backtest_system()
        
        # Phase 2: Process historical data
        logger.info("📊 Processing historical data...")
        processed_data = await process_historical_data(
            orchestrator, symbols, start_date, end_date
        )
        
        # Phase 3: Run strategy backtests
        logger.info("🎯 Running strategy backtests...")
        backtest_results = await run_strategy_backtest(
            orchestrator, processed_data, strategy_configs
        )
        
        # Phase 4: Analyze performance
        logger.info("📈 Analyzing performance...")
        performance_analysis = await analyze_backtest_performance(
            orchestrator, backtest_results
        )
        
        # Phase 5: Generate comprehensive report
        logger.info("📋 Generating backtest report...")
        backtest_report = {
            'backtest_config': {
                'symbols': symbols,
                'start_date': start_date,
                'end_date': end_date,
                'strategies': [config['name'] for config in strategy_configs]
            },
            'data_summary': {
                'total_records': len(processed_data['market_data']),
                'regime_changes': len(processed_data['regime_history']),
                'signals_generated': len(processed_data['signals'])
            },
            'execution_summary': {
                'total_trades': len(backtest_results),
                'successful_trades': sum(1 for r in backtest_results if r.status == 'filled'),
                'total_pnl': sum(r.pnl for r in backtest_results if hasattr(r, 'pnl'))
            },
            'performance_analysis': performance_analysis
        }
        
        # Phase 6: Cleanup
        await orchestrator.stop_all_components()
        
        logger.info("✅ Backtest completed successfully")
        return backtest_report
        
    except Exception as e:
        logger.error(f"❌ Backtest failed: {e}")
        if 'orchestrator' in locals():
            await orchestrator.emergency_shutdown()
        raise
```

## Validation Suite for Backtests

### Data Quality Validation
```python
def validate_backtest_data(processed_data: Dict) -> Dict[str, Any]:
    """Validate data quality for backtesting"""
    
    validation_results = {
        'data_completeness': {},
        'signal_quality': {},
        'regime_consistency': {},
        'overall_quality': 'unknown'
    }
    
    # Check data completeness
    market_data = processed_data['market_data']
    validation_results['data_completeness'] = {
        'total_records': len(market_data),
        'missing_values': market_data.isnull().sum().sum(),
        'date_coverage': {
            'start': market_data['timestamp'].min(),
            'end': market_data['timestamp'].max()
        }
    }
    
    # Check signal quality
    signals = processed_data['signals']
    validation_results['signal_quality'] = {
        'total_signals': len(signals),
        'high_confidence_signals': len(signals[signals['confidence'] > 0.8]),
        'signal_distribution': signals['signal_type'].value_counts().to_dict()
    }
    
    # Overall quality score
    quality_score = calculate_data_quality_score(validation_results)
    validation_results['overall_quality'] = 'good' if quality_score > 0.8 else 'poor'
    
    return validation_results
```

### Risk Validation
```python
def validate_backtest_risk_compliance(backtest_results: List, risk_config: Dict) -> Dict:
    """Validate backtest results comply with risk limits"""
    
    violations = []
    
    # Check position size violations
    for result in backtest_results:
        if hasattr(result, 'position_size_pct'):
            if result.position_size_pct > risk_config['max_position_size']:
                violations.append(f"Position size violation: {result.position_size_pct:.2%}")
    
    # Check concentration violations
    symbol_exposures = {}
    for result in backtest_results:
        symbol = result.symbol
        symbol_exposures[symbol] = symbol_exposures.get(symbol, 0) + result.quantity
    
    for symbol, exposure in symbol_exposures.items():
        if exposure > risk_config['position_concentration_limit']:
            violations.append(f"Concentration violation in {symbol}: {exposure:.2%}")
    
    return {
        'compliant': len(violations) == 0,
        'violations': violations,
        'risk_score': calculate_risk_score(backtest_results)
    }
```

