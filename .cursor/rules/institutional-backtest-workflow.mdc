## Backtest Orchestration Workflow

### Phase 1: System Initialization
```python
async def initialize_backtest_system():
    """Initialize all components for backtesting"""
    
    # 1. Create orchestrator and system integration manager
    orchestrator = HierarchicalSystemOrchestrator()
    system_integration_manager = SystemIntegrationManager()
    
    # Register system integration manager (very early)
    orchestrator.register_component(
        name="SystemIntegrationManager",
        component=system_integration_manager,
        layer=ComponentLayer.SYSTEM_CONTROL,
        authority_level=AuthorityLevel.SYSTEM_CONTROL,
        initialization_order=1  # Very early initialization
    )
    
    # 2. Register governance layer (EARLY - Rule 4)
    risk_manager = CentralRiskManager(backtest_risk_config)
    orchestrator.register_component(
        name="CentralRiskManager",
        component=risk_manager,
        layer=ComponentLayer.GOVERNANCE,
        authority_level=AuthorityLevel.GOVERNANCE_CONTROL,
        initialization_order=5  # Early governance
    )
    
    # 3. Register data management layer
    data_manager = ClickHouseDataManager(backtest_data_config)
    orchestrator.register_component(
        name="DataManager",
        component=data_manager,
        layer=ComponentLayer.SUPPORT,
        authority_level=AuthorityLevel.OPERATIONAL,
        initialization_order=10  # Data foundation
    )
    
    # 4. Register regime analysis (BEFORE signal processing - Rule 12)
    regime_engine = RegimeEngine(regime_config)
    orchestrator.register_component(
        name="RegimeEngine", 
        component=regime_engine,
        layer=ComponentLayer.SUPPORT,
        initialization_order=15  # Early regime detection
    )
    
    # 5. Register processing pipeline (with regime context)
    indicators_engine = EnhancedTechnicalIndicators()
    feature_engineer = FeatureEngineer()
    signal_generator = SignalGenerator()
    
    orchestrator.register_component("IndicatorsEngine", indicators_engine, ComponentLayer.SUPPORT, initialization_order=20)
    orchestrator.register_component("FeatureEngineer", feature_engineer, ComponentLayer.SUPPORT, initialization_order=22)
    orchestrator.register_component("SignalGenerator", signal_generator, ComponentLayer.SUPPORT, initialization_order=24)
    
    # Register strategy registry (before strategy validation)
    strategy_registry = StrategyRegistry()
    orchestrator.register_component("StrategyRegistry", strategy_registry, ComponentLayer.EXECUTION, initialization_order=24)
    
    # 6. Register strategy layer (after processing pipeline)
    strategy_manager = StrategyManager(enhanced_strategy_config)
    strategy_validator = StrategyValidator()
    strategy_engine = StrategyExecutionEngine()
    
    orchestrator.register_component("StrategyManager", strategy_manager, ComponentLayer.EXECUTION, initialization_order=25)
    orchestrator.register_component("StrategyValidator", strategy_validator, ComponentLayer.EXECUTION, initialization_order=26)
    orchestrator.register_component("StrategyEngine", strategy_engine, ComponentLayer.EXECUTION, initialization_order=28)
    
    # Register trading engine (after strategy components)
    trading_engine = TradingEngine()
    orchestrator.register_component("TradingEngine", trading_engine, ComponentLayer.EXECUTION, initialization_order=30)
    
    # Register enhanced strategies
    for strategy_info in enhanced_strategies_config:
        await strategy_manager.register_enhanced_strategy(
            strategy_info['type'], 
            strategy_info['config']
        )
    
    # 7. Register analytics layer (after core components)
    metrics_calculator = MetricsCalculator()
    performance_analyzer = PerformanceAnalyzer()
    enhanced_analytics = EnhancedAnalyticsManager(analytics_config)
    
    orchestrator.register_component("MetricsCalculator", metrics_calculator, ComponentLayer.EXECUTION, initialization_order=32)
    orchestrator.register_component("PerformanceAnalyzer", performance_analyzer, ComponentLayer.EXECUTION, initialization_order=33)
    orchestrator.register_component("EnhancedAnalyticsManager", enhanced_analytics, ComponentLayer.EXECUTION, initialization_order=35)
    
    # 8. Register execution and portfolio management (late initialization)
    portfolio_manager = EnhancedPortfolioManager()
    unified_execution_engine = UnifiedExecutionEngine()
    
    orchestrator.register_component("PortfolioManager", portfolio_manager, ComponentLayer.EXECUTION, initialization_order=38)
    orchestrator.register_component("UnifiedExecutionEngine", unified_execution_engine, ComponentLayer.EXECUTION, initialization_order=40)
    
    # 9. Register strategy implementations (after all core components)
    base_strategy_enhanced = BaseStrategyEnhanced()
    orchestrator.register_component("BaseStrategyEnhanced", base_strategy_enhanced, ComponentLayer.EXECUTION, initialization_order=50)
    
    # 10. Initialize all components in dependency order
    await orchestrator.initialize_all_components()
    await orchestrator.start_all_components()
    
    return orchestrator
```

### Phase 2: Historical Data Processing
```python
async def process_historical_data(orchestrator, symbols, start_date, end_date):
    """Process historical data through the pipeline"""
    
    data_manager = orchestrator.get_component("DataManager")
    regime_engine = orchestrator.get_component("RegimeEngine")
    indicators_engine = orchestrator.get_component("IndicatorsEngine")
    feature_engineer = orchestrator.get_component("FeatureEngineer")
    signal_generator = orchestrator.get_component("SignalGenerator")
    
    # Load historical market data
    market_data = data_manager.load_market_data(
        symbols=symbols,
        start_time=datetime.strptime(start_date, "%Y-%m-%d"),
        end_time=datetime.strptime(end_date, "%Y-%m-%d"),
        interval="1min"
    )
    
    # Process through pipeline
    logger.info("Processing historical data through pipeline...")
    
    # 1. Calculate technical indicators
    indicators_df = indicators_engine.calculate_indicators(market_data)
    
    # 2. Engineer features for ML
    features_df = feature_engineer.create_features(indicators_df)
    
    # 3. Generate trading signals
    signals_df = signal_generator.generate_signals(features_df)
    
    # 4. Feed data to regime engine for historical regime classification
    for _, row in market_data.iterrows():
        await regime_engine.on_market_data(row)
    
    return {
        'market_data': market_data,
        'indicators': indicators_df,
        'features': features_df,
        'signals': signals_df,
        'regime_history': regime_engine.get_regime_history()
    }
```

### Phase 3: Strategy Backtesting
```python
async def run_strategy_backtest(orchestrator, processed_data, strategy_configs):
    """Execute strategy backtesting with risk management"""
    
    strategy_manager = orchestrator.get_component("EnhancedStrategyManager")
    risk_manager = orchestrator.get_component("CentralRiskManager")
    analytics_manager = orchestrator.get_component("EnhancedAnalyticsManager")
    performance_analyzer = orchestrator.get_component("PerformanceAnalyzer")
    
    backtest_results = []
    
    for strategy_config in strategy_configs:
        logger.info(f"Backtesting strategy: {strategy_config['name']}")
        
        # Initialize strategy
        strategy = strategy_manager.create_strategy(strategy_config)
        
        # Run historical simulation
        for timestamp, market_state in processed_data['signals'].iterrows():
            
            # Generate strategy signals
            strategy_signals = strategy.generate_signals(market_state)
            
            # Process each signal through risk management
            for signal in strategy_signals:
                # Create trading decision request
                request = TradingDecisionRequest(
                    decision_type=TradingDecisionType.POSITION_ENTRY,
                    symbol=signal.symbol,
                    side=signal.signal_type.value,
                    quantity=signal.quantity,
                    strategy_id=strategy_config['name'],
                    confidence=signal.confidence,
                    market_regime=processed_data['regime_history'].get(timestamp, 'unknown')
                )
                
                # Request authorization from risk manager
                authorization = await risk_manager.authorize_trading_decision(request)
                
                # Execute if authorized
                if authorization.authorization_level != AuthorizationLevel.REJECTED:
                    execution_result = await backtest_engine.simulate_execution(
                        authorization, market_state, timestamp
                    )
                    backtest_results.append(execution_result)
    
    return backtest_results
```

### Phase 4: Performance Analytics
```python
async def analyze_backtest_performance(orchestrator, backtest_results):
    """Comprehensive performance analysis"""
    
    portfolio_analytics = orchestrator.get_component("PortfolioAnalytics")
    risk_manager = orchestrator.get_component("RiskManager")
    
    # Calculate performance metrics
    performance_metrics = portfolio_analytics.calculate_performance_metrics(backtest_results)
    
    # Risk analysis
