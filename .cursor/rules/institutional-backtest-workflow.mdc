        logger.info("🔧 Initializing backtest system...")
        orchestrator = await initialize_backtest_system()
        
        # Phase 2: Process historical data
        logger.info("📊 Processing historical data...")
        processed_data = await process_historical_data(
            orchestrator, symbols, start_date, end_date
        )
        
        # Phase 3: Run strategy backtests
        logger.info("🎯 Running strategy backtests...")
        backtest_results = await run_strategy_backtest(
            orchestrator, processed_data, strategy_configs
        )
        
        # Phase 4: Analyze performance
        logger.info("📈 Analyzing performance...")
        performance_analysis = await analyze_backtest_performance(
            orchestrator, backtest_results
        )
        
        # Phase 5: Generate comprehensive report
        logger.info("📋 Generating backtest report...")
        backtest_report = {
            'backtest_config': {
                'symbols': symbols,
                'start_date': start_date,
                'end_date': end_date,
                'strategies': [config['name'] for config in strategy_configs]
            },
            'data_summary': {
                'total_records': len(processed_data['market_data']),
                'regime_changes': len(processed_data['regime_history']),
                'signals_generated': len(processed_data['signals'])
            },
            'execution_summary': {
                'total_trades': len(backtest_results),
                'successful_trades': sum(1 for r in backtest_results if r.status == 'filled'),
                'total_pnl': sum(r.pnl for r in backtest_results if hasattr(r, 'pnl'))
            },
            'performance_analysis': performance_analysis
        }
        
        # Phase 6: Cleanup
        await orchestrator.stop_all_components()
        
        logger.info("✅ Backtest completed successfully")
        return backtest_report
        
    except Exception as e:
        logger.error(f"❌ Backtest failed: {e}")
        if 'orchestrator' in locals():
            await orchestrator.emergency_shutdown()
        raise
