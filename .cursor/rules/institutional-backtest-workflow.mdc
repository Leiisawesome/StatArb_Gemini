## Backtest Orchestration Workflow

### Phase 1: System Initialization - UPDATED for Rule 13 (Regime-First)
```python
async def initialize_backtest_system():
    """
    Initialize all components for backtesting with REGIME-FIRST PRINCIPLE (Rule 13)
    
    CRITICAL: EnhancedRegimeEngine MUST initialize BEFORE all other operational components
    """
    
    # 1. Create orchestrator and system integration manager
    orchestrator = HierarchicalSystemOrchestrator()
    system_integration_manager = SystemIntegrationManager()
    
    # Register system integration manager (very early)
    orchestrator.register_component(
        name="SystemIntegrationManager",
        component=system_integration_manager,
        layer=ComponentLayer.SYSTEM_CONTROL,
        authority_level=AuthorityLevel.SYSTEM_CONTROL,
        initialization_order=1  # Very early initialization
    )
    
    # ═══════════════════════════════════════════════════════════════════
    # 🔥 REGIME-FIRST PRINCIPLE (Rule 13): Initialize Regime Engine FIRST
    # ═══════════════════════════════════════════════════════════════════
    
    # 2. LAYER 0: Regime Detection - Foundation Layer (Rule 13)
    regime_engine = EnhancedRegimeEngine(backtest_regime_config)
    orchestrator.register_component(
        name="EnhancedRegimeEngine",
        component=regime_engine,
        layer=ComponentLayer.SUPPORT,  # Actually Layer 0, but uses SUPPORT enum
        authority_level=AuthorityLevel.OPERATIONAL,
        initialization_order=5  # 🔥 LOWEST ORDER = FIRST TO INITIALIZE
    )
    
    await regime_engine.initialize()
    await regime_engine.start()
    
    print("✅ REGIME ENGINE INITIALIZED - Foundation layer ready")
    
    # 3. Register governance layer (Rule 4) - REGIME-AWARE
    risk_manager = CentralRiskManager(backtest_risk_config)
    risk_manager.set_regime_engine(regime_engine)  # Inject regime awareness
    orchestrator.register_component(
        name="CentralRiskManager",
        component=risk_manager,
        layer=ComponentLayer.GOVERNANCE,
        authority_level=AuthorityLevel.GOVERNANCE_CONTROL,
        initialization_order=25  # After regime (order=5), data (order=10), processing (order=15)
    )
    
    # 4. Register data management layer - REGIME-AWARE
    data_manager = ClickHouseDataManager(backtest_data_config)
    data_manager.set_regime_engine(regime_engine)  # Inject regime awareness
    
    # Subscribe to regime changes for regime-tagged data
    regime_engine.subscribe_to_regime_changes(
        data_manager.on_regime_change
    )
    
    orchestrator.register_component(
        name="DataManager",
        component=data_manager,
        layer=ComponentLayer.SUPPORT,
        authority_level=AuthorityLevel.OPERATIONAL,
        initialization_order=10  # Data foundation after regime
    )
    
    # 5. Register liquidity management layer (Rule 12) - REGIME-AWARE
    liquidity_engine.set_regime_engine(regime_engine)  # Inject regime awareness
    impact_model.set_regime_engine(regime_engine)
    
    orchestrator.register_component(
        name="LiquidityAssessmentEngine",
        component=liquidity_engine,
        layer=ComponentLayer.SUPPORT,
        authority_level=AuthorityLevel.OPERATIONAL,
        initialization_order=12  # After data, before processing
    )
    
    orchestrator.register_component(
        name="MarketImpactModel",
        component=impact_model,
        layer=ComponentLayer.SUPPORT,
        authority_level=AuthorityLevel.OPERATIONAL,
        initialization_order=12
    )
    
    orchestrator.register_component(
        name="ExecutionQualityAnalyzer",
        component=tca_analyzer,
        layer=ComponentLayer.SUPPORT,
        authority_level=AuthorityLevel.OPERATIONAL,
        initialization_order=12
    )
    
    # 6. Register processing pipeline - REGIME-AWARE (Rule 13)
    indicators_engine = EnhancedTechnicalIndicators()
    indicators_engine.set_regime_engine(regime_engine)  # Inject regime awareness
    
    feature_engineer = FeatureEngineer()
    feature_engineer.set_regime_engine(regime_engine)
    
    signal_generator = SignalGenerator()
    signal_generator.set_regime_engine(regime_engine)
    
    # Subscribe processing components to regime changes
    regime_engine.subscribe_to_regime_changes(indicators_engine.on_regime_change)
    regime_engine.subscribe_to_regime_changes(feature_engineer.on_regime_change)
    regime_engine.subscribe_to_regime_changes(signal_generator.on_regime_change)
    
    orchestrator.register_component("IndicatorsEngine", indicators_engine, ComponentLayer.SUPPORT, initialization_order=15)
    orchestrator.register_component("FeatureEngineer", feature_engineer, ComponentLayer.SUPPORT, initialization_order=16)
    orchestrator.register_component("SignalGenerator", signal_generator, ComponentLayer.SUPPORT, initialization_order=17)
    
    # Register strategy registry (before strategy validation)
    strategy_registry = StrategyRegistry()
    orchestrator.register_component("StrategyRegistry", strategy_registry, ComponentLayer.EXECUTION, initialization_order=19)
    
    # 7. Register strategy layer - REGIME-AWARE (Rule 13)
    strategy_manager = StrategyManager(enhanced_strategy_config)
    strategy_manager.set_regime_engine(regime_engine)  # Inject regime awareness
    
    strategy_validator = StrategyValidator()
    strategy_engine = StrategyExecutionEngine()
    strategy_engine.set_regime_engine(regime_engine)  # Regime-optimized execution
    
    # Subscribe to regime changes for dynamic strategy weighting
    regime_engine.subscribe_to_regime_changes(strategy_manager.on_regime_change)
    regime_engine.subscribe_to_regime_changes(strategy_engine.on_regime_change)
    
    orchestrator.register_component("StrategyManager", strategy_manager, ComponentLayer.EXECUTION, initialization_order=20)
    orchestrator.register_component("StrategyValidator", strategy_validator, ComponentLayer.EXECUTION, initialization_order=21)
    orchestrator.register_component("StrategyEngine", strategy_engine, ComponentLayer.EXECUTION, initialization_order=22)
    
    # Register trading engine - REGIME-AWARE (Rule 13)
    trading_engine = TradingEngine()
    trading_engine.set_regime_engine(regime_engine)  # Regime-optimized order planning
    regime_engine.subscribe_to_regime_changes(trading_engine.on_regime_change)
    
    orchestrator.register_component("TradingEngine", trading_engine, ComponentLayer.EXECUTION, initialization_order=30)
    
    # Register enhanced strategies
    for strategy_info in enhanced_strategies_config:
        await strategy_manager.register_enhanced_strategy(
            strategy_info['type'], 
            strategy_info['config']
        )
    
    # 8. Register analytics layer - REGIME-AWARE (Rules 9, 13)
    metrics_calculator = MetricsCalculator()
    metrics_calculator.set_regime_engine(regime_engine)  # Regime-adjusted metrics
    
    performance_analyzer = PerformanceAnalyzer()
    performance_analyzer.set_regime_engine(regime_engine)  # Regime attribution
    performance_analyzer.set_tca_analyzer(tca_analyzer)  # Execution quality analysis
    
    enhanced_analytics = EnhancedAnalyticsManager(analytics_config)
    enhanced_analytics.set_regime_engine(regime_engine)  # Regime-aware analytics
    
    # Subscribe analytics to regime changes
    regime_engine.subscribe_to_regime_changes(enhanced_analytics.on_regime_change)
    
    orchestrator.register_component("MetricsCalculator", metrics_calculator, ComponentLayer.EXECUTION, initialization_order=32)
    orchestrator.register_component("PerformanceAnalyzer", performance_analyzer, ComponentLayer.EXECUTION, initialization_order=33)
    orchestrator.register_component("EnhancedAnalyticsManager", enhanced_analytics, ComponentLayer.EXECUTION, initialization_order=35)
    
    # 8. Register execution and portfolio management (late initialization)
    portfolio_manager = EnhancedPortfolioManager()
    unified_execution_engine = UnifiedExecutionEngine()
    
    orchestrator.register_component("PortfolioManager", portfolio_manager, ComponentLayer.EXECUTION, initialization_order=38)
    orchestrator.register_component("UnifiedExecutionEngine", unified_execution_engine, ComponentLayer.EXECUTION, initialization_order=40)
    
    # 9. Register strategy implementations (after all core components)
    base_strategy_enhanced = BaseStrategyEnhanced()
    orchestrator.register_component("BaseStrategyEnhanced", base_strategy_enhanced, ComponentLayer.EXECUTION, initialization_order=50)
    
    # 10. Initialize all components in dependency order
    await orchestrator.initialize_all_components()
    await orchestrator.start_all_components()
    
    return orchestrator
```

### Phase 2: Historical Data Processing - UPDATED for Rules 12-13
```python
async def process_historical_data(orchestrator, symbols, start_date, end_date):
    """
    Process historical data with REGIME-FIRST and LIQUIDITY-AWARE pipeline (Rules 12-13)
    
    Flow: Regime Detection → Liquidity Assessment → Signal Generation → Execution Simulation
    """
    
    # Get all components
    data_manager = orchestrator.get_component("DataManager")
    regime_engine = orchestrator.get_component("EnhancedRegimeEngine")  # Layer 0 - Foundation
    liquidity_engine = orchestrator.get_component("LiquidityAssessmentEngine")  # Rule 12
    impact_model = orchestrator.get_component("MarketImpactModel")  # Rule 12
    indicators_engine = orchestrator.get_component("IndicatorsEngine")
    feature_engineer = orchestrator.get_component("FeatureEngineer")
    signal_generator = orchestrator.get_component("SignalGenerator")
    
    # Load historical market data
    logger.info(f"Loading historical data for {symbols} from {start_date} to {end_date}")
    market_data = data_manager.load_market_data(
        symbols=symbols,
        start_time=datetime.strptime(start_date, "%Y-%m-%d"),
        end_time=datetime.strptime(end_date, "%Y-%m-%d"),
        interval="1min"
    )
    
    # ═══════════════════════════════════════════════════════════════════
    # 🔥 REGIME-FIRST: Feed data to regime engine BEFORE any processing
    # ═══════════════════════════════════════════════════════════════════
    logger.info("STEP 1: Historical regime classification (Rule 13)...")
    regime_history = []
    
    for _, row in market_data.iterrows():
        regime_context = await regime_engine.on_market_data(row)
        regime_history.append({
            'timestamp': row['timestamp'],
            'regime': regime_context.primary_regime,
            'confidence': regime_context.regime_confidence,
            'volatility_regime': regime_context.volatility_regime,
            'liquidity_regime': regime_context.liquidity_regime
        })
    
    logger.info(f"✅ Classified {len(regime_history)} historical regime periods")
    
    # ═══════════════════════════════════════════════════════════════════
    # 📊 LIQUIDITY ASSESSMENT: Evaluate historical liquidity (Rule 12)
    # ═══════════════════════════════════════════════════════════════════
    logger.info("STEP 2: Historical liquidity assessment (Rule 12)...")
    liquidity_history = {}
    
    for symbol in symbols:
        symbol_data = market_data[market_data['symbol'] == symbol]
        liquidity_scores = []
        
        for _, row in symbol_data.iterrows():
            # Assess liquidity for each historical period
            liquidity_score = await liquidity_engine.assess_liquidity_score(
                symbol=symbol,
                quantity=10000,  # Standard reference quantity
                historical_data=row
            )
            liquidity_scores.append({
                'timestamp': row['timestamp'],
                'liquidity_score': liquidity_score.overall_score,
                'liquidity_regime': liquidity_score.liquidity_regime.value,
                'avg_daily_volume': liquidity_score.avg_daily_volume,
                'bid_ask_spread_bps': liquidity_score.bid_ask_spread_bps
            })
        
        liquidity_history[symbol] = liquidity_scores
        logger.info(f"  {symbol}: Avg liquidity score = {np.mean([s['liquidity_score'] for s in liquidity_scores]):.2f}")
    
    # ═══════════════════════════════════════════════════════════════════
    # 🔄 REGIME-AWARE SIGNAL PROCESSING: Process with regime context
    # ═══════════════════════════════════════════════════════════════════
    logger.info("STEP 3: Regime-aware signal processing...")
    
    # 3.1. Calculate technical indicators (regime-adaptive)
    indicators_df = indicators_engine.calculate_indicators(market_data)
    
    # 3.2. Engineer features for ML (regime-aware)
    features_df = feature_engineer.create_features(indicators_df)
    
    # 3.3. Generate trading signals (regime-filtered and liquidity-constrained)
    signals_df = signal_generator.generate_signals(features_df)
    
    logger.info(f"✅ Generated {len(signals_df)} raw signals")
    
    # 3.4. Filter signals by liquidity (Rule 12)
    liquidity_filtered_signals = []
    filtered_out_count = 0
    
    for _, signal in signals_df.iterrows():
        symbol = signal['symbol']
        timestamp = signal['timestamp']
        
        # Get liquidity score for this period
        period_liquidity = next(
            (l for l in liquidity_history[symbol] if l['timestamp'] == timestamp),
            None
        )
        
        if period_liquidity and period_liquidity['liquidity_score'] >= 60:  # Min threshold
            # Estimate market impact
            impact_estimate = await impact_model.estimate_market_impact(
                symbol=symbol,
                quantity=signal['quantity'],
                side=signal['side'],
                urgency='normal'
            )
            
            # Accept signal if impact is acceptable
            if impact_estimate.total_impact_bps < 30:  # Max 30 bps impact
                signal['liquidity_score'] = period_liquidity['liquidity_score']
                signal['estimated_impact_bps'] = impact_estimate.total_impact_bps
                signal['spread_cost_bps'] = impact_estimate.execution_cost_bps
                liquidity_filtered_signals.append(signal)
            else:
                filtered_out_count += 1
        else:
            filtered_out_count += 1
    
    logger.info(f"✅ Liquidity filtering: {len(signals_df)} → {len(liquidity_filtered_signals)} signals "
               f"({filtered_out_count} filtered due to liquidity/impact)")
    
    return {
        'market_data': market_data,
        'indicators': indicators_df,
        'features': features_df,
        'raw_signals': signals_df,
        'liquidity_filtered_signals': pd.DataFrame(liquidity_filtered_signals),
        'regime_history': regime_history,
        'liquidity_history': liquidity_history,
        'processing_stats': {
            'total_periods': len(market_data),
            'raw_signals': len(signals_df),
            'liquidity_filtered_signals': len(liquidity_filtered_signals),
            'filter_rate': filtered_out_count / len(signals_df) if len(signals_df) > 0 else 0
        }
    }
```

