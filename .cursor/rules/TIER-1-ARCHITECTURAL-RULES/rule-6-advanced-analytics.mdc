# Rule 6: Advanced Analytics Integration Standards

All analytics components within the core_engine must support **real-time processing**, **batch analytics**, **performance attribution**, **regime-aware analysis**, and **multi-timeframe capabilities**.

## 1. Analytics Component Requirements

All analytics components MUST implement the `ISystemComponent` interface and provide both real-time and batch processing capabilities:

```python
from core_engine.system.interfaces import ISystemComponent
from abc import abstractmethod
from typing import Dict, Any, List, Optional
import pandas as pd
from datetime import datetime, timedelta

class IAnalyticsComponent(ISystemComponent):
    """Enhanced interface for analytics components"""
    
    @abstractmethod
    async def process_real_time_data(self, data: Dict[str, Any]) -> Dict[str, Any]:
        """Process real-time market data or trading events"""
        pass
    
    @abstractmethod
    async def process_batch_data(self, data: pd.DataFrame, start_time: datetime, end_time: datetime) -> Dict[str, Any]:
        """Process historical data in batch mode"""
        pass
    
    @abstractmethod
    async def get_analytics_summary(self, timeframe: str = '1D') -> Dict[str, Any]:
        """Get analytics summary for specified timeframe"""
        pass
    
    @abstractmethod
    async def get_regime_aware_metrics(self, regime_context: Dict[str, Any]) -> Dict[str, Any]:
        """Get metrics adjusted for current market regime"""
        pass
    
    @abstractmethod
    async def get_multi_timeframe_analysis(self, timeframes: List[str]) -> Dict[str, Dict[str, Any]]:
        """Get analysis across multiple timeframes"""
        pass
```

## 2. Real-Time Analytics Processing

### Streaming Analytics Pattern
```python
class RealTimeAnalyticsProcessor(IAnalyticsComponent):
    """Real-time analytics processing with streaming capabilities"""
    
    def __init__(self, config):
        super().__init__()
        self.config = config
        self.streaming_buffer = {}
        self.real_time_metrics = {}
        self.update_frequency = config.get('update_frequency', 1)  # seconds
        self.last_update = datetime.now()
    
    async def process_real_time_data(self, data: Dict[str, Any]) -> Dict[str, Any]:
        """Process real-time data with streaming analytics"""
        try:
            data_type = data.get('type')
            timestamp = data.get('timestamp', datetime.now())
            
            if data_type == 'market_data':
                return await self._process_market_data_stream(data)
            elif data_type == 'trade_execution':
                return await self._process_trade_execution_stream(data)
            elif data_type == 'position_update':
                return await self._process_position_update_stream(data)
            else:
                self.logger.warning(f"Unknown data type: {data_type}")
                return {}
                
        except Exception as e:
            self.logger.error(f"Real-time processing failed: {e}")
            return {'error': str(e)}
    
    async def _process_market_data_stream(self, data: Dict[str, Any]) -> Dict[str, Any]:
        """Process streaming market data"""
        symbol = data.get('symbol')
        price = data.get('price')
        volume = data.get('volume')
        timestamp = data.get('timestamp')
        
        # Update streaming buffer
        if symbol not in self.streaming_buffer:
            self.streaming_buffer[symbol] = {
                'prices': [],
                'volumes': [],
                'timestamps': [],
                'returns': [],
                'volatility': 0.0,
                'momentum': 0.0
            }
        
        buffer = self.streaming_buffer[symbol]
        buffer['prices'].append(price)
        buffer['volumes'].append(volume)
        buffer['timestamps'].append(timestamp)
        
        # Maintain buffer size
        max_buffer_size = self.config.get('max_buffer_size', 1000)
        if len(buffer['prices']) > max_buffer_size:
            buffer['prices'] = buffer['prices'][-max_buffer_size:]
            buffer['volumes'] = buffer['volumes'][-max_buffer_size:]
            buffer['timestamps'] = buffer['timestamps'][-max_buffer_size:]
        
        # Calculate real-time metrics
        if len(buffer['prices']) >= 2:
            # Calculate returns
            returns = [(buffer['prices'][i] - buffer['prices'][i-1]) / buffer['prices'][i-1] 
                      for i in range(1, len(buffer['prices']))]
            buffer['returns'] = returns[-100:]  # Keep last 100 returns
            
            # Calculate real-time volatility (rolling)
            if len(returns) >= 20:
                buffer['volatility'] = np.std(returns[-20:]) * np.sqrt(252)  # Annualized
            
            # Calculate momentum
            if len(buffer['prices']) >= 10:
                buffer['momentum'] = (buffer['prices'][-1] - buffer['prices'][-10]) / buffer['prices'][-10]
        
        # Update real-time metrics
        self.real_time_metrics[symbol] = {
            'current_price': price,
            'current_volume': volume,
            'volatility': buffer['volatility'],
            'momentum': buffer['momentum'],
            'last_update': timestamp
        }
        
        return self.real_time_metrics[symbol]
```

### Event-Driven Analytics
```python
class EventDrivenAnalytics(IAnalyticsComponent):
    """Event-driven analytics for trading events"""
    
    def __init__(self):
        super().__init__()
        self.event_handlers = {
            'trade_executed': self._handle_trade_execution,
            'position_changed': self._handle_position_change,
            'signal_generated': self._handle_signal_generation,
            'risk_limit_breach': self._handle_risk_breach
        }
        self.event_metrics = defaultdict(list)
    
    async def process_trading_event(self, event: Dict[str, Any]) -> Dict[str, Any]:
        """Process trading events for analytics"""
        event_type = event.get('event_type')
        handler = self.event_handlers.get(event_type)
        
        if handler:
            return await handler(event)
        else:
            self.logger.warning(f"No handler for event type: {event_type}")
            return {}
    
    async def _handle_trade_execution(self, event: Dict[str, Any]) -> Dict[str, Any]:
        """Handle trade execution events"""
        symbol = event.get('symbol')
        quantity = event.get('quantity')
        price = event.get('price')
        timestamp = event.get('timestamp')
        strategy_id = event.get('strategy_id')
        
        # Calculate execution metrics
        execution_metrics = {
            'symbol': symbol,
            'execution_time': timestamp,
            'execution_price': price,
            'execution_quantity': quantity,
            'strategy_id': strategy_id,
            'market_impact': await self._calculate_market_impact(event),
            'execution_cost': await self._calculate_execution_cost(event),
            'slippage': await self._calculate_slippage(event)
        }
        
        # Store for attribution analysis
        self.event_metrics['trade_executions'].append(execution_metrics)
        
        return execution_metrics
```

## 3. Performance Attribution Framework

### Multi-Strategy Attribution
```python
class MultiStrategyAttributionAnalyzer(IAnalyticsComponent):
    """Advanced performance attribution across multiple strategies"""
    
    def __init__(self):
        super().__init__()
        self.strategy_returns = defaultdict(list)
        self.factor_exposures = defaultdict(dict)
        self.attribution_cache = {}
    
    async def calculate_strategy_attribution(self, portfolio_returns: pd.Series, 
                                           strategy_returns: Dict[str, pd.Series]) -> Dict[str, Any]:
        """Calculate performance attribution by strategy"""
        
        attribution_results = {}
        total_portfolio_return = portfolio_returns.sum()
        
        for strategy_id, returns in strategy_returns.items():
            # Calculate strategy contribution
            strategy_contribution = returns.sum()
            contribution_percentage = strategy_contribution / total_portfolio_return if total_portfolio_return != 0 else 0
            
            # Calculate risk-adjusted metrics
            sharpe_ratio = self._calculate_sharpe_ratio(returns)
            max_drawdown = self._calculate_max_drawdown(returns)
            calmar_ratio = returns.mean() * 252 / abs(max_drawdown) if max_drawdown != 0 else 0
            
            # Calculate factor attribution
            factor_attribution = await self._calculate_factor_attribution(strategy_id, returns)
            
            attribution_results[strategy_id] = {
                'total_return': strategy_contribution,
                'contribution_percentage': contribution_percentage,
                'sharpe_ratio': sharpe_ratio,
                'max_drawdown': max_drawdown,
                'calmar_ratio': calmar_ratio,
                'volatility': returns.std() * np.sqrt(252),
                'factor_attribution': factor_attribution,
                'trade_count': len(returns[returns != 0]),
                'win_rate': len(returns[returns > 0]) / len(returns[returns != 0]) if len(returns[returns != 0]) > 0 else 0
            }
        
        return attribution_results
    
