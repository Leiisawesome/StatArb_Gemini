## Centralized Position Management Framework

### Position Management Authority
**CRITICAL**: The CentralRiskManager is the **SINGLE SOURCE OF TRUTH** for all position data. NO other component can directly modify positions.

### Position Update Flow
```python
# MANDATORY: All position updates MUST flow through RiskManager
# Step 1: Execution Engine reports successful trade
# Step 2: RiskManager updates positions and risk metrics
# Step 3: RiskManager notifies other components of position changes

class CentralizedPositionManager:
    """Centralized position management with real-time tracking"""
    
    def __init__(self):
        self.current_positions = {}  # {symbol: position_quantity}
        self.position_history = []   # Historical position changes
        self.position_metrics = {}  # Position-level risk metrics
        self.portfolio_value = 0.0  # Total portfolio value
        
    def update_position(self, symbol: str, side: str, quantity: float, 
                       price: float, timestamp: datetime) -> Dict[str, Any]:
        """Update position and return position status"""
        
        # Get current position
        current_position = self.current_positions.get(symbol, 0.0)
        
        # Calculate new position
        if side.lower() == 'buy':
            new_position = current_position + quantity
        elif side.lower() == 'sell':
            new_position = current_position - quantity
        else:
            raise ValueError(f"Invalid side: {side}")
        
        # Update position
        self.current_positions[symbol] = new_position
        
        # Record position change
        position_change = {
            'timestamp': timestamp,
            'symbol': symbol,
            'side': side,
            'quantity': quantity,
            'price': price,
            'previous_position': current_position,
            'new_position': new_position,
            'position_value': new_position * price
        }
        self.position_history.append(position_change)
        
        # Update portfolio metrics
        self._update_portfolio_metrics()
        
        # Notify components of position change
        await self._notify_position_change(position_change)
        
        return {
            'symbol': symbol,
            'position': new_position,
            'position_value': new_position * price,
            'portfolio_value': self.portfolio_value,
            'risk_metrics': self._calculate_position_risk(symbol, new_position)
        }
    
    def _update_portfolio_metrics(self):
        """Update portfolio-level metrics"""
        total_value = 0.0
        for symbol, position in self.current_positions.items():
            # Get current market price (would come from data manager)
            current_price = self._get_current_price(symbol)
            total_value += position * current_price
        
        self.portfolio_value = total_value
        
        # Update position metrics
        self.position_metrics = {
            'total_positions': len([p for p in self.current_positions.values() if p != 0]),
            'long_positions': len([p for p in self.current_positions.values() if p > 0]),
            'short_positions': len([p for p in self.current_positions.values() if p < 0]),
            'net_exposure': sum(self.current_positions.values()),
            'gross_exposure': sum(abs(p) for p in self.current_positions.values()),
            'portfolio_value': total_value
        }
    
    async def _notify_position_change(self, position_change: Dict[str, Any]):
        """Notify all components of position changes"""
        # Notify Portfolio Manager
        await self.portfolio_manager.on_position_update(position_change)
        
        # Notify Analytics Engine
        await self.analytics_engine.on_position_update(position_change)
        
        # Notify Risk Monitoring
        await self.risk_monitor.on_position_update(position_change)
```

### Position Validation and Risk Checks
```python
def validate_position_change(self, symbol: str, side: str, quantity: float) -> Tuple[bool, str]:
    """Validate position change against risk limits"""
    
    current_position = self.current_positions.get(symbol, 0.0)
    
    # Calculate new position
    if side.lower() == 'buy':
        new_position = current_position + quantity
    elif side.lower() == 'sell':
        new_position = current_position - quantity
    else:
        return False, f"Invalid side: {side}"
    
    # Check position limits
    max_position = self.risk_limits.get('max_position_size', 0.10) * self.portfolio_value
    if abs(new_position) > max_position:
        return False, f"Position would exceed limit: {abs(new_position)} > {max_position}"
    
    # Check concentration limits
    position_value = abs(new_position) * self._get_current_price(symbol)
    concentration = position_value / self.portfolio_value
    max_concentration = self.risk_limits.get('max_concentration', 0.15)
    if concentration > max_concentration:
        return False, f"Concentration would exceed limit: {concentration:.2%} > {max_concentration:.2%}"
    
    # Check short selling limits
    if new_position < 0 and not self.allow_short_selling:
        return False, "Short selling not allowed"
    
    return True, "Position change validated"

def get_position_risk_metrics(self, symbol: str) -> Dict[str, float]:
    """Get risk metrics for specific position"""
    position = self.current_positions.get(symbol, 0.0)
    current_price = self._get_current_price(symbol)
    position_value = position * current_price
    
    return {
        'position': position,
        'position_value': position_value,
        'position_pct': position_value / self.portfolio_value if self.portfolio_value > 0 else 0,
        'unrealized_pnl': self._calculate_unrealized_pnl(symbol),
        'var_contribution': self._calculate_var_contribution(symbol),
        'beta_exposure': self._calculate_beta_exposure(symbol)
    }
```

### Position Reconciliation and Audit
```python
def reconcile_positions(self) -> Dict[str, Any]:
    """Reconcile positions across all components"""
    
    reconciliation_report = {
        'timestamp': datetime.now(),
        'risk_manager_positions': self.current_positions.copy(),
        'portfolio_manager_positions': self.portfolio_manager.get_positions(),
        'execution_engine_positions': self.execution_engine.get_positions(),
        'discrepancies': [],
        'reconciliation_status': 'success'
    }
    
    # Check for discrepancies
    for symbol in set(self.current_positions.keys()) | set(self.portfolio_manager.get_positions().keys()):
        risk_pos = self.current_positions.get(symbol, 0.0)
        portfolio_pos = self.portfolio_manager.get_positions().get(symbol, 0.0)
        
        if abs(risk_pos - portfolio_pos) > 0.01:  # Allow for small rounding differences
            reconciliation_report['discrepancies'].append({
                'symbol': symbol,
                'risk_manager': risk_pos,
                'portfolio_manager': portfolio_pos,
                'difference': risk_pos - portfolio_pos
            })
    
    if reconciliation_report['discrepancies']:
        reconciliation_report['reconciliation_status'] = 'discrepancies_found'
        logger.warning(f"Position discrepancies found: {reconciliation_report['discrepancies']}")
    
    return reconciliation_report
```

