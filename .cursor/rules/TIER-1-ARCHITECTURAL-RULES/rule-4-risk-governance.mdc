### Risk Calculation Methods
```python
def calculate_var_historical(self, returns: List[float], confidence: float = 0.95) -> float:
    """Calculate Value at Risk using historical simulation"""
    return np.percentile(returns, (1 - confidence) * 100)

def calculate_conditional_var(self, returns: List[float], var_threshold: float) -> float:
    """Calculate Conditional Value at Risk (Expected Shortfall)"""
    tail_returns = [r for r in returns if r <= var_threshold]
    return np.mean(tail_returns) if tail_returns else 0.0

def calculate_max_drawdown(self, cumulative_returns: List[float]) -> float:
    """Calculate maximum drawdown from peak"""
    peak = np.maximum.accumulate(cumulative_returns)
    drawdown = (peak - cumulative_returns) / peak
    return np.max(drawdown)

def calculate_sharpe_ratio(self, returns: List[float], risk_free_rate: float = 0.02) -> float:
    """Calculate Sharpe ratio"""
    excess_returns = [r - risk_free_rate/252 for r in returns]  # Daily risk-free rate
    return np.mean(excess_returns) / np.std(excess_returns) * np.sqrt(252)
```

## Regime-Aware Risk Scaling

### Market Regime Risk Adjustment
```python
def calculate_regime_adjusted_risk(self, base_risk: float, regime: str, 
                                 volatility_regime: str, liquidity_regime: str) -> float:
    """Scale risk based on market regime conditions"""
    
    # Base regime multipliers
    regime_multipliers = {
        'low_volatility': 1.2,    # Increase risk in low vol (more opportunities)
        'normal_volatility': 1.0, # Normal risk in normal vol
        'high_volatility': 0.7,   # Reduce risk in high vol (more dangerous)
        'extreme_volatility': 0.4, # Significantly reduce risk in extreme vol
        
        'trending': 1.1,          # Slightly increase risk in trending markets
        'sideways': 0.9,          # Reduce risk in sideways markets
        'choppy': 0.6,            # Significantly reduce risk in choppy markets
        
        'high_liquidity': 1.0,    # Normal risk in liquid markets
        'normal_liquidity': 0.9,   # Slightly reduce risk in normal liquidity
        'low_liquidity': 0.7,     # Reduce risk in low liquidity
        'illiquid': 0.4           # Significantly reduce risk in illiquid markets
    }
    
    # Calculate combined risk adjustment
    regime_factor = regime_multipliers.get(regime, 1.0)
    vol_factor = regime_multipliers.get(volatility_regime, 1.0)
    liq_factor = regime_multipliers.get(liquidity_regime, 1.0)
    
    # Apply conservative scaling (use minimum of factors)
    adjusted_risk = base_risk * min(regime_factor, vol_factor, liq_factor)
    
    # Ensure risk doesn't exceed maximum allowed
    max_risk = base_risk * 1.5  # Never more than 50% above base
    return min(adjusted_risk, max_risk)

def get_regime_risk_limits(self, regime: str) -> Dict[str, float]:
    """Get risk limits adjusted for current market regime"""
    base_limits = {
        'max_position_size': 0.10,
        'max_daily_var': 0.05,
        'max_concentration': 0.15
    }
    
    regime_adjustments = {
        'low_volatility': {'max_position_size': 0.12, 'max_daily_var': 0.06},
        'high_volatility': {'max_position_size': 0.07, 'max_daily_var': 0.03},
        'choppy': {'max_position_size': 0.05, 'max_concentration': 0.10},
        'illiquid': {'max_position_size': 0.08, 'max_concentration': 0.12}
    }
    
    adjusted_limits = base_limits.copy()
    if regime in regime_adjustments:
        adjusted_limits.update(regime_adjustments[regime])
    
    return adjusted_limits
```

