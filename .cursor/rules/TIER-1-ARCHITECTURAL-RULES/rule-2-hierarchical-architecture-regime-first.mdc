## System Initialization Pattern

```python
async def initialize_system_with_regime_first():
    """Initialize system with Regime-First architecture"""
    
    orchestrator = HierarchicalSystemOrchestrator()
    
    # STEP 1: Initialize EnhancedRegimeEngine FIRST (order=5)
    regime_engine = EnhancedRegimeEngine(config)
    orchestrator.register_component(
        "EnhancedRegimeEngine", regime_engine,
        ComponentLayer.SUPPORT, AuthorityLevel.OPERATIONAL,
        initialization_order=5  # FIRST!
    )
    await regime_engine.initialize()
    await regime_engine.start()
    
    # STEP 2: Initialize DataManager with regime context (order=10)
    data_manager = ClickHouseDataManager(config)
    data_manager.set_regime_engine(regime_engine)  # Inject regime context
    orchestrator.register_component(
        "DataManager", data_manager,
        ComponentLayer.SUPPORT, AuthorityLevel.OPERATIONAL,
        initialization_order=10
    )
    
    # STEP 3: Continue with other components in order...
    # All components receive regime context
    
    return orchestrator
```

