### Market Impact Models

```python
def _almgren_chriss_model(
    self,
    quantity: float,
    market_data: Dict[str, Any],
    liquidity_score: LiquidityScore,
    participation_rate: float
) -> Dict[str, Any]:
    """Almgren-Chriss optimal execution model"""
    
    volatility = market_data.get('volatility', 0.02)
    
    # Permanent impact (linear in quantity)
    permanent_impact = self.linear_coefficient * participation_rate
    
    # Temporary impact (square root law)
    temporary_impact = self.sqrt_coefficient * np.sqrt(participation_rate)
    
    total_impact_bps = (permanent_impact + temporary_impact) * 10000
    
    return {
        'permanent_impact_bps': permanent_impact * 10000,
        'temporary_impact_bps': temporary_impact * 10000,
        'total_impact_bps': total_impact_bps,
        'model_type': 'almgren_chriss'
    }
```

