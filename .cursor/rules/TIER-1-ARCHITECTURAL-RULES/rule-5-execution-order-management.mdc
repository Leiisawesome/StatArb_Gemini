## Section 2: Phase 12 - Order Management System (NEW) ⭐

### Component: OrderManagementSystem

**File:** `core_engine/system/oms.py`  
**Responsibility:** Complete order lifecycle management

```python
class OrderState(Enum):
    """Order lifecycle states"""
    PENDING_NEW = "pending_new"
    NEW = "new"
    PARTIALLY_FILLED = "partially_filled"
    FILLED = "filled"
    PENDING_CANCEL = "pending_cancel"
    CANCELLED = "cancelled"
    REJECTED = "rejected"
    EXPIRED = "expired"
    PENDING_REPLACE = "pending_replace"

@dataclass
class Order:
    """Order entity with complete lifecycle tracking"""
    
    # Identity
    order_id: str
    client_order_id: str
    parent_order_id: Optional[str] = None
    authorization_id: str = None
    
    # Order details
    symbol: str = None
    side: str = None
    order_type: OrderType = OrderType.MARKET
    quantity: float = 0.0
    limit_price: Optional[float] = None
    
    # State
    state: OrderState = OrderState.PENDING_NEW
    filled_quantity: float = 0.0
    remaining_quantity: float = 0.0
    avg_fill_price: float = 0.0
    
    # Timestamps
    created_at: datetime = None
    submitted_at: Optional[datetime] = None
    filled_at: Optional[datetime] = None
    
    # Audit trail
    state_history: List[Dict[str, Any]] = field(default_factory=list)


class OrderManagementSystem(ISystemComponent):
    """Institutional Order Management System"""
    
    def __init__(self, config: Dict[str, Any]):
        self.orders: Dict[str, Order] = {}
        self.orders_by_authorization: Dict[str, List[str]] = {}
        self.persistence_enabled = config.get('persistence_enabled', True)
    
    async def create_order(
        self,
        authorization_id: str,
        symbol: str,
        side: str,
        quantity: float,
        order_type: OrderType = OrderType.MARKET,
        limit_price: Optional[float] = None,
        parent_order_id: Optional[str] = None
    ) -> Order:
        """Create new order from authorization"""
        order = Order(
            order_id=str(uuid.uuid4()),
            client_order_id=f"CO-{uuid.uuid4().hex[:8]}",
            authorization_id=authorization_id,
            symbol=symbol,
            side=side,
            quantity=quantity,
            remaining_quantity=quantity,
            order_type=order_type,
            limit_price=limit_price,
            parent_order_id=parent_order_id,
            created_at=datetime.now()
        )
        
        # Store order
        self.orders[order.order_id] = order
        
        # Index by authorization
        if authorization_id not in self.orders_by_authorization:
            self.orders_by_authorization[authorization_id] = []
        self.orders_by_authorization[authorization_id].append(order.order_id)
        
        # Record state change
        order.state_history.append({
            'timestamp': datetime.now(),
            'from_state': None,
            'to_state': OrderState.PENDING_NEW,
            'reason': 'order_created'
        })
        
        if self.persistence_enabled:
            await self._persist_order(order)
        
        return order
    
    async def submit_order(self, order_id: str) -> Order:
        """Submit order to execution engine"""
        order = self.orders.get(order_id)
        if not order:
            raise ValueError(f"Order not found: {order_id}")
        
        if order.state != OrderState.PENDING_NEW:
            raise ValueError(f"Cannot submit order in state: {order.state}")
        
        await self._transition_state(order, OrderState.NEW, 'submitted_to_venue')
        order.submitted_at = datetime.now()
        
        return order
    
    async def record_fill(
        self,
        order_id: str,
        fill_quantity: float,
        fill_price: float
    ) -> Order:
        """Record execution fill"""
        order = self.orders.get(order_id)
        if not order:
            raise ValueError(f"Order not found: {order_id}")
        
        # Update quantities
        order.filled_quantity += fill_quantity
        order.remaining_quantity = order.quantity - order.filled_quantity
        
        # Update average price (weighted)
        if order.avg_fill_price == 0:
            order.avg_fill_price = fill_price
        else:
            total_value = (
                order.avg_fill_price * (order.filled_quantity - fill_quantity) + 
                fill_price * fill_quantity
            )
            order.avg_fill_price = total_value / order.filled_quantity
        
        # Determine new state
        if order.remaining_quantity <= 0:
            await self._transition_state(order, OrderState.FILLED, 'completely_filled')
            order.filled_at = datetime.now()
        else:
            await self._transition_state(order, OrderState.PARTIALLY_FILLED, 'partial_fill')
        
        return order
    
    async def cancel_order(self, order_id: str, reason: str = None) -> Order:
        """Request order cancellation"""
        order = self.orders.get(order_id)
        if order.state in [OrderState.FILLED, OrderState.CANCELLED, OrderState.REJECTED]:
            raise ValueError(f"Cannot cancel order in state: {order.state}")
        
        await self._transition_state(order, OrderState.PENDING_CANCEL, reason or 'cancel_requested')
        return order
    
    async def get_working_orders(self) -> List[Order]:
        """Get all working (active) orders"""
        working_states = [
            OrderState.NEW,
            OrderState.PARTIALLY_FILLED,
            OrderState.PENDING_CANCEL,
            OrderState.PENDING_REPLACE
        ]
        return [o for o in self.orders.values() if o.state in working_states]
    
    async def _transition_state(self, order: Order, new_state: OrderState, reason: str):
        """Record state transition"""
        old_state = order.state
        order.state = new_state
        
        order.state_history.append({
            'timestamp': datetime.now(),
            'from_state': old_state,
            'to_state': new_state,
            'reason': reason
        })
        
        if self.persistence_enabled:
            await self._persist_order(order)
```

