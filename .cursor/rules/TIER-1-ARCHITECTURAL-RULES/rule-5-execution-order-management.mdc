## Phase 13: Execution Action

```python
async def execute_authorized_trade(self, order: Order) -> ExecutionResult:
    # Validate authorization
    if not self._validate_authorization(order.authorization_id):
        return self._create_rejected_result(order, "Authorization invalid")
    
    # Execute per algorithm
    result = await self._execute_by_algorithm(order)
    
    # Update OMS
    if result.status == ExecutionStatus.FILLED:
        await self.oms.record_fill(order.order_id, result.filled_quantity, result.avg_fill_price)
    
    # MANDATORY: Report to RiskManager for position update (Phase 15)
    if result.status == ExecutionStatus.FILLED:
        await self._handle_position_updates(order, result)
    
    return result
```

### Position Update Callback (CRITICAL)

```python
async def _handle_position_updates(self, order: Order, result: ExecutionResult):
    """MANDATORY: Update via RiskManager ONLY (Rule 3)"""
    if not self.risk_manager_callback:
        raise RuntimeError("Cannot update position without RiskManager callback")
    
    await self.risk_manager_callback.update_position(
        symbol=order.symbol,
        side=order.side,
        quantity=result.filled_quantity,
        price=result.avg_fill_price,
        timestamp=result.execution_timestamp
    )
```

