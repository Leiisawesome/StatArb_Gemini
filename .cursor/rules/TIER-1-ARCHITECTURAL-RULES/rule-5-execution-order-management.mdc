## Section 3: Phase 13 - Execution Action

### Component: UnifiedExecutionEngine

**File:** `core_engine/system/unified_execution_engine.py`  
**Responsibility:** Perform actual trade execution

```python
async def execute_authorized_trade(
    self,
    order: Order
) -> ExecutionResult:
    """
    Execute trade according to plan
    
    Steps:
    1. Validate authorization
    2. Execute per algorithm
    3. Monitor fills
    4. Calculate metrics
    5. Report to RiskManager
    """
    
    # Step 1: Validate authorization
    if not self._validate_authorization(order.authorization_id):
        return self._create_rejected_result(order, "Authorization expired or invalid")
    
    # Step 2: Execute based on algorithm
    algorithm = self._get_algorithm_for_order(order)
    if algorithm == ExecutionAlgorithm.MARKET:
        result = await self._execute_market_order(order)
    elif algorithm == ExecutionAlgorithm.TWAP:
        result = await self._execute_twap(order)
    elif algorithm == ExecutionAlgorithm.VWAP:
        result = await self._execute_vwap(order)
    elif algorithm == ExecutionAlgorithm.ADAPTIVE:
        result = await self._execute_adaptive(order)
    else:
        result = await self._execute_market_order(order)
    
    # Step 3: Calculate execution metrics
    result.execution_quality = self._calculate_execution_quality(order, result)
    
    # Step 4: Update OMS
    if result.status == ExecutionStatus.FILLED:
        await self.oms.record_fill(
            order.order_id,
            result.filled_quantity,
            result.avg_fill_price
        )
    
    # Step 5: MANDATORY - Report to RiskManager for position update (Phase 15)
    if result.status == ExecutionStatus.FILLED:
        await self._handle_position_updates(order, result)
    
    return result
```

### Position Update Callback (CRITICAL)

```python
async def _handle_position_updates(self, order: Order, result: ExecutionResult):
    """
    Handle position updates after successful execution
    
    MANDATORY: Update position via Risk Manager ONLY (Rule 3)
    """
    if result.status != ExecutionStatus.FILLED:
        return
    
    if self.risk_manager_callback:
        position_update = await self.risk_manager_callback.update_position(
            symbol=order.symbol,
            side=order.side.lower(),
            quantity=result.filled_quantity,
            price=result.avg_fill_price,
            timestamp=result.execution_timestamp
        )
        
        self.logger.info(
            f"📊 Position updated via RiskManager (Rule 3, Phase 15): "
            f"{order.symbol} {order.side} {result.filled_quantity} @ ${result.avg_fill_price:.2f}"
        )
        
        return position_update
    else:
        self.logger.error("❌ No RiskManager callback - violates Rule 3")
        raise RuntimeError("Cannot update position without RiskManager callback")
```

