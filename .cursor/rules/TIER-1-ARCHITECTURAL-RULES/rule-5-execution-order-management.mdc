## Section 4: Phase 14 - Fill Processing

### Order Rejection Handler

```python
class OrderRejectionHandler(ISystemComponent):
    """Intelligent order rejection handling with retry logic"""
    
    REJECTION_PATTERNS = {
        'INSUFFICIENT_MARGIN': {'action': 'reduce_quantity', 'factor': 0.5},
        'STOCK_HALTED': {'action': 'wait_and_retry', 'wait_seconds': 60},
        'PRICE_COLLAR_VIOLATION': {'action': 'adjust_price'},
        'CONNECTION_TIMEOUT': {'action': 'exponential_backoff', 'delays': [5, 10, 30]},
        'DUPLICATE_ORDER_ID': {'action': 'regenerate_id'},
        'MARKET_CLOSED': {'action': 'cancel'},
        'POSITION_LIMIT_REACHED': {'action': 'escalate'},
        'UNKNOWN_ERROR': {'action': 'escalate'}
    }
    
    async def handle_rejection(
        self,
        order: Order,
        rejection_reason: str,
        rejection_code: str
    ) -> RejectionResolution:
        """Handle order rejection with intelligent retry"""
        
        pattern = self.REJECTION_PATTERNS.get(rejection_code, 
                                               self.REJECTION_PATTERNS['UNKNOWN_ERROR'])
        
        if pattern['action'] == 'reduce_quantity':
            new_quantity = order.quantity * pattern['factor']
            return RejectionResolution(
                action='RETRY',
                modified_order=order._replace(quantity=new_quantity),
                reason=f"Reduced quantity to {new_quantity}"
            )
        
        elif pattern['action'] == 'wait_and_retry':
            await asyncio.sleep(pattern['wait_seconds'])
            return RejectionResolution(action='RETRY', modified_order=order)
        
        elif pattern['action'] == 'exponential_backoff':
            retry_count = order.metadata.get('retry_count', 0)
            if retry_count < len(pattern['delays']):
                await asyncio.sleep(pattern['delays'][retry_count])
                order.metadata['retry_count'] = retry_count + 1
                return RejectionResolution(action='RETRY', modified_order=order)
            else:
                return RejectionResolution(action='ESCALATE', reason='Max retries exceeded')
        
        elif pattern['action'] == 'escalate':
            await self._alert_risk_team(order, rejection_reason)
            return RejectionResolution(action='ESCALATE', reason=rejection_reason)
        
        else:
            return RejectionResolution(action='CANCEL', reason=rejection_reason)
```

