### Market Impact Modeling

#### Almgren-Chriss Optimal Execution Model

```python
def _almgren_chriss_model(self, quantity: float, market_data: Dict[str, Any],
                         liquidity_score: LiquidityScore,
                         participation_rate: float) -> Dict[str, Any]:
    """Almgren-Chriss optimal execution model"""
    
    # Model parameters
    volatility = market_data.get('volatility', 0.02)
    price = market_data.get('price', 100.0)
    
    # Permanent impact (linear in quantity)
    permanent_impact = self.linear_coefficient * participation_rate
    
    # Temporary impact (square root law)
    temporary_impact = self.sqrt_coefficient * np.sqrt(participation_rate)
    
    # Total impact in basis points
    total_impact_bps = (permanent_impact + temporary_impact) * 10000
    permanent_impact_bps = permanent_impact * 10000
    temporary_impact_bps = temporary_impact * 10000
    
    # Execution cost (spread + impact)
    spread_cost_bps = liquidity_score.bid_ask_spread_bps / 2
    execution_cost_bps = spread_cost_bps + total_impact_bps
    
    # Opportunity cost (risk of price moving against us)
    execution_time_minutes = self._estimate_execution_time(participation_rate)
    daily_volatility = volatility / np.sqrt(252)
    time_fraction = execution_time_minutes / (6.5 * 60)
    opportunity_cost_bps = daily_volatility * np.sqrt(time_fraction) * 10000
    
    return {
        'permanent_impact_bps': permanent_impact_bps,
        'temporary_impact_bps': temporary_impact_bps,
        'total_impact_bps': total_impact_bps,
        'execution_cost_bps': execution_cost_bps,
        'opportunity_cost_bps': opportunity_cost_bps,
        'total_cost_bps': execution_cost_bps + opportunity_cost_bps,
        'model_type': 'almgren_chriss'
    }
```

#### Kyle's Lambda Model

```python
def _kyle_model(self, quantity: float, market_data: Dict[str, Any],
               liquidity_score: LiquidityScore,
               participation_rate: float) -> Dict[str, Any]:
    """Kyle's lambda model for market impact"""
    
    volatility = market_data.get('volatility', 0.02)
    avg_volume = liquidity_score.avg_daily_volume
    
    # Kyle's lambda (price impact per unit volume)
    kyle_lambda = volatility / np.sqrt(avg_volume) if avg_volume > 0 else 0.001
    
    # Impact calculation
    total_impact = kyle_lambda * quantity
    total_impact_bps = total_impact * 10000
    
    # Split into permanent and temporary
    permanent_impact_bps = total_impact_bps * self.permanent_impact_factor
    temporary_impact_bps = total_impact_bps * self.temporary_impact_factor
    
    return {
        'permanent_impact_bps': permanent_impact_bps,
        'temporary_impact_bps': temporary_impact_bps,
        'total_impact_bps': total_impact_bps,
        'model_type': 'kyle_lambda'
    }
```

