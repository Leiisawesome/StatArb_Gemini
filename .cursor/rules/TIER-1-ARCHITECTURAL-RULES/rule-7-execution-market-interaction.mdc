            venue_scores, quantity, urgency
        )
        
        return {
            'routing_plan': routing_plan,
            'primary_venue': routing_plan[0] if routing_plan else None,
            'expected_fill_rate': self._calculate_expected_fill_rate(routing_plan),
            'expected_cost_bps': self._calculate_expected_cost(routing_plan),
