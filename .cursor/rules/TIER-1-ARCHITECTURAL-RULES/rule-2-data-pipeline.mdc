## Strategy Implementation

### ✅ CORRECT: Read Pre-Calculated Indicators

```python
class EnhancedMomentumStrategy(EnhancedBaseStrategy):
    async def generate_signals(self, enriched_data: Dict[str, pd.DataFrame]) -> List[StrategySignal]:
        self._validate_enriched_data(enriched_data)
        
        for symbol in self.config.symbols:
            data = enriched_data[symbol]
            
            # READ pre-calculated indicators
            adx = data['ADX_14'].iloc[-1]
            rsi = data['RSI_14'].iloc[-1]
            volume_ratio = data['volume_ratio'].iloc[-1]
            
            # Apply strategy logic ONLY
            if adx > 25 and rsi < 70 and volume_ratio > 1.2:
                signals.append(StrategySignal(...))
        
        return signals
    
    def _validate_enriched_data(self, data: Dict[str, pd.DataFrame]):
        required = ['SMA_10', 'RSI_14', 'ADX_14', 'volume_ratio']
        for symbol, df in data.items():
            missing = [col for col in required if col not in df.columns]
            if missing:
                raise ValueError(f"{symbol} missing indicators: {missing}")
```

### ❌ PROHIBITED: Calculate Own Indicators

```python
class BadStrategy:
    async def generate_signals(self, market_data):
        sma_10 = data['close'].rolling(10).mean()  # ❌ VIOLATES RULE 2
        adx = self._calculate_adx(data)             # ❌ VIOLATES RULE 2
```

