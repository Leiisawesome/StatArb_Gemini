## Section 4: Settlement Management

### Component: SettlementManager

**File:** `core_engine/system/settlement_manager.py`  
**Authority:** OPERATIONAL - Settlement tracking and failure handling

### Settlement Tracking

```python
class SettlementStatus(Enum):
    """Settlement lifecycle states"""
    PENDING = "pending"           # Trade executed, awaiting settlement
    MATCHED = "matched"           # Trade matched with counterparty
    AFFIRMED = "affirmed"         # Trade affirmed
    SETTLING = "settling"         # Settlement in progress
    SETTLED = "settled"           # Settlement complete
    FAILED = "failed"             # Settlement failed
    CANCELLED = "cancelled"       # Trade cancelled before settlement


@dataclass
class SettlementRecord:
    """Settlement tracking record"""
    
    # Identity
    settlement_id: str
    execution_id: str
    order_id: str
    
    # Trade details
    symbol: str
    side: str
    quantity: float
    price: float
    trade_date: date
    settlement_date: date
    
    # Settlement state
    status: SettlementStatus = SettlementStatus.PENDING
    
    # Amounts
    gross_amount: float = 0.0
    net_amount: float = 0.0
    commission: float = 0.0
    fees: float = 0.0
    
    # Counterparty
    counterparty_id: Optional[str] = None
    clearing_broker: Optional[str] = None
    
    # Timestamps
    created_at: datetime = field(default_factory=datetime.now)
    settled_at: Optional[datetime] = None
    
    # Failure tracking
    failure_reason: Optional[str] = None
    retry_count: int = 0


class SettlementManager(ISystemComponent):
    """T+1/T+2 Settlement tracking and management"""
    
    def __init__(self, config: Dict[str, Any]):
        super().__init__()
        self.pending_settlements: Dict[str, SettlementRecord] = {}
        self.settlement_calendar = {}  # Market holidays
        self.default_settlement_days = config.get('settlement_days', 1)  # T+1
        self.max_retries = config.get('max_retries', 3)
    
    def calculate_settlement_date(self, trade_date: date, symbol: str) -> date:
        """Calculate settlement date based on market and instrument"""
        settlement_days = self._get_settlement_days(symbol)
        
        # Add business days (skip weekends and holidays)
        current = trade_date
        days_added = 0
        while days_added < settlement_days:
            current += timedelta(days=1)
            if current.weekday() < 5 and current not in self.settlement_calendar:
                days_added += 1
        
        return current
    
    async def track_pending_settlement(
        self, 
        execution_id: str,
        order_id: str,
        symbol: str,
        side: str,
        quantity: float,
        price: float,
        commission: float = 0.0
    ) -> SettlementRecord:
        """Create settlement tracking record after execution"""
        trade_date = date.today()
        settlement_date = self.calculate_settlement_date(trade_date, symbol)
        
        gross = quantity * price
        net = gross + commission if side == 'buy' else gross - commission
        
        record = SettlementRecord(
            settlement_id=f"STL-{execution_id}",
            execution_id=execution_id,
            order_id=order_id,
            symbol=symbol,
            side=side,
            quantity=quantity,
            price=price,
            trade_date=trade_date,
            settlement_date=settlement_date,
            gross_amount=gross,
            net_amount=net,
            commission=commission
        )
        
        self.pending_settlements[record.settlement_id] = record
        
        self.logger.info(
            f"📋 Settlement tracked: {record.settlement_id} "
            f"{symbol} {side} {quantity}@${price:.2f} "
            f"due {settlement_date}"
        )
        
        return record
    
    async def get_settlement_exposure(self) -> Dict[str, float]:
        """Calculate total settlement exposure"""
        buy_exposure = sum(
            r.net_amount for r in self.pending_settlements.values()
            if r.status == SettlementStatus.PENDING and r.side == 'buy'
        )
        sell_exposure = sum(
            r.net_amount for r in self.pending_settlements.values()
            if r.status == SettlementStatus.PENDING and r.side == 'sell'
        )
        
        return {
            'pending_buys': buy_exposure,
            'pending_sells': sell_exposure,
            'net_exposure': buy_exposure - sell_exposure,
            'total_pending_count': len([
                r for r in self.pending_settlements.values()
                if r.status == SettlementStatus.PENDING
            ]),
            'due_today': len([
                r for r in self.pending_settlements.values()
                if r.settlement_date == date.today()
            ]),
            'overdue': len([
                r for r in self.pending_settlements.values()
                if r.settlement_date < date.today() and r.status == SettlementStatus.PENDING
            ])
        }
    
    async def check_settlement_failures(self) -> List[SettlementRecord]:
        """Check for failed or late settlements"""
        today = date.today()
        failures = []
        
        for record in self.pending_settlements.values():
            if record.status == SettlementStatus.PENDING:
                if record.settlement_date < today:
                    record.status = SettlementStatus.FAILED
                    record.failure_reason = 'settlement_date_passed'
                    failures.append(record)
                    
                    await self._handle_settlement_failure(record)
        
        return failures
    
    async def _handle_settlement_failure(self, record: SettlementRecord):
        """Handle settlement failure"""
        self.logger.error(
            f"❌ Settlement failed: {record.settlement_id} "
            f"{record.symbol} due {record.settlement_date}"
        )
        
        if record.retry_count < self.max_retries:
            # Retry settlement
            record.retry_count += 1
            record.status = SettlementStatus.PENDING
            record.settlement_date = date.today() + timedelta(days=1)
            
            self.logger.info(
                f"🔄 Retry settlement: {record.settlement_id} "
                f"(attempt {record.retry_count}/{self.max_retries})"
            )
        else:
            # Escalate to operations
            await self._escalate_settlement_failure(record)
    
    async def confirm_settlement(self, settlement_id: str) -> SettlementRecord:
        """Confirm settlement completion"""
        record = self.pending_settlements.get(settlement_id)
        if record:
            record.status = SettlementStatus.SETTLED
            record.settled_at = datetime.now()
            
            self.logger.info(
                f"✅ Settlement confirmed: {settlement_id} "
                f"{record.symbol}"
            )
        return record
```

