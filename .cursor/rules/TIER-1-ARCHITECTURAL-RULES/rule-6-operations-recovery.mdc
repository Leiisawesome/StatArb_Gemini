class DiscrepancySeverity(Enum):
    """Position discrepancy severity levels"""
    NONE = "none"           # No discrepancy
    MINOR = "minor"         # <$1K - Log and monitor
    MODERATE = "moderate"   # $1K-$10K - Alert risk team
    SEVERE = "severe"       # >$10K - Auto-correct
