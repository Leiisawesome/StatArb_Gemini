## Section 3: Position Aging Management

### Component: PositionAgingMonitor

**File:** `core_engine/system/position_aging_monitor.py`  
**Schedule:** Hourly check, continuous monitoring  
**Authority:** OPERATIONAL - Can trigger auto-close

### Strategy-Specific Holding Limits

```python
class PositionAgingMonitor(ISystemComponent):
    """Monitor position age with strategy-specific limits"""
    
    # Default holding periods by strategy type
    DEFAULT_HOLDING_PERIODS = {
        'arbitrage': timedelta(days=2),
        'mean_reversion': timedelta(days=3),
        'stat_arb': timedelta(days=5),
        'momentum': timedelta(days=7),
        'breakout': timedelta(days=10),
        'trend_following': timedelta(days=30),
        'default': timedelta(days=5)
    }
    
    def __init__(self, config: Dict[str, Any]):
        super().__init__()
        self.holding_periods = {
            **self.DEFAULT_HOLDING_PERIODS,
            **config.get('holding_periods', {})
        }
        self.age_alerts = defaultdict(list)
        self.auto_close_enabled = config.get('auto_close_enabled', True)
    
    async def check_position_aging(self) -> AgingReport:
        """Check all positions for aging violations"""
        aging_report = AgingReport(timestamp=datetime.now())
        
        positions = await self.risk_manager.get_position_tracking()
        
        for symbol, position_info in positions.items():
            entry_time = position_info['entry_time']
            strategy_id = position_info['strategy_id']
            strategy_type = position_info.get('strategy_type', 'default')
            
            # Get holding limit for this strategy
            max_holding = self.holding_periods.get(
                strategy_type, 
                self.DEFAULT_HOLDING_PERIODS['default']
            )
            
            # Calculate position age
            age = datetime.now() - entry_time
            age_ratio = age / max_holding
            
            # Categorize position
            category = self._categorize_age(age_ratio)
            
            aging_report.add_position(symbol, {
                'age_days': age.days,
                'age_hours': age.total_seconds() / 3600,
                'max_age_days': max_holding.days,
                'age_ratio': age_ratio,
                'category': category,
                'strategy_id': strategy_id,
                'strategy_type': strategy_type
            })
            
            # Take action based on category
            await self._handle_aging_category(symbol, category, position_info, age)
        
        return aging_report
    
    def _categorize_age(self, age_ratio: float) -> PositionAgeCategory:
        """Categorize position by age ratio"""
        if age_ratio < 0.5:
            return PositionAgeCategory.FRESH      # 🟢 <50% of limit
        elif age_ratio < 0.8:
            return PositionAgeCategory.AGING      # 🟡 50-80%
        elif age_ratio < 1.0:
            return PositionAgeCategory.STALE      # 🟠 80-100%
        else:
            return PositionAgeCategory.EXPIRED    # 🔴 >100%
    
    async def _handle_aging_category(
        self, 
        symbol: str, 
        category: PositionAgeCategory,
        position_info: Dict[str, Any],
        age: timedelta
    ):
        """Handle position based on age category"""
        
        if category == PositionAgeCategory.FRESH:
            # Normal operation
            pass
        
        elif category == PositionAgeCategory.AGING:
            # Monitor closely - log warning
            self.logger.warning(
                f"🟡 Position aging: {symbol} held for {age.days} days "
                f"(Strategy: {position_info['strategy_id']})"
            )
        
        elif category == PositionAgeCategory.STALE:
            # Alert trader - prepare to close
            await self._alert_position_stale(symbol, position_info, age)
            self.logger.warning(
                f"🟠 Position stale: {symbol} held for {age.days} days - "
                f"approaching limit! (Strategy: {position_info['strategy_id']})"
            )
        
        elif category == PositionAgeCategory.EXPIRED:
            # Auto-close if enabled
            if self.auto_close_enabled:
                await self._auto_close_expired_position(symbol, position_info, age)
            else:
                await self._alert_expired_position(symbol, position_info, age)
    
    async def _auto_close_expired_position(
        self, 
        symbol: str, 
        position_info: Dict[str, Any],
        age: timedelta
    ):
        """Auto-close expired position"""
        self.logger.warning(
            f"🔴 AUTO-CLOSING expired position: {symbol} "
            f"held for {age.days} days (limit exceeded)"
        )
        
        # Request close through RiskManager
        await self.risk_manager.close_position(
            symbol=symbol,
            reason='holding_period_exceeded',
            urgency='normal',
            metadata={
                'age_days': age.days,
                'strategy_id': position_info['strategy_id'],
                'entry_time': position_info['entry_time'].isoformat()
            }
        )


class PositionAgeCategory(Enum):
    """Position age categories"""
    FRESH = "fresh"       # 🟢 <50% of limit
    AGING = "aging"       # 🟡 50-80% of limit  
    STALE = "stale"       # 🟠 80-100% of limit
    EXPIRED = "expired"   # 🔴 >100% of limit
```

