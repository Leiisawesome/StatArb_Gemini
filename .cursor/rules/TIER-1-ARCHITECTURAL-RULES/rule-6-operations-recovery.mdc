## Section 1: Position Reconciliation

### Component: PositionReconciliationEngine

**File:** `core_engine/system/position_reconciliation.py`  
**Schedule:** Every 5 minutes (1 minute if discrepancies detected)  
**Authority:** OPERATIONAL - Can auto-correct severe discrepancies

### Reconciliation Flow

```python
class PositionReconciliationEngine(ISystemComponent):
    """Broker position reconciliation with auto-correction"""
    
    def __init__(self, config: Dict[str, Any]):
        super().__init__()
        self.reconciliation_interval = config.get('reconciliation_interval', 300)  # 5 min
        self.accelerated_interval = config.get('accelerated_interval', 60)  # 1 min
        self.minor_threshold = config.get('minor_threshold', 1000)  # $1K
        self.moderate_threshold = config.get('moderate_threshold', 10000)  # $10K
        self.severe_threshold = config.get('severe_threshold', 10000)  # $10K (auto-correct)
        
    async def reconcile_positions(self) -> ReconciliationReport:
        """
        Compare internal positions with broker positions
        
        Steps:
        1. Fetch broker positions via API
        2. Compare with CentralRiskManager positions
        3. Calculate discrepancies
        4. Classify severity
        5. Take appropriate action
        """
        
        # Step 1: Fetch broker positions
        broker_positions = await self._fetch_broker_positions()
        
        # Step 2: Get internal positions (READ-ONLY from RiskManager)
        internal_positions = await self.risk_manager.get_all_positions()
        
        # Step 3: Calculate discrepancies
        discrepancies = self._calculate_discrepancies(
            broker_positions, 
            internal_positions
        )
        
        # Step 4: Classify and handle each discrepancy
        for symbol, discrepancy in discrepancies.items():
            severity = self._classify_severity(discrepancy)
            
            if severity == DiscrepancySeverity.MINOR:
                # Log and monitor
                self.logger.info(f"Minor discrepancy: {symbol} ${discrepancy['value_diff']:.2f}")
                
            elif severity == DiscrepancySeverity.MODERATE:
                # Alert risk team
                await self._alert_risk_team(symbol, discrepancy)
                
            elif severity == DiscrepancySeverity.SEVERE:
                # Auto-correct (trust broker)
                await self._auto_correct_position(symbol, discrepancy, broker_positions)
        
        # Step 5: Generate report
        return ReconciliationReport(
            timestamp=datetime.now(),
            discrepancies=discrepancies,
            auto_corrections=self.auto_corrections,
            next_reconciliation=self._calculate_next_reconciliation(discrepancies)
        )
    
    def _classify_severity(self, discrepancy: Dict[str, Any]) -> DiscrepancySeverity:
        """Classify discrepancy severity"""
        value_diff = abs(discrepancy['value_diff'])
        
        if value_diff <= self.minor_threshold:
            return DiscrepancySeverity.MINOR
        elif value_diff <= self.moderate_threshold:
            return DiscrepancySeverity.MODERATE
        else:
            return DiscrepancySeverity.SEVERE
    
    async def _auto_correct_position(
        self, 
        symbol: str, 
        discrepancy: Dict[str, Any],
        broker_positions: Dict[str, float]
    ):
        """
        Auto-correct severe discrepancy
        
        SAFETY: Trust broker position over internal
        """
        broker_position = broker_positions.get(symbol, 0.0)
        
        # Log the correction
        self.logger.warning(
            f"🔧 AUTO-CORRECTING position: {symbol} "
            f"Internal: {discrepancy['internal_qty']:.2f} → "
            f"Broker: {broker_position:.2f}"
        )
        
        # Request correction through RiskManager (Rule 3 compliance)
        await self.risk_manager.force_position_sync(
            symbol=symbol,
            broker_position=broker_position,
            correction_reason='severe_discrepancy_auto_correct',
            original_internal=discrepancy['internal_qty']
        )
        
        # Record the correction
        self.auto_corrections.append({
            'timestamp': datetime.now(),
            'symbol': symbol,
            'from': discrepancy['internal_qty'],
            'to': broker_position,
            'value_diff': discrepancy['value_diff']
        })
        
        # Alert operations team
        await self._notify_operations('POSITION_AUTO_CORRECTION', {
            'symbol': symbol,
            'correction': self.auto_corrections[-1]
        })
```

### Discrepancy Severity Levels

