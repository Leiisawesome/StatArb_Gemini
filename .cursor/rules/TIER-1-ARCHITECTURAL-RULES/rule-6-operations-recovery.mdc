## Section 2: Real-Time P&L Monitoring

### Component: RealTimePnLTracker

**File:** `core_engine/analytics/real_time_pnl.py`  
**Updates:** Every market data tick  
**Integration:** CentralRiskManager + AnalyticsManager

### P&L Tracking Implementation

```python
class RealTimePnLTracker(ISystemComponent):
    """Tick-level P&L tracking with attribution"""
    
    def __init__(self, config: Dict[str, Any]):
        super().__init__()
        self.positions = {}
        self.cost_basis = {}
        self.realized_pnl = 0.0
        self.unrealized_pnl = 0.0
        self.intraday_high = 0.0
        self.intraday_low = float('inf')
        self.strategy_pnl = defaultdict(float)
        self.position_pnl = defaultdict(float)
    
    async def on_market_data_tick(self, symbol: str, price: float):
        """Update P&L on every price tick"""
        if symbol not in self.positions or self.positions[symbol] == 0:
            return
        
        position_qty = self.positions[symbol]
        entry_price = self.cost_basis.get(symbol, price)
        
        # Calculate unrealized P&L for this position
        position_unrealized = (price - entry_price) * position_qty
        self.position_pnl[symbol] = position_unrealized
        
        # Update total unrealized P&L
        self.unrealized_pnl = sum(self.position_pnl.values())
        
        # Update total P&L
        total_pnl = self.realized_pnl + self.unrealized_pnl
        
        # Track intraday high/low
        self.intraday_high = max(self.intraday_high, total_pnl)
        self.intraday_low = min(self.intraday_low, total_pnl)
        
        # Calculate current drawdown
        current_drawdown = total_pnl - self.intraday_high
        
        # Check circuit breaker thresholds
        await self._check_pnl_circuit_breakers(total_pnl, current_drawdown)
        
        # Broadcast P&L update
        await self._broadcast_pnl_update({
            'timestamp': datetime.now(),
            'total_pnl': total_pnl,
            'realized_pnl': self.realized_pnl,
            'unrealized_pnl': self.unrealized_pnl,
            'intraday_high': self.intraday_high,
            'current_drawdown': current_drawdown,
            'position_pnl': dict(self.position_pnl),
            'strategy_pnl': dict(self.strategy_pnl)
        })
    
    async def on_position_closed(
        self, 
        symbol: str, 
        quantity: float, 
        exit_price: float,
        strategy_id: str
    ):
        """Update realized P&L on position close"""
        entry_price = self.cost_basis.get(symbol, exit_price)
        realized = (exit_price - entry_price) * quantity
        
        self.realized_pnl += realized
        self.strategy_pnl[strategy_id] += realized
        
        # Update position
        self.positions[symbol] = self.positions.get(symbol, 0) - quantity
        if self.positions[symbol] == 0:
            del self.position_pnl[symbol]
            del self.cost_basis[symbol]
        
        self.logger.info(
            f"💰 Realized P&L: {symbol} {quantity}@${exit_price:.2f} "
            f"= ${realized:,.2f} (Strategy: {strategy_id})"
        )
    
    async def _check_pnl_circuit_breakers(
        self, 
        total_pnl: float, 
        current_drawdown: float
    ):
        """Check P&L against circuit breaker thresholds"""
        portfolio_value = await self.risk_manager.get_portfolio_value()
        
        # Daily loss limit check (-2%)
        daily_pnl_pct = total_pnl / portfolio_value
        if daily_pnl_pct <= self.daily_loss_limit:
            await self._trigger_circuit_breaker(
                'DAILY_LOSS_LIMIT',
                f"Daily P&L {daily_pnl_pct:.2%} breached {self.daily_loss_limit:.2%} limit"
            )
        
        # Drawdown limit check (-5%)
        drawdown_pct = current_drawdown / portfolio_value
        if drawdown_pct <= self.drawdown_limit:
            await self._trigger_circuit_breaker(
                'DRAWDOWN_LIMIT',
                f"Drawdown {drawdown_pct:.2%} breached {self.drawdown_limit:.2%} limit"
            )
    
    def get_pnl_snapshot(self) -> Dict[str, Any]:
        """Get current P&L snapshot"""
        total_pnl = self.realized_pnl + self.unrealized_pnl
        return {
            'total_pnl': total_pnl,
            'realized_pnl': self.realized_pnl,
            'unrealized_pnl': self.unrealized_pnl,
            'intraday_high': self.intraday_high,
            'intraday_low': self.intraday_low,
            'current_drawdown': total_pnl - self.intraday_high,
            'position_pnl': dict(self.position_pnl),
            'strategy_pnl': dict(self.strategy_pnl)
        }
```

