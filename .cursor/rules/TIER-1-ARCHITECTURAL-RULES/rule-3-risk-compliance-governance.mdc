## Section 3: Phase 8 - Risk Authorization ⭐

### Component: CentralRiskManager

**File:** `core_engine/system/central_risk_manager.py`  
**Layer:** GOVERNANCE_CONTROL  
**Authority:** SINGLE POINT OF AUTHORITY for ALL trades

### 9 Mandatory Authorization Checks

```python
async def authorize_trading_decision(
    self, 
    request: TradingDecisionRequest
) -> TradingAuthorization:
    """
    Authorize or reject trading decision
    
    Performs 9 mandatory checks before authorizing any trade.
    """
    
    # CHECK 1: Signal confidence
    if request.confidence < self.risk_limits.min_signal_confidence:
        return self._reject_authorization(
            request, f"Confidence {request.confidence:.2%} below threshold"
        )
    
    # CHECK 2: Cash availability (BUY orders)
    if request.side.lower() == 'buy':
        required_cash = request.quantity * request.current_price
        if required_cash > self.available_cash:
            max_affordable = self.available_cash / request.current_price
            if max_affordable < request.quantity * 0.5:
                return self._reject_authorization(
                    request, f"Insufficient cash: need ${required_cash:,.2f}"
                )
            else:
                request.quantity = max_affordable  # Partial fill
    
    # CHECK 3: Position availability (SELL orders)
    elif request.side.lower() == 'sell':
        current_position = self.current_positions.get(request.symbol, 0.0)
        if current_position <= 0:
            return self._reject_authorization(
                request, f"No position to sell"
            )
        if request.quantity > current_position:
            request.quantity = current_position
    
    # CHECK 4: Position size limits
    new_position_value = request.quantity * request.current_price
    if new_position_value > self.risk_limits.max_position_size * self.portfolio_value:
        return self._reject_authorization(
            request, f"Position size ${new_position_value:,.2f} exceeds limit"
        )
    
    # CHECK 5: Concentration limits
    concentration = new_position_value / self.portfolio_value
    if concentration > self.risk_limits.max_concentration:
        return self._reject_authorization(
            request, f"Concentration {concentration:.2%} exceeds limit"
        )
    
    # CHECK 6: Daily VaR limits
    current_var = self._calculate_current_var()
    if current_var > self.risk_limits.max_daily_var:
        return self._reject_authorization(
            request, f"Daily VaR {current_var:.2%} exceeds limit"
        )
    
    # CHECK 7: Strategy allocation limits
    strategy_allocation = self._get_strategy_allocation(request.strategy_id)
    if strategy_allocation > self.risk_limits.max_strategy_allocation:
        return self._reject_authorization(
            request, f"Strategy allocation {strategy_allocation:.2%} exceeds limit"
        )
    
    # CHECK 8: Regime-adjusted risk scaling
    regime_multiplier = self._get_regime_risk_multiplier(request.market_regime)
    adjusted_quantity = request.quantity * regime_multiplier
    
    # CHECK 9: Emergency mode
    if self.emergency_mode:
        return self._reject_authorization(
            request, "System in emergency mode - all trades blocked"
        )
    
    # ALL CHECKS PASSED - Authorize trade
    authorization = TradingAuthorization(
        authorization_id=str(uuid.uuid4()),
        request_id=request.request_id,
        authorization_level=AuthorizationLevel.AUTOMATIC,
        authorized=True,
        authorized_quantity=adjusted_quantity,
        authorization_timestamp=datetime.now(),
        risk_budget_allocated=new_position_value * 0.02,
        conditions=['regime_adjusted', 'standard_limits'],
        expiry_time=datetime.now() + timedelta(seconds=request.max_execution_time)
    )
    
    self.active_authorizations[authorization.authorization_id] = authorization
    return authorization
```

