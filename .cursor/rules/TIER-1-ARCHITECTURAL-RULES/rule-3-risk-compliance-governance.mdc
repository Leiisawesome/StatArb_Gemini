## Section 1: Phase 6 - Multi-Strategy Coordination

### Component: StrategyManager

**File:** `core_engine/trading/strategies/manager.py`  
**Layer:** OPERATIONAL  
**Responsibility:** Coordinate multiple strategies and aggregate signals

### Signal Aggregation Pattern

```python
class StrategyManager(ISystemComponent):
    """Multi-strategy coordinator with signal aggregation"""
    
    def __init__(self):
        self.active_strategies = {}
        self.strategy_weights = {}
        self.signal_aggregator = MultiStrategySignalAggregator()
        self.conflict_resolver = SignalConflictResolver()
    
    async def aggregate_strategy_signals(
        self, 
        strategy_signals: Dict[str, List[StrategySignal]]
    ) -> List[TradingDecisionRequest]:
        """
        Aggregate signals from multiple strategies
        
        Steps:
        1. Collect all signals with strategy weights
        2. Group signals by symbol
        3. Resolve conflicts (conflicting signals for same symbol)
        4. Create TradingDecisionRequest for each final signal
        """
        aggregated_signals = []
        
        # Group signals by symbol
        signals_by_symbol = defaultdict(list)
        for strategy_id, signals in strategy_signals.items():
            for signal in signals:
                signals_by_symbol[signal.symbol].append((strategy_id, signal))
        
        # Resolve conflicts and create requests
        for symbol, symbol_signals in signals_by_symbol.items():
            resolved_signal = await self.conflict_resolver.resolve_conflicts(
                symbol_signals
            )
            
            if resolved_signal:
                request = TradingDecisionRequest(
                    decision_type=TradingDecisionType.POSITION_ENTRY,
                    symbol=symbol,
                    side=resolved_signal.signal_type.value,
                    quantity=resolved_signal.quantity,
                    confidence=resolved_signal.confidence,
                    strategy_id=resolved_signal.metadata.get('strategy_id'),
                    market_regime=await self._get_current_regime(),
                    requesting_component='StrategyManager'
                )
                aggregated_signals.append(request)
        
        return aggregated_signals
```

### Signal Conflict Resolution

```python
class SignalConflictResolver:
    """Resolve conflicts between strategy signals"""
    
    async def resolve_conflicts(self, signals: List[Signal]) -> Optional[Signal]:
        """Resolve conflicting signals for the same symbol"""
        if not signals:
            return None
        
        if len(signals) == 1:
            return signals[0]
        
        # Separate by signal type
        buy_signals = [s for s in signals if s.signal_type == SignalType.BUY]
        sell_signals = [s for s in signals if s.signal_type == SignalType.SELL]
        
        if buy_signals and sell_signals:
            # Conflicting signals - use confidence-weighted approach
            return await self._resolve_conflicting_signals(buy_signals, sell_signals)
        elif buy_signals:
            return await self._aggregate_same_direction_signals(buy_signals)
        elif sell_signals:
            return await self._aggregate_same_direction_signals(sell_signals)
        else:
            return None
    
    async def _resolve_conflicting_signals(
        self, 
        buy_signals: List[Signal], 
        sell_signals: List[Signal]
    ) -> Optional[Signal]:
        """Resolve conflicting buy/sell signals"""
        buy_confidence = sum(s.confidence * s.metadata.get('final_weight', 1.0) 
                           for s in buy_signals)
        sell_confidence = sum(s.confidence * s.metadata.get('final_weight', 1.0) 
                            for s in sell_signals)
        
        # 10% bias threshold to avoid flip-flopping
        if buy_confidence > sell_confidence * 1.1:
            return await self._aggregate_same_direction_signals(buy_signals)
        elif sell_confidence > buy_confidence * 1.1:
            return await self._aggregate_same_direction_signals(sell_signals)
        else:
            # Too close - generate HOLD signal
            return Signal(
                symbol=buy_signals[0].symbol,
                signal_type=SignalType.HOLD,
                confidence=0.5,
                quantity=0,
                metadata={'resolution_reason': 'conflicting_signals_too_close'}
            )
```

### Strategy Correlation Analysis

```python
class StrategyCorrelationAnalyzer:
    """Monitor strategy correlation for diversification"""
    
    async def calculate_correlation_matrix(self) -> pd.DataFrame:
        """Calculate daily correlation matrix between strategies"""
        strategy_returns = {}
        for strategy_id, strategy in self.strategies.items():
            returns = await strategy.get_daily_returns()
            strategy_returns[strategy_id] = returns
        
        returns_df = pd.DataFrame(strategy_returns)
        correlation_matrix = returns_df.corr()
        
        # Flag highly correlated pairs (>0.7)
        high_correlations = []
        for i, s1 in enumerate(correlation_matrix.columns):
            for j, s2 in enumerate(correlation_matrix.columns):
                if i < j and correlation_matrix.loc[s1, s2] > 0.7:
                    high_correlations.append((s1, s2, correlation_matrix.loc[s1, s2]))
        
        if high_correlations:
            self.logger.warning(f"High strategy correlations detected: {high_correlations}")
        
        return correlation_matrix
```

