## Section 2: Phase 7 - Pre-Trade Compliance

### Component: PreTradeComplianceChecker

**File:** `core_engine/system/compliance_checker.py`  
**Authority:** GOVERNANCE_CONTROL  
**Priority:** CRITICAL - Regulatory compliance

### 7 Mandatory Compliance Checks

```python
class PreTradeComplianceChecker(ISystemComponent):
    """Pre-trade regulatory compliance validation"""
    
    async def check_pre_trade_compliance(
        self, 
        request: TradingDecisionRequest
    ) -> ComplianceResult:
        """
        Perform 7 mandatory compliance checks
        """
        checks = [
            self._check_restricted_securities(request),
            self._check_hard_to_borrow(request),
            self._check_insider_blackout(request),
            self._check_13d_filing_trigger(request),
            self._check_pattern_day_trading(request),
            self._check_concentration_limits(request),
            self._check_watch_list(request)
        ]
        
        results = await asyncio.gather(*checks)
        
        failed_checks = [r for r in results if not r.passed]
        if failed_checks:
            return ComplianceResult(
                approved=False,
                rejection_reason=failed_checks[0].reason,
                failed_checks=failed_checks
            )
        
        return ComplianceResult(approved=True)
    
    async def _check_restricted_securities(self, request):
        """Check against internal restricted securities list"""
        if request.symbol in self.restricted_securities:
            return CheckResult(passed=False, reason="Restricted security")
        return CheckResult(passed=True)
    
    async def _check_hard_to_borrow(self, request):
        """Check Reg SHO share locate for short sales"""
        if request.side == 'sell' and not self._has_position(request.symbol):
            if not await self._locate_shares(request.symbol, request.quantity):
                return CheckResult(passed=False, reason="HTB: No shares to locate")
        return CheckResult(passed=True)
    
    async def _check_insider_blackout(self, request):
        """Check earnings blackouts and MNPI periods"""
        if await self._is_in_blackout_period(request.symbol):
            return CheckResult(passed=False, reason="Insider blackout period")
        return CheckResult(passed=True)
    
    async def _check_13d_filing_trigger(self, request):
        """Check 5% ownership disclosure requirements"""
        projected_ownership = await self._calculate_ownership_pct(
            request.symbol, request.quantity
        )
        if projected_ownership >= 0.05:
            return CheckResult(passed=False, reason="13D filing triggered")
        return CheckResult(passed=True)
    
    async def _check_pattern_day_trading(self, request):
        """Check PDT rules: 4 trades in 5 days, $25K minimum"""
        if self.account_value < 25000:
            day_trades = await self._count_day_trades_last_5_days()
            if day_trades >= 3:
                return CheckResult(passed=False, reason="PDT limit reached")
        return CheckResult(passed=True)
    
    async def _check_concentration_limits(self, request):
        """Check position concentration limits"""
        # Handled in Phase 8, but pre-check here
        return CheckResult(passed=True)
    
    async def _check_watch_list(self, request):
        """Check compliance watch list"""
        if request.symbol in self.watch_list:
            await self._alert_compliance_team(request)
        return CheckResult(passed=True)
```

