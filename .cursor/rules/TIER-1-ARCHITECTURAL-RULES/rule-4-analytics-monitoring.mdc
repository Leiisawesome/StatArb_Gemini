## Section 4: Regime-Aware Analytics

```python
class RegimeAwareAnalytics(IAnalyticsComponent):
    """Analytics that adapt to market regime conditions"""
    
    def __init__(self, regime_engine):
        super().__init__()
        self.regime_engine = regime_engine
        self.regime_metrics = defaultdict(dict)
    
    async def get_regime_aware_metrics(
        self, 
        regime_context: Dict[str, Any]
    ) -> Dict[str, Any]:
        """Get metrics adjusted for current market regime"""
        current_regime = regime_context.get('primary_regime')
        volatility_regime = regime_context.get('volatility_regime')
        
        regime_adjustments = {
            'low_volatility': {
                'risk_multiplier': 1.2,
                'confidence_threshold': 0.5,
                'position_sizing_factor': 1.1
            },
            'normal_volatility': {
                'risk_multiplier': 1.0,
                'confidence_threshold': 0.6,
                'position_sizing_factor': 1.0
            },
            'high_volatility': {
                'risk_multiplier': 0.7,
                'confidence_threshold': 0.7,
                'position_sizing_factor': 0.8
            },
            'extreme_volatility': {
                'risk_multiplier': 0.4,
                'confidence_threshold': 0.8,
                'position_sizing_factor': 0.5
            }
        }
        
        adjustments = regime_adjustments.get(
            volatility_regime, 
            regime_adjustments['normal_volatility']
        )
        
        return {
            'current_regime': current_regime,
            'volatility_regime': volatility_regime,
            'regime_adjustments': adjustments,
            'regime_confidence': regime_context.get('confidence', 0.5),
            'regime_duration': regime_context.get('duration_days', 0),
            'expected_regime_persistence': await self._calculate_regime_persistence(current_regime)
        }
```

