## Section 3: Performance Attribution Framework

### Multi-Strategy Attribution

```python
class MultiStrategyAttributionAnalyzer(IAnalyticsComponent):
    """Advanced performance attribution across multiple strategies"""
    
    def __init__(self):
        super().__init__()
        self.strategy_returns = defaultdict(list)
        self.factor_exposures = defaultdict(dict)
        self.attribution_cache = {}
    
    async def calculate_strategy_attribution(
        self, 
        portfolio_returns: pd.Series, 
        strategy_returns: Dict[str, pd.Series]
    ) -> Dict[str, Any]:
        """Calculate performance attribution by strategy"""
        
        attribution_results = {}
        total_portfolio_return = portfolio_returns.sum()
        
        for strategy_id, returns in strategy_returns.items():
            strategy_contribution = returns.sum()
            contribution_percentage = (
                strategy_contribution / total_portfolio_return 
                if total_portfolio_return != 0 else 0
            )
            
            sharpe_ratio = self._calculate_sharpe_ratio(returns)
            max_drawdown = self._calculate_max_drawdown(returns)
            calmar_ratio = (
                returns.mean() * 252 / abs(max_drawdown) 
                if max_drawdown != 0 else 0
            )
            
            factor_attribution = await self._calculate_factor_attribution(
                strategy_id, returns
            )
            
            attribution_results[strategy_id] = {
                'total_return': strategy_contribution,
                'contribution_percentage': contribution_percentage,
                'sharpe_ratio': sharpe_ratio,
                'max_drawdown': max_drawdown,
                'calmar_ratio': calmar_ratio,
                'volatility': returns.std() * np.sqrt(252),
                'factor_attribution': factor_attribution,
                'trade_count': len(returns[returns != 0]),
                'win_rate': (
                    len(returns[returns > 0]) / len(returns[returns != 0]) 
                    if len(returns[returns != 0]) > 0 else 0
                )
            }
        
        return attribution_results
    
    async def _calculate_factor_attribution(
        self, 
        strategy_id: str, 
        returns: pd.Series
    ) -> Dict[str, float]:
        """Calculate factor-based attribution (Fama-French, etc.)"""
        return {
            'market_factor': 0.0,
            'size_factor': 0.0,
            'value_factor': 0.0,
            'momentum_factor': 0.0,
            'quality_factor': 0.0,
            'alpha': 0.0
        }
```

