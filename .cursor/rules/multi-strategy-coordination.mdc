## 3. Multi-Strategy Signal Aggregation

### Strategy Manager Coordination
```python
class EnhancedStrategyManager(ISystemComponent):
    """Enhanced strategy manager with multi-strategy coordination"""
    
    def __init__(self):
        super().__init__()
        self.active_strategies = {}
        self.strategy_weights = {}
        self.signal_aggregator = MultiStrategySignalAggregator()
        self.conflict_resolver = SignalConflictResolver()
    
    async def aggregate_strategy_signals(self, strategy_signals: Dict[str, List[Signal]]) -> List[Signal]:
        """Aggregate signals from multiple strategies"""
        try:
            # Step 1: Collect all signals with weights
            weighted_signals = []
            for strategy_id, signals in strategy_signals.items():
                strategy_weight = self.strategy_weights.get(strategy_id, 1.0)
                
                for signal in signals:
                    weighted_signal = signal.copy()
                    weighted_signal.confidence *= strategy_weight
                    weighted_signal.metadata['final_weight'] = strategy_weight
                    weighted_signals.append(weighted_signal)
            
            # Step 2: Group signals by symbol
            signals_by_symbol = defaultdict(list)
            for signal in weighted_signals:
                signals_by_symbol[signal.symbol].append(signal)
            
            # Step 3: Resolve conflicts and aggregate
            aggregated_signals = []
            for symbol, symbol_signals in signals_by_symbol.items():
                resolved_signal = await self.conflict_resolver.resolve_conflicts(symbol_signals)
                if resolved_signal:
                    aggregated_signals.append(resolved_signal)
            
            return aggregated_signals
            
        except Exception as e:
            self.logger.error(f"Signal aggregation failed: {e}")
            return []
```

### Signal Conflict Resolution
```python
class SignalConflictResolver:
    """Resolve conflicts between strategy signals"""
    
    async def resolve_conflicts(self, signals: List[Signal]) -> Optional[Signal]:
        """Resolve conflicting signals for the same symbol"""
        if not signals:
            return None
        
        if len(signals) == 1:
            return signals[0]
        
        # Separate by signal type
        buy_signals = [s for s in signals if s.signal_type == SignalType.BUY]
        sell_signals = [s for s in signals if s.signal_type == SignalType.SELL]
        hold_signals = [s for s in signals if s.signal_type == SignalType.HOLD]
        
        # Resolution strategies
        if buy_signals and sell_signals:
            # Conflicting signals - use confidence-weighted approach
            return await self._resolve_conflicting_signals(buy_signals, sell_signals)
        elif buy_signals:
            # Aggregate buy signals
            return await self._aggregate_same_direction_signals(buy_signals)
        elif sell_signals:
            # Aggregate sell signals
            return await self._aggregate_same_direction_signals(sell_signals)
        else:
            # Only hold signals
            return hold_signals[0] if hold_signals else None
    
    async def _resolve_conflicting_signals(self, buy_signals: List[Signal], sell_signals: List[Signal]) -> Optional[Signal]:
        """Resolve conflicting buy/sell signals"""
        # Calculate weighted confidence for each direction
        buy_confidence = sum(s.confidence * s.metadata.get('final_weight', 1.0) for s in buy_signals)
        sell_confidence = sum(s.confidence * s.metadata.get('final_weight', 1.0) for s in sell_signals)
        
        # Choose direction with higher weighted confidence
        if buy_confidence > sell_confidence * 1.1:  # 10% bias threshold
            return await self._aggregate_same_direction_signals(buy_signals)
        elif sell_confidence > buy_confidence * 1.1:
            return await self._aggregate_same_direction_signals(sell_signals)
        else:
            # Too close - generate hold signal
            return Signal(
                symbol=buy_signals[0].symbol,
                signal_type=SignalType.HOLD,
                confidence=0.5,
                quantity=0,
                timestamp=datetime.now(),
                metadata={'resolution_reason': 'conflicting_signals_too_close'}
            )
    
    async def _aggregate_same_direction_signals(self, signals: List[Signal]) -> Signal:
        """Aggregate signals in the same direction"""
        if not signals:
            return None
        
        # Weighted average of confidence and quantity
        total_weight = sum(s.metadata.get('final_weight', 1.0) for s in signals)
        weighted_confidence = sum(s.confidence * s.metadata.get('final_weight', 1.0) for s in signals) / total_weight
        weighted_quantity = sum(s.quantity * s.metadata.get('final_weight', 1.0) for s in signals) / total_weight
        
        # Create aggregated signal
        aggregated_signal = Signal(
            symbol=signals[0].symbol,
            signal_type=signals[0].signal_type,
            confidence=min(weighted_confidence, 1.0),  # Cap at 1.0
            quantity=weighted_quantity,
            timestamp=max(s.timestamp for s in signals),  # Use latest timestamp
            metadata={
                'aggregated_from': [s.metadata.get('strategy_id') for s in signals],
                'contributing_strategies': len(signals),
                'aggregation_method': 'weighted_average',
                'original_confidences': [s.confidence for s in signals]
            }
        )
        
        return aggregated_signal
```

## 4. Strategy-Specific Risk Limits

### Individual Strategy Risk Management
```python
class StrategyRiskManager:
    """Manage risk limits for individual strategies"""
    
    def __init__(self, strategy_id: str, risk_config: Dict[str, Any]):
        self.strategy_id = strategy_id
        self.risk_limits = {
            'max_position_size': risk_config.get('max_position_size', 0.05),  # 5% per strategy
            'max_daily_trades': risk_config.get('max_daily_trades', 10),
            'max_drawdown': risk_config.get('max_drawdown', 0.02),  # 2% max drawdown
            'min_confidence_threshold': risk_config.get('min_confidence_threshold', 0.6)
        }
        self.current_positions = {}
        self.daily_trade_count = 0
        self.current_drawdown = 0.0
    
    async def validate_signal(self, signal: Signal) -> Tuple[bool, str]:
        """Validate signal against strategy-specific risk limits"""
        
        # Check confidence threshold
        if signal.confidence < self.risk_limits['min_confidence_threshold']:
            return False, f"Signal confidence {signal.confidence} below threshold {self.risk_limits['min_confidence_threshold']}"
        
        # Check position size limits
        current_position = self.current_positions.get(signal.symbol, 0.0)
        new_position = current_position + signal.quantity
        if abs(new_position) > self.risk_limits['max_position_size']:
            return False, f"Position size {abs(new_position)} exceeds limit {self.risk_limits['max_position_size']}"
        
        # Check daily trade limits
        if self.daily_trade_count >= self.risk_limits['max_daily_trades']:
            return False, f"Daily trade limit {self.risk_limits['max_daily_trades']} exceeded"
        
        # Check drawdown limits
        if self.current_drawdown > self.risk_limits['max_drawdown']:
            return False, f"Current drawdown {self.current_drawdown} exceeds limit {self.risk_limits['max_drawdown']}"
        
        return True, "Signal validated"
```

## 5. Performance Attribution by Strategy

### Strategy Performance Tracking
```python
class MultiStrategyPerformanceTracker:
    """Track performance attribution across multiple strategies"""
    
    def __init__(self):
        self.strategy_performance = defaultdict(lambda: {
            'total_return': 0.0,
            'trade_count': 0,
            'win_rate': 0.0,
            'avg_return_per_trade': 0.0,
            'max_drawdown': 0.0,
            'sharpe_ratio': 0.0,
            'contribution_to_portfolio': 0.0
        })
    
    async def update_strategy_performance(self, strategy_id: str, trade_result: TradeResult):
        """Update performance metrics for a specific strategy"""
        perf = self.strategy_performance[strategy_id]
        
        # Update basic metrics
        perf['total_return'] += trade_result.pnl
        perf['trade_count'] += 1
        
        # Update win rate
        if trade_result.pnl > 0:
            perf['winning_trades'] = perf.get('winning_trades', 0) + 1
        perf['win_rate'] = perf.get('winning_trades', 0) / perf['trade_count']
        
        # Update average return per trade
        perf['avg_return_per_trade'] = perf['total_return'] / perf['trade_count']
        
        # Update contribution to portfolio
        total_portfolio_return = sum(s['total_return'] for s in self.strategy_performance.values())
        if total_portfolio_return != 0:
            perf['contribution_to_portfolio'] = perf['total_return'] / total_portfolio_return
    
    async def get_strategy_attribution(self) -> Dict[str, Dict[str, float]]:
        """Get performance attribution by strategy"""
        return dict(self.strategy_performance)
```

## 6. PROHIBITED Multi-Strategy Patterns

❌ **Direct Strategy Communication**: Strategies must communicate through StrategyManager
❌ **Independent Signal Emission**: All signals must go through coordination system
❌ **Bypassing Conflict Resolution**: Cannot skip signal aggregation process
❌ **Unweighted Signal Aggregation**: Must use proper weighting schemes
❌ **Strategy Isolation**: Strategies must participate in coordination framework

## 7. MANDATORY Multi-Strategy Requirements

1. **Strategy Registration**: All strategies register with StrategyManager
2. **Signal Coordination**: All signals participate in aggregation process
3. **Conflict Resolution**: Implement proper conflict resolution mechanisms
4. **Risk Attribution**: Track risk and performance by strategy
5. **Unified Authorization**: All aggregated signals require CentralRiskManager authorization

This multi-strategy coordination framework ensures **systematic signal aggregation**, **conflict resolution**, and **unified risk management** across all trading strategies.