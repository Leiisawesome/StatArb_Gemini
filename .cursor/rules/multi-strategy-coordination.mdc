## 3. Signal Coordination Pattern

### Signal Generation with Metadata
```python
async def generate_signals(self, market_data: pd.DataFrame) -> List[Signal]:
    """Generate signals with coordination metadata"""
    signals = []
    
    for signal in self._calculate_raw_signals(market_data):
        # Enhance signal with coordination metadata
        enhanced_signal = Signal(
            symbol=signal.symbol,
            signal_type=signal.signal_type,
            confidence=signal.confidence,
            quantity=signal.quantity,
            timestamp=signal.timestamp,
            metadata={
                'strategy_id': self.strategy_id,
                'strategy_type': self.__class__.__name__,
                'signal_source': 'primary_algorithm',
                'regime_context': await self.get_regime_context(),
                'risk_factors': await self.calculate_risk_factors(signal),
                'coordination_weight': self.config.strategy_weight
            }
        )
        signals.append(enhanced_signal)
    
    return signals
```

