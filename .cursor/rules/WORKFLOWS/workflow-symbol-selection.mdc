### 2. Helper Functions for Symbol Selection
```python
def calculate_turnover(old_selection, new_selection):
    """Calculate portfolio turnover between selections"""
    if not old_selection:
        return 1.0  # 100% turnover for initial selection
    
    old_set = set(old_selection)
    new_set = set(new_selection)
    
    # Calculate turnover as percentage of portfolio changed
    total_positions = len(old_set.union(new_set))
    unchanged_positions = len(old_set.intersection(new_set))
    
    turnover = (total_positions - unchanged_positions) / max(len(old_set), len(new_set))
    return turnover

def calculate_transaction_costs(turnover, market_data):
    """Calculate estimated transaction costs"""
    # Simple linear transaction cost model
    base_cost_bps = 10  # 10 basis points base cost
    market_impact_bps = turnover * 5  # Additional market impact
    
    total_cost_bps = base_cost_bps + market_impact_bps
    return total_cost_bps / 10000  # Convert to decimal

def calculate_selection_performance(selected_symbols, market_data, date):
    """Calculate daily performance of selected symbols"""
    if not selected_symbols:
        return 0.0
    
    # Equal weight performance calculation
    daily_returns = []
    for symbol in selected_symbols:
        if symbol in market_data.columns:
            symbol_return = market_data[symbol].pct_change().iloc[-1]
            if not pd.isna(symbol_return):
                daily_returns.append(symbol_return)
    
    if daily_returns:
        return np.mean(daily_returns)
    else:
        return 0.0

async def generate_symbol_selection_report(performance_analysis, backtest_results):
    """Generate comprehensive symbol selection report"""
    
    report = {
        'executive_summary': {
            'total_return': f"{performance_analysis['overall_performance']['total_return']:.2%}",
            'annualized_return': f"{performance_analysis['overall_performance']['annualized_return']:.2%}",
            'sharpe_ratio': f"{performance_analysis['overall_performance']['sharpe_ratio']:.2f}",
            'max_drawdown': f"{performance_analysis['overall_performance']['max_drawdown']:.2%}",
            'average_turnover': f"{performance_analysis['overall_performance']['average_turnover']:.2%}"
        },
        'regime_analysis': performance_analysis['regime_specific_performance'],
        'factor_attribution': performance_analysis['factor_attribution'],
        'selection_quality': performance_analysis['selection_quality_metrics'],
        'recommendations': generate_selection_recommendations(performance_analysis)
    }
    
    return report

def generate_selection_recommendations(performance_analysis):
    """Generate actionable recommendations based on analysis"""
    
    recommendations = []
    
    # Performance-based recommendations
    if performance_analysis['overall_performance']['sharpe_ratio'] < 1.0:
        recommendations.append("Consider increasing factor diversification to improve risk-adjusted returns")
    
    if performance_analysis['overall_performance']['average_turnover'] > 0.3:
        recommendations.append("High turnover detected - consider increasing minimum holding periods")
    
    # Regime-specific recommendations
    regime_perf = performance_analysis['regime_specific_performance']
    worst_regime = min(regime_perf.keys(), key=lambda x: regime_perf[x]['return'])
    recommendations.append(f"Focus on improving performance in {worst_regime} regime")
    
    # Factor timing recommendations
    if performance_analysis['selection_quality_metrics']['factor_timing_effectiveness'] < 0.5:
        recommendations.append("Consider improving factor timing model or reducing factor rotation frequency")
    
    return recommendations
