## Symbol Selection Workflow Implementation

### 1. Complete Symbol Selection Workflow
```python
from core_engine.system.integration_manager import SystemIntegrationManager
from core_engine.selection.workflow import SymbolSelectionWorkflow

async def run_symbol_selection_workflow():
    """Complete symbol selection and ranking workflow"""
    
    # Initialize system
    integration_manager = SystemIntegrationManager(production_config)
    await integration_manager.initialize_all_components()
    
    # Initialize symbol selection workflow
    selection_workflow = SymbolSelectionWorkflow(
        universe_config=universe_config,
        regime_config=regime_selection_config,
        ranking_config=ranking_config,
        dynamic_config=dynamic_selection_config,
        backtest_config=backtest_config
    )
    
    # Step 1: Initialize universe and data
    print("🔍 Initializing symbol universe...")
    universe = await selection_workflow.initialize_universe()
    print(f"✅ Universe initialized with {len(universe)} symbols")
    
    # Step 2: Load historical data for backtesting
    print("📊 Loading historical data...")
    data_manager = integration_manager.get_component('ClickHouseDataManager')
    historical_data = await data_manager.load_historical_data(
        symbols=universe,
        start_date=backtest_config.start_date,
        end_date=backtest_config.end_date
    )
    print(f"✅ Loaded data for {len(historical_data.columns)} symbols")
    
    # Step 3: Run regime-aware symbol selection backtest
    print("🎯 Running regime-aware symbol selection backtest...")
    backtest_results = await run_regime_aware_selection_backtest(
        selection_workflow, historical_data, integration_manager
    )
    
    # Step 4: Analyze results and generate report
    print("📈 Analyzing selection performance...")
    performance_report = await analyze_selection_performance(
        backtest_results, integration_manager
    )
    
    return performance_report

async def run_regime_aware_selection_backtest(selection_workflow, historical_data, integration_manager):
    """Run comprehensive regime-aware symbol selection backtest"""
    
    regime_engine = integration_manager.get_component('EnhancedRegimeEngine')
    ranking_engine = integration_manager.get_component('SymbolRankingEngine')
    
    backtest_results = {
        'daily_selections': {},
        'regime_transitions': {},
        'performance_metrics': {},
        'attribution_analysis': {}
    }
    
    current_selection = []
    
    # Iterate through backtesting period
    for date in pd.date_range(start=backtest_config.start_date, end=backtest_config.end_date, freq='D'):
        try:
            # Get market data for current date
            current_data = historical_data[historical_data.index.date <= date.date()]
            
            if len(current_data) < 60:  # Need minimum history
                continue
            
            # Step 1: Determine current market regime
            regime_analysis = await regime_engine.analyze_regime(current_data)
            current_regime = regime_analysis['primary_regime']
            regime_confidence = regime_analysis['confidence']
            
            # Step 2: Check if rebalancing is needed
            rebalance_needed = await selection_workflow.check_rebalancing_triggers(
                date, current_regime, current_selection, current_data
            )
            
            if rebalance_needed:
                print(f"🔄 Rebalancing on {date.strftime('%Y-%m-%d')} - Regime: {current_regime}")
                
                # Step 3: Calculate symbol rankings for current regime
                symbol_rankings = await ranking_engine.calculate_regime_aware_rankings(
                    current_data, current_regime, regime_confidence
                )
                
                # Step 4: Select top symbols based on regime and strategy requirements
                new_selection = await selection_workflow.select_symbols(
                    symbol_rankings, current_regime, date
                )
                
                # Step 5: Calculate turnover and transaction costs
                turnover = calculate_turnover(current_selection, new_selection)
                transaction_costs = calculate_transaction_costs(turnover, current_data)
                
                # Update current selection
                current_selection = new_selection
                
                # Record selection
                backtest_results['daily_selections'][date] = {
                    'selected_symbols': new_selection,
                    'regime': current_regime,
                    'regime_confidence': regime_confidence,
                    'turnover': turnover,
                    'transaction_costs': transaction_costs,
                    'rankings': symbol_rankings
                }
            
            # Step 6: Calculate daily performance
            if current_selection:
                daily_performance = calculate_selection_performance(
                    current_selection, current_data, date
                )
                
                backtest_results['performance_metrics'][date] = daily_performance
        
        except Exception as e:
            print(f"⚠️ Error processing {date}: {e}")
            continue
    
    return backtest_results

async def analyze_selection_performance(backtest_results, integration_manager):
    """Analyze symbol selection performance with comprehensive metrics"""
    
    analytics_manager = integration_manager.get_component('EnhancedAnalyticsManager')
    
    # Calculate comprehensive performance metrics
    performance_analysis = {
        'overall_performance': {},
        'regime_specific_performance': {},
        'factor_attribution': {},
        'risk_analysis': {},
        'selection_quality_metrics': {}
    }
    
    # Overall performance metrics
    daily_returns = extract_daily_returns(backtest_results['performance_metrics'])
    
    performance_analysis['overall_performance'] = {
        'total_return': calculate_total_return(daily_returns),
        'annualized_return': calculate_annualized_return(daily_returns),
        'sharpe_ratio': calculate_sharpe_ratio(daily_returns),
        'sortino_ratio': calculate_sortino_ratio(daily_returns),
        'max_drawdown': calculate_max_drawdown(daily_returns),
        'calmar_ratio': calculate_calmar_ratio(daily_returns),
        'hit_rate': calculate_hit_rate(daily_returns),
        'average_turnover': calculate_average_turnover(backtest_results['daily_selections'])
    }
    
    # Regime-specific performance analysis
    regime_performance = {}
    for regime in ['low_volatility', 'normal_volatility', 'high_volatility', 'trending_up', 'trending_down', 'sideways']:
        regime_returns = extract_regime_specific_returns(backtest_results, regime)
        if len(regime_returns) > 0:
            regime_performance[regime] = {
                'return': calculate_total_return(regime_returns),
                'sharpe': calculate_sharpe_ratio(regime_returns),
                'max_dd': calculate_max_drawdown(regime_returns),
                'hit_rate': calculate_hit_rate(regime_returns)
            }
    
    performance_analysis['regime_specific_performance'] = regime_performance
    
    # Factor attribution analysis
    performance_analysis['factor_attribution'] = await analytics_manager.calculate_factor_attribution(
        backtest_results, ['momentum', 'quality', 'value', 'growth', 'size', 'volatility']
    )
    
    # Selection quality metrics
    performance_analysis['selection_quality_metrics'] = {
        'average_symbols_selected': calculate_average_selection_size(backtest_results['daily_selections']),
        'selection_consistency': calculate_selection_consistency(backtest_results['daily_selections']),
        'regime_adaptation_effectiveness': calculate_regime_adaptation_effectiveness(backtest_results),
        'factor_timing_effectiveness': calculate_factor_timing_effectiveness(backtest_results)
    }
    
    # Generate comprehensive report
    report = await generate_symbol_selection_report(performance_analysis, backtest_results)
    
    return report
