class SignalConflictResolver(ISystemComponent):
    """Resolve signal conflicts with institutional standards"""
    
    def __init__(self, config: Dict[str, Any]):
        super().__init__()
        self.config = config
        self.conflict_resolution_strategies = {
            'confidence_weighted': self._resolve_by_confidence,
            'time_weighted': self._resolve_by_timeliness,
            'regime_aware': self._resolve_by_regime,
            'ensemble': self._resolve_by_ensemble
        }
    
    async def resolve_signal_conflicts(self, signals: List[Signal]) -> List[Signal]:
        """Resolve signal conflicts using advanced algorithms"""
        
        if not signals:
            return []
        
        # Group signals by symbol
        signals_by_symbol = self._group_signals_by_symbol(signals)
        
        resolved_signals = []
        for symbol, symbol_signals in signals_by_symbol.items():
            if len(symbol_signals) == 1:
                resolved_signals.append(symbol_signals[0])
            else:
                resolved_signal = await self._resolve_symbol_conflicts(symbol_signals)
                if resolved_signal:
                    resolved_signals.append(resolved_signal)
        
        logger.info(f"✅ Signal conflict resolution: {len(signals)} → {len(resolved_signals)} signals")
        return resolved_signals
    
    async def _resolve_symbol_conflicts(self, signals: List[Signal]) -> Optional[Signal]:
        """Resolve conflicts for signals of the same symbol"""
        
        # Separate by signal type
        buy_signals = [s for s in signals if s.signal_type == SignalType.BUY]
        sell_signals = [s for s in signals if s.signal_type == SignalType.SELL]
        hold_signals = [s for s in signals if s.signal_type == SignalType.HOLD]
        
        # Resolution strategies
        if buy_signals and sell_signals:
            # Conflicting signals - use confidence-weighted approach
            return await self._resolve_conflicting_signals(buy_signals, sell_signals)
        elif buy_signals:
            return await self._aggregate_same_direction_signals(buy_signals)
        elif sell_signals:
            return await self._aggregate_same_direction_signals(sell_signals)
        else:
            return hold_signals[0] if hold_signals else None
