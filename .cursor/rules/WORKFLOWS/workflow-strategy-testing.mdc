            'regime_context': regime_context.primary_regime if regime_context else 'unknown'
        }
    
    def _create_composite_objective(self, objectives: List[str], weights: Dict[str, float]) -> Callable:
        """Create composite objective function from multiple objectives"""
        
        def composite_objective(parameters: Dict[str, Any]) -> float:
            total_score = 0.0
            total_weight = 0.0
            
            for objective in objectives:
                weight = weights.get(objective, 1.0)
                objective_function = self.objective_functions[objective]
                objective_value = objective_function(parameters)
                
                # Normalize objective value (0-1 scale)
                normalized_value = self._normalize_objective_value(objective, objective_value)
                
                total_score += normalized_value * weight
                total_weight += weight
            
            return total_score / total_weight if total_weight > 0 else 0.0
        
        return composite_objective
```

