class StrategyOptimizer(ISystemComponent):
    """Enhanced strategy optimization with full compliance"""
    
    def __init__(self, config: Dict[str, Any], 
                 strategy: EnhancedBaseStrategy,
                 regime_engine: EnhancedRegimeEngine,
                 risk_manager: CentralRiskManager):
        super().__init__()
        self.config = config
        self.strategy = strategy
        self.regime_engine = regime_engine
        self.risk_manager = risk_manager
        self.optimization_results = {}
        self.current_regime_context: Optional[RegimeContext] = None
    
    async def optimize_strategy_parameters(self, 
                                        parameter_space: Dict[str, Any],
                                        optimization_objectives: List[str]) -> Dict[str, Any]:
        """Optimize strategy parameters with regime awareness (Rule 13)"""
        
        # STEP 1: Get current regime context (MANDATORY - Rule 13)
        self.current_regime_context = await self.regime_engine.get_current_regime_context()
        
        if not self.current_regime_context:
            logger.error("❌ Cannot optimize without regime context")
            return {'error': 'No regime context available'}
        
        # STEP 2: Adjust parameter space based on regime
        regime_adjusted_space = await self._adjust_parameter_space_for_regime(
            parameter_space, self.current_regime_context
        )
        
        # STEP 3: Run optimization with regime awareness
        optimization_result = await self._run_regime_aware_optimization(
            regime_adjusted_space, optimization_objectives, self.current_regime_context
        )
        
        # STEP 4: Validate optimization results
        validated_result = await self._validate_optimization_results(
            optimization_result, self.current_regime_context
        )
        
        logger.info(f"✅ Strategy optimization completed for regime: {self.current_regime_context.primary_regime}")
        return validated_result
    
    async def _adjust_parameter_space_for_regime(self, 
                                               parameter_space: Dict[str, Any],
                                               regime_context: RegimeContext) -> Dict[str, Any]:
        """Adjust parameter space based on regime conditions"""
        
        regime_adjustments = {
            'low_volatility': {
                'momentum_threshold': 0.8,  # Lower threshold in low vol
                'lookback_period': 1.2     # Longer lookback
            },
            'high_volatility': {
                'momentum_threshold': 1.3,  # Higher threshold in high vol
                'lookback_period': 0.8     # Shorter lookback
            },
            'extreme_volatility': {
                'momentum_threshold': 1.5,  # Much higher threshold
                'lookback_period': 0.6     # Much shorter lookback
            }
        }
        
        adjustments = regime_adjustments.get(regime_context.volatility_regime, {})
        adjusted_space = parameter_space.copy()
        
        for param, multiplier in adjustments.items():
            if param in adjusted_space:
                if 'min' in adjusted_space[param] and 'max' in adjusted_space[param]:
                    adjusted_space[param]['min'] *= multiplier
                    adjusted_space[param]['max'] *= multiplier
        
        return adjusted_space
