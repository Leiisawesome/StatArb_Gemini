class MomentumParameterOptimizer:
    """Momentum strategy parameter optimization with regime adaptation"""
    
    def __init__(self, base_config: Dict[str, Any]):
        self.base_config = base_config
        self.parameter_space = {
            'lookback_period': {'min': 5, 'max': 100, 'step': 5},
            'momentum_threshold': {'min': 0.01, 'max': 0.10, 'step': 0.005},
            'volatility_threshold': {'min': 0.05, 'max': 0.50, 'step': 0.05}
        }
    
    async def optimize_for_regime(self, regime_context: RegimeContext, 
                                historical_data: pd.DataFrame) -> Dict[str, Any]:
        """Optimize momentum parameters for specific regime"""
        
        # Get regime-specific parameter ranges
        regime_ranges = self._get_regime_parameter_ranges(regime_context)
        
        # Run optimization
        optimizer = BacktestOptimizerInterface(self.base_config)
        optimization_result = await optimizer.optimize_parameters(
            strategy_type='momentum',
            parameter_space=regime_ranges,
            historical_data=historical_data,
            regime_context=regime_context
        )
        
        return optimization_result
    
    def _get_regime_parameter_ranges(self, regime_context: RegimeContext) -> Dict[str, Any]:
        """Get regime-specific parameter ranges"""
        
        if regime_context.volatility_regime == 'low_volatility':
            return {
                'lookback_period': {'min': 10, 'max': 50, 'step': 5},
                'momentum_threshold': {'min': 0.005, 'max': 0.03, 'step': 0.005},
                'volatility_threshold': {'min': 0.05, 'max': 0.20, 'step': 0.05}
            }
        elif regime_context.volatility_regime == 'high_volatility':
            return {
                'lookback_period': {'min': 20, 'max': 80, 'step': 5},
                'momentum_threshold': {'min': 0.02, 'max': 0.08, 'step': 0.005},
                'volatility_threshold': {'min': 0.20, 'max': 0.50, 'step': 0.05}
            }
        else:
            return self.parameter_space
