#### **0.2 Regime Classification Integration (Rule 13)**
```python
class RegimeAwareDataProcessor(ISystemComponent):
    """Regime-aware data processing with Rule 13 compliance"""
    
    def __init__(self, config: Dict[str, Any], regime_engine: EnhancedRegimeEngine):
        super().__init__()
        self.config = config
        self.regime_engine = regime_engine
        self.regime_context: Optional[RegimeContext] = None
    
    async def process_data_with_regime(self, data: pd.DataFrame) -> pd.DataFrame:
        """Process data with regime classification (Rule 13 - Regime-First)"""
        
        # STEP 1: Get current regime context (MANDATORY - Rule 13)
        self.regime_context = await self.regime_engine.get_current_regime_context()
        
        if not self.regime_context:
            logger.warning("⚠️ No regime context available - using default processing")
            return await self._default_data_processing(data)
        
        # STEP 2: Process data based on regime
        if self.regime_context.volatility_regime == 'high_vol':
            data = await self._apply_high_volatility_processing(data)
        elif self.regime_context.volatility_regime == 'low_vol':
            data = await self._apply_low_volatility_processing(data)
        elif self.regime_context.volatility_regime == 'extreme_vol':
            data = await self._apply_extreme_volatility_processing(data)
        else:
            data = await self._apply_normal_volatility_processing(data)
        
        # STEP 3: Tag data with regime context
        data = self._tag_data_with_regime(data, self.regime_context)
        
        logger.info(f"✅ Data processed with regime context: {self.regime_context.primary_regime}")
        return data
    
    def _tag_data_with_regime(self, data: pd.DataFrame, regime_context: RegimeContext) -> pd.DataFrame:
        """Tag data with regime context for downstream processing"""
        data.attrs.update({
            'regime': regime_context.primary_regime,
            'volatility_regime': regime_context.volatility_regime,
            'liquidity_regime': regime_context.liquidity_regime,
            'regime_confidence': regime_context.regime_confidence,
            'regime_timestamp': regime_context.last_update.isoformat()
        })
        return data
