class StrategyRegistry(ISystemComponent):
    """Centralized strategy registry with configuration management"""
    
    def __init__(self, config: Dict[str, Any]):
        super().__init__()
        self.config = config
        self.registered_strategies = {}
        self.strategy_configs = {}
        self.optimization_configs = {}
    
    async def register_strategy(self, strategy_type: str, 
                              strategy_instance: EnhancedBaseStrategy,
                              config: Dict[str, Any]) -> str:
        """Register strategy with centralized configuration"""
        
        strategy_id = f"{strategy_type}_{uuid.uuid4().hex[:8]}"
        
        # Store strategy instance
        self.registered_strategies[strategy_id] = {
            'strategy_type': strategy_type,
            'strategy_instance': strategy_instance,
            'config': config,
            'registration_time': datetime.now(),
            'status': 'registered'
        }
        
        # Store configuration
        self.strategy_configs[strategy_id] = config
        
        logger.info(f"✅ Strategy {strategy_type} registered with ID: {strategy_id}")
        return strategy_id
    
    async def get_strategy_config(self, strategy_id: str, 
                                regime_context: Optional[RegimeContext] = None) -> Dict[str, Any]:
        """Get strategy configuration with regime awareness"""
        
        base_config = self.strategy_configs.get(strategy_id, {})
        
        if regime_context:
            regime_adjustments = await self._get_regime_adjustments(strategy_id, regime_context)
            base_config = self._merge_configs(base_config, regime_adjustments)
        
        return base_config
```

