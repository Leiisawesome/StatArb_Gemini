class DynamicParameterAdapter:
    """Dynamic parameter adaptation based on market conditions"""
    
    def __init__(self, strategy_type: str, base_config: Dict[str, Any]):
        self.strategy_type = strategy_type
        self.base_config = base_config
        self.regime_adaptations = {
            'low_volatility': self._get_low_vol_adaptations(),
            'normal_volatility': self._get_normal_vol_adaptations(),
            'high_volatility': self._get_high_vol_adaptations(),
            'extreme_volatility': self._get_extreme_vol_adaptations(),
            'trending_market': self._get_trending_adaptations(),
            'ranging_market': self._get_ranging_adaptations(),
            'crisis_market': self._get_crisis_adaptations()
        }
    
    async def adapt_parameters(self, regime_context: RegimeContext) -> Dict[str, Any]:
        """Adapt strategy parameters based on current market regime"""
        
        # Get base configuration
        adapted_config = self.base_config.copy()
        
        # Apply regime-specific adaptations
        regime_adaptations = self.regime_adaptations.get(
            regime_context.volatility_regime, 
            self.regime_adaptations['normal_volatility']
        )
        
        # Apply trend-specific adaptations
        if regime_context.trend_regime in ['strong_up', 'strong_down']:
            trend_adaptations = self.regime_adaptations['trending_market']
            adapted_config = self._merge_adaptations(adapted_config, trend_adaptations)
        elif regime_context.trend_regime == 'sideways':
            ranging_adaptations = self.regime_adaptations['ranging_market']
            adapted_config = self._merge_adaptations(adapted_config, ranging_adaptations)
        
        # Apply crisis adaptations if needed
        if regime_context.primary_regime == 'crisis':
            crisis_adaptations = self.regime_adaptations['crisis_market']
            adapted_config = self._merge_adaptations(adapted_config, crisis_adaptations)
        
        return adapted_config
    
    def _get_low_vol_adaptations(self) -> Dict[str, Any]:
        """Low volatility market adaptations"""
        return {
            'momentum_threshold': 0.8,      # Lower threshold for easier signals
            'signal_confidence_threshold': 0.5,  # Lower confidence requirement
            'max_position_size': 1.2,      # Higher position size
            'risk_budget': 1.1,            # Higher risk budget
            'lookback_period': 0.9         # Slightly shorter lookback
        }
    
    def _get_high_vol_adaptations(self) -> Dict[str, Any]:
        """High volatility market adaptations"""
        return {
            'momentum_threshold': 1.3,      # Higher threshold for quality signals
            'signal_confidence_threshold': 0.8,  # Higher confidence requirement
            'max_position_size': 0.7,      # Lower position size
            'risk_budget': 0.8,            # Lower risk budget
            'lookback_period': 1.1         # Longer lookback for stability
        }
    
    def _get_trending_adaptations(self) -> Dict[str, Any]:
        """Trending market adaptations"""
        return {
            'momentum_threshold': 0.9,     # Lower threshold for trend following
            'signal_confidence_threshold': 0.6,  # Moderate confidence requirement
            'max_position_size': 1.1,     # Slightly higher position size
            'risk_budget': 1.05,           # Slightly higher risk budget
            'lookback_period': 1.05        # Slightly longer lookback
        }
    
    def _get_ranging_adaptations(self) -> Dict[str, Any]:
        """Ranging market adaptations"""
        return {
            'momentum_threshold': 1.1,     # Higher threshold for mean reversion
            'signal_confidence_threshold': 0.7,  # Higher confidence requirement
            'max_position_size': 0.9,     # Lower position size
            'risk_budget': 0.95,          # Lower risk budget
            'lookback_period': 0.95       # Shorter lookback for responsiveness
        }
```

