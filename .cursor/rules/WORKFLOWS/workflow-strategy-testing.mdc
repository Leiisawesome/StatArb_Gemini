        super().__init__()
        self.config = config
        self.risk_manager = risk_manager
        self.risk_metrics = {}
        self.risk_alerts = []
        self.risk_thresholds = {
            'var_95': 0.05,           # 5% VaR limit
            'max_drawdown': 0.15,     # 15% max drawdown
            'position_concentration': 0.20,  # 20% position limit
            'leverage': 2.0           # 2x leverage limit
        }
    
    async def monitor_risk_metrics(self, 
                                 positions: Dict[str, float],
                                 market_data: Dict[str, Any],
                                 regime_context: Optional[RegimeContext] = None) -> Dict[str, Any]:
        """Monitor risk metrics in real-time with regime awareness"""
        
        # Calculate risk metrics
        risk_metrics = {
            'var_95': await self._calculate_var_95(positions, market_data),
            'var_99': await self._calculate_var_99(positions, market_data),
            'max_drawdown': await self._calculate_max_drawdown(positions),
            'position_concentration': await self._calculate_position_concentration(positions),
            'leverage': await self._calculate_leverage(positions)
        }
        
        # Apply regime adjustments
        if regime_context:
            risk_metrics = await self._apply_regime_risk_adjustments(risk_metrics, regime_context)
        
        # Check risk limits
        risk_violations = await self._check_risk_limits(risk_metrics)
        
        # Generate alerts if necessary
        if risk_violations:
            await self._generate_risk_alerts(risk_violations)
        
        return {
            'risk_metrics': risk_metrics,
            'risk_violations': risk_violations,
            'regime_context': regime_context.volatility_regime if regime_context else 'unknown',
            'monitoring_timestamp': datetime.now().isoformat()
        }
    
    async def _apply_regime_risk_adjustments(self, 
                                           risk_metrics: Dict[str, float],
                                           regime_context: RegimeContext) -> Dict[str, float]:
        """Apply regime-specific risk adjustments"""
        
        regime_multipliers = {
            'low_volatility': 1.2,      # Increase risk limits in low vol
            'normal_volatility': 1.0,   # Normal risk limits
            'high_volatility': 0.7,     # Reduce risk limits in high vol
            'extreme_volatility': 0.4,  # Significantly reduce risk limits
            'crisis': 0.2               # Minimal risk limits
        }
        
        multiplier = regime_multipliers.get(regime_context.volatility_regime, 1.0)
        adjusted_metrics = {}
        
        for metric, value in risk_metrics.items():
            if metric in self.risk_thresholds:
                threshold = self.risk_thresholds[metric]
                adjusted_metrics[metric] = min(value, threshold * multiplier)
            else:
                adjusted_metrics[metric] = value
        
        return adjusted_metrics
```

