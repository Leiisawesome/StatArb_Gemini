class BacktestInterfaceValidator(ISystemComponent):
    """Validate backtest interface with 13-rules compliance"""
    
    def __init__(self, config: Dict[str, Any]):
        super().__init__()
        self.config = config
        self.compliance_rules = {
            'data_flow_pipeline': self._validate_data_flow_compliance,
            'component_integration': self._validate_component_integration,
            'regime_first': self._validate_regime_first_compliance,
            'risk_management': self._validate_risk_management_compliance,
            'execution_quality': self._validate_execution_quality_compliance
        }
    
    async def validate_backtest_interface(self, 
                                        optimizer_interface: BacktestOptimizerInterface,
                                        institutional_engine: InstitutionalBacktestEngine) -> Dict[str, Any]:
        """Validate backtest interface compliance with all 13 rules"""
        
        validation_results = {}
        overall_compliance = True
        
        for rule_name, validation_func in self.compliance_rules.items():
            try:
                rule_result = await validation_func(optimizer_interface, institutional_engine)
                validation_results[rule_name] = rule_result
                
                if not rule_result.get('compliant', False):
                    overall_compliance = False
                    logger.warning(f"⚠️ Rule {rule_name} not compliant: {rule_result.get('issues', [])}")
                
            except Exception as e:
                logger.error(f"❌ Rule {rule_name} validation failed: {e}")
                validation_results[rule_name] = {
                    'compliant': False,
                    'error': str(e)
                }
                overall_compliance = False
        
        return {
            'overall_compliance': overall_compliance,
            'rule_results': validation_results,
            'compliance_score': self._calculate_compliance_score(validation_results)
        }
    
    async def _validate_regime_first_compliance(self, 
                                               optimizer_interface: BacktestOptimizerInterface,
                                               institutional_engine: InstitutionalBacktestEngine) -> Dict[str, Any]:
        """Validate Rule 13 - Regime-First compliance"""
        
        # Check if regime engine initializes first
        regime_engine = institutional_engine.regime_engine
        if not regime_engine:
            return {
                'compliant': False,
                'issues': ['Regime engine not initialized']
            }
        
        # Check if regime context is available
        regime_context = await regime_engine.get_current_regime_context()
        if not regime_context:
            return {
                'compliant': False,
                'issues': ['No regime context available']
            }
        
        # Check if optimization uses regime context
        if not hasattr(optimizer_interface, 'regime_engine'):
            return {
                'compliant': False,
                'issues': ['Optimizer interface not regime-aware']
            }
        
        return {
            'compliant': True,
            'regime_context': regime_context.primary_regime,
            'regime_confidence': regime_context.regime_confidence
        }
