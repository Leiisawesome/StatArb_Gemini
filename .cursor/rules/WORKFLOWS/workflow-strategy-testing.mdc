class StrategyConfigManager(ISystemComponent):
    """Centralized strategy configuration management with institutional standards"""
    
    def __init__(self, config: Dict[str, Any]):
        super().__init__()
        self.config = config
        self.strategy_configs = {}
        self.regime_configs = {}
        self.risk_configs = {}
        self.execution_configs = {}
        self.optimization_configs = {}
    
    async def load_strategy_config(self, strategy_type: str, 
                                 regime_context: Optional[RegimeContext] = None) -> Dict[str, Any]:
        """Load strategy configuration with regime awareness"""
        
        # Base strategy configuration
        base_config = await self._load_base_strategy_config(strategy_type)
        
        # Apply regime-specific adjustments
        if regime_context:
            regime_config = await self._load_regime_config(strategy_type, regime_context)
            base_config = self._merge_configs(base_config, regime_config)
        
