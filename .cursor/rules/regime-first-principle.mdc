### Strategy Manager with Regime-First Priority
The StrategyManager MUST consult regime context BEFORE executing strategies:

```python
from core_engine.trading.strategies.manager import StrategyManager
from core_engine.regime.engine import EnhancedRegimeEngine, RegimeContext

class RegimeAwareStrategyManager(StrategyManager, IRegimeAware):
    """Strategy manager with regime-first priority"""
    
    def __init__(self, config: Dict[str, Any], regime_engine: EnhancedRegimeEngine):
        super().__init__(config)
        self.regime_engine = regime_engine
        self.current_regime_context: Optional[RegimeContext] = None
        
        # Regime-specific strategy weights
        self.regime_strategy_weights: Dict[str, Dict[str, float]] = {
            'bull_low_volatility': {
                'momentum': 0.8,
                'trend_following': 0.7,
                'breakout': 0.6,
                'mean_reversion': 0.3,
                'pairs_trading': 0.2
            },
            'bear_high_volatility': {
                'mean_reversion': 0.7,
                'pairs_trading': 0.8,
                'volatility': 0.9,
                'momentum': 0.2,
                'trend_following': 0.3
            },
            'range_bound': {
                'mean_reversion': 0.9,
                'pairs_trading': 0.8,
                'statistical_arbitrage': 0.85,
                'momentum': 0.2,
                'breakout': 0.3
            },
            'crisis_mode': {
                'pairs_trading': 0.9,
                'statistical_arbitrage': 0.8,
                'volatility': 0.7,
                'momentum': 0.1,
                'trend_following': 0.2
            }
        }
    
    async def on_regime_change(self, new_regime_context: RegimeContext) -> None:
        """Handle regime change - rebalance strategy allocations"""
        
        previous_regime = self.current_regime_context.primary_regime if self.current_regime_context else None
        self.current_regime_context = new_regime_context
        
        logger.info(f"🔄 Strategy manager adapting to regime change: {previous_regime} → {new_regime_context.primary_regime}")
        
        # Rebalance strategy weights
        await self._rebalance_strategies_for_regime(new_regime_context)
        
        # Notify active strategies of regime change
        await self._notify_strategies_of_regime_change(new_regime_context)
    
    async def _rebalance_strategies_for_regime(self, regime_context: RegimeContext) -> None:
        """Rebalance strategy allocations based on regime"""
        
        regime_weights = self.regime_strategy_weights.get(
            regime_context.primary_regime,
            self._get_default_strategy_weights()
        )
        
        # Update strategy weights
        for strategy_id, strategy in self.active_strategies.items():
            strategy_type = strategy.config.strategy_type
            new_weight = regime_weights.get(strategy_type.value, 0.5)
            
            # Apply regime confidence adjustment
            adjusted_weight = new_weight * regime_context.regime_confidence
            
            # Update strategy weight
            self.strategy_weights[strategy_id] = adjusted_weight
            
            logger.info(f"📊 Strategy {strategy_type.value} weight adjusted to {adjusted_weight:.2f} "
                       f"for regime {regime_context.primary_regime}")
    
    async def execute_strategies(self, market_data: pd.DataFrame) -> Dict[str, List[Signal]]:
        """
        Execute strategies with MANDATORY regime-first priority
        
        CRITICAL: Regime context MUST be retrieved and applied BEFORE strategy execution
        """
        
        # STEP 1: Retrieve current regime context (MANDATORY)
        if not self.regime_engine:
            raise RuntimeError("❌ REGIME-FIRST VIOLATION: Regime engine not configured")
        
        regime_context = await self.regime_engine.get_current_regime_context()
        
        if not regime_context:
            logger.error("❌ Cannot execute strategies without regime context")
            return {}
        
        # Update current context
        self.current_regime_context = regime_context
        
        # STEP 2: Rebalance strategies for current regime
        await self._rebalance_strategies_for_regime(regime_context)
        
        # STEP 3: Filter strategies appropriate for current regime
        active_strategies = self._get_regime_appropriate_strategies(regime_context)
        
        # STEP 4: Execute regime-appropriate strategies
        strategy_signals = {}
        
        for strategy_id, strategy in active_strategies.items():
            # Pass regime context to strategy
            strategy_signals[strategy_id] = await strategy.generate_signals(
                market_data, 
                regime_context=regime_context
            )
        
        logger.info(f"✅ Executed {len(active_strategies)} regime-appropriate strategies "
                   f"(regime: {regime_context.primary_regime})")
        
        return strategy_signals
    
    def _get_regime_appropriate_strategies(self, regime_context: RegimeContext) -> Dict[str, Any]:
        """Filter strategies appropriate for current regime"""
        
        appropriate_strategies = {}
        
        for strategy_id, strategy in self.active_strategies.items():
            strategy_weight = self.strategy_weights.get(strategy_id, 0.0)
            
            # Only include strategies with sufficient weight for current regime
            if strategy_weight >= 0.3:  # Minimum threshold
                appropriate_strategies[strategy_id] = strategy
        
        logger.info(f"📊 Regime filtering: {len(self.active_strategies)} → {len(appropriate_strategies)} active strategies")
        
        return appropriate_strategies
```

