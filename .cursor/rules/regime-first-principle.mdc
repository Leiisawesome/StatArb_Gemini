from core_engine.system.central_risk_manager import CentralRiskManager, TradingDecisionRequest
from core_engine.regime.engine import EnhancedRegimeEngine, RegimeContext

class RegimeAwareRiskManager(CentralRiskManager, IRegimeAware):
    """Risk manager with regime-adjusted risk limits"""
    
    def __init__(self, config: Dict[str, Any], regime_engine: EnhancedRegimeEngine):
        super().__init__(config)
        self.regime_engine = regime_engine
        self.current_regime_context: Optional[RegimeContext] = None
        
        # Base risk limits
        self.base_risk_limits = {
            'max_position_size': 0.10,  # 10% of portfolio
            'max_daily_var': 0.05,      # 5% VaR
            'max_concentration': 0.15,   # 15% per position
            'max_leverage': 2.0          # 2x leverage
        }
        
        # Current regime-adjusted limits
        self.current_risk_limits = self.base_risk_limits.copy()
    
    async def on_regime_change(self, new_regime_context: RegimeContext) -> None:
        """Handle regime change - adjust risk limits"""
        
        previous_regime = self.current_regime_context.primary_regime if self.current_regime_context else None
        self.current_regime_context = new_regime_context
        
        logger.info(f"🔄 Risk manager adapting to regime change: {previous_regime} → {new_regime_context.primary_regime}")
        
        # Adjust risk limits for new regime
        await self._adjust_risk_limits_for_regime(new_regime_context)
    
    async def _adjust_risk_limits_for_regime(self, regime_context: RegimeContext) -> None:
        """Adjust risk limits based on current regime"""
        
        # Get regime-specific risk multiplier
        risk_multiplier = regime_context.risk_multiplier
        position_adjustment = regime_context.max_position_size_adjustment
        leverage_adjustment = regime_context.leverage_adjustment
        
        # Apply regime adjustments to base limits
        self.current_risk_limits = {
            'max_position_size': self.base_risk_limits['max_position_size'] * position_adjustment,
            'max_daily_var': self.base_risk_limits['max_daily_var'] * risk_multiplier,
            'max_concentration': self.base_risk_limits['max_concentration'] * position_adjustment,
            'max_leverage': self.base_risk_limits['max_leverage'] * leverage_adjustment
        }
        
        logger.info(f"📊 Risk limits adjusted for regime {regime_context.primary_regime}:")
        logger.info(f"  - Max position size: {self.current_risk_limits['max_position_size']:.2%}")
        logger.info(f"  - Max daily VaR: {self.current_risk_limits['max_daily_var']:.2%}")
        logger.info(f"  - Max concentration: {self.current_risk_limits['max_concentration']:.2%}")
        logger.info(f"  - Max leverage: {self.current_risk_limits['max_leverage']:.2f}x")
    
    async def authorize_trading_decision(self, request: TradingDecisionRequest) -> TradingDecisionAuthorization:
        """
        Authorize trading decision with MANDATORY regime-adjusted risk limits
        
        CRITICAL: Risk limits MUST be adjusted for current regime BEFORE authorization
        """
        
        # STEP 1: Retrieve current regime context (MANDATORY)
        if not self.regime_engine:
            raise RuntimeError("❌ REGIME-FIRST VIOLATION: Regime engine not configured")
        
        regime_context = await self.regime_engine.get_current_regime_context()
        
        if not regime_context:
            logger.error("❌ Cannot authorize trade without regime context")
            return self._reject_authorization(request, "No regime context available")
        
        # Update current context
        self.current_regime_context = regime_context
        
        # STEP 2: Ensure risk limits are current for regime
        await self._adjust_risk_limits_for_regime(regime_context)
        
        # STEP 3: Validate trade against regime-adjusted limits
        validation_result = await self._validate_trade_with_regime_limits(request, regime_context)
        
        if not validation_result['valid']:
            return self._reject_authorization(request, validation_result['reason'])
        
        # STEP 4: Apply regime-specific risk adjustments to authorized quantity
        authorized_quantity = self._calculate_regime_adjusted_quantity(
            request.quantity, 
            regime_context
        )
        
        # STEP 5: Create authorization with regime context
        authorization = TradingDecisionAuthorization(
            authorization_level=AuthorizationLevel.STANDARD,
            quantity=authorized_quantity,
            risk_budget=self._calculate_risk_budget(authorized_quantity, regime_context),
            metadata={
                'regime': regime_context.primary_regime,
                'regime_confidence': regime_context.regime_confidence,
                'risk_multiplier': regime_context.risk_multiplier,
                'regime_adjusted_limits': self.current_risk_limits
            }
        )
        
        logger.info(f"✅ Trade authorized with regime-adjusted limits "
                   f"(regime: {regime_context.primary_regime}, qty: {authorized_quantity})")
        
        return authorization
```

## 7. Regime-Aware Execution Optimization

### Execution Engine with Regime-Optimized Strategies
The UnifiedExecutionEngine MUST optimize execution based on regime:

```python
from core_engine.system.unified_execution_engine import UnifiedExecutionEngine, ExecutionRequest
from core_engine.regime.engine import EnhancedRegimeEngine, RegimeContext

class RegimeAwareExecutionEngine(UnifiedExecutionEngine, IRegimeAware):
    """Execution engine with regime-optimized execution strategies"""
    
    def __init__(self, config: Dict[str, Any], regime_engine: EnhancedRegimeEngine):
        super().__init__(config)
        self.regime_engine = regime_engine
        self.current_regime_context: Optional[RegimeContext] = None
    
    async def on_regime_change(self, new_regime_context: RegimeContext) -> None:
        """Handle regime change - adjust execution strategies"""
        
        previous_regime = self.current_regime_context.primary_regime if self.current_regime_context else None
        self.current_regime_context = new_regime_context
        
        logger.info(f"🔄 Execution engine adapting to regime change: {previous_regime} → {new_regime_context.primary_regime}")
    
    async def execute_authorized_trade(self, execution_request: ExecutionRequest) -> ExecutionResult:
        """
        Execute trade with MANDATORY regime-optimized execution strategy
        
        CRITICAL: Execution strategy MUST be selected based on current regime
        """
        
        # STEP 1: Retrieve current regime context (MANDATORY)
        if not self.regime_engine:
            raise RuntimeError("❌ REGIME-FIRST VIOLATION: Regime engine not configured")
        
        regime_context = await self.regime_engine.get_current_regime_context()
        
        if not regime_context:
            logger.error("❌ Cannot execute trade without regime context")
            return self._create_error_result("No regime context available")
        
        # Update current context
        self.current_regime_context = regime_context
        
        # STEP 2: Select regime-optimized execution strategy
        execution_strategy = self._select_execution_strategy_for_regime(
            execution_request, 
            regime_context
        )
        
        # STEP 3: Apply regime-specific execution parameters
        execution_params = self._get_regime_execution_parameters(regime_context)
        
        # STEP 4: Execute with regime-optimized strategy
        execution_result = await self._execute_with_strategy(
            execution_request,
            execution_strategy,
            execution_params,
            regime_context
        )
        
        # STEP 5: Tag result with regime context
        execution_result.metadata.update({
            'regime': regime_context.primary_regime,
            'execution_strategy': execution_strategy,
            'regime_optimized': True
        })
        
        logger.info(f"✅ Trade executed with regime-optimized strategy {execution_strategy} "
                   f"(regime: {regime_context.primary_regime})")
        
        return execution_result
    
    def _select_execution_strategy_for_regime(self, request: ExecutionRequest,
                                             regime_context: RegimeContext) -> str:
        """Select optimal execution strategy based on regime"""
        
        # Use regime's recommended execution style
        recommended_style = regime_context.recommended_execution_style
        
        # Override based on urgency from regime
        if regime_context.execution_urgency == 'urgent':
            return 'MARKET'
        elif regime_context.execution_urgency == 'high':
            return 'ADAPTIVE'
        
        # Use recommended style or default to ADAPTIVE
        return recommended_style if recommended_style else 'ADAPTIVE'
```

## 8. PROHIBITED Regime-Awareness Violations

❌ **Signal Generation Before Regime Detection**: Cannot generate signals without regime context  
❌ **Strategy Execution Without Regime Check**: Must validate regime before strategy execution  
❌ **Risk Authorization Ignoring Regime**: Risk limits must be regime-adjusted  
❌ **Direct Regime Engine Bypass**: All components must use regime context distribution  
❌ **Stale Regime Context**: Must use current regime context, not cached/outdated data  
❌ **Missing Regime Dependency**: All operational components must inject regime engine  
❌ **Regime-Unaware Execution**: Execution strategies must adapt to regime conditions  

## 9. MANDATORY Regime-First Requirements

1. **Initialization Priority**: EnhancedRegimeEngine MUST initialize first (order=5)
2. **Component Integration**: All operational components MUST implement IRegimeAware
3. **Regime Context Distribution**: EnhancedRegimeEngine MUST distribute context to all subscribers
4. **Signal Generation**: ALL signals MUST be generated with current regime context
5. **Strategy Selection**: Strategy weights MUST be adjusted for current regime
6. **Risk Management**: Risk limits MUST be regime-adjusted before authorization
7. **Execution Optimization**: Execution strategies MUST be regime-optimized
8. **Context Validation**: Components MUST validate regime dependency before operations
9. **Regime Tagging**: All trading decisions, signals, and executions MUST be tagged with regime
10. **Real-Time Adaptation**: Components MUST adapt to regime changes via on_regime_change callback

## 10. Regime-First Validation Framework

### System-Wide Regime Compliance Checker
```python
class RegimeFirstComplianceChecker:
    """Validate system-wide compliance with Regime-First Principle"""
    
    async def validate_regime_first_compliance(self, orchestrator) -> Dict[str, Any]:
        """Comprehensive regime-first compliance validation"""
        
        validation_results = {
            'compliant': True,
            'violations': [],
            'warnings': [],
            'component_checks': {}
        }
        
        # Check 1: Regime Engine initialized first
        regime_component = orchestrator.get_component("EnhancedRegimeEngine")
        if not regime_component or regime_component.initialization_order != 5:
            validation_results['violations'].append(
                "Regime Engine not initialized with priority order 5"
            )
            validation_results['compliant'] = False
        
        # Check 2: All operational components implement IRegimeAware
        operational_components = orchestrator.get_components_by_layer(ComponentLayer.OPERATIONAL)
        for component_id, component in operational_components.items():
            if not isinstance(component, IRegimeAware):
                validation_results['violations'].append(
                    f"Component {component.__class__.__name__} does not implement IRegimeAware"
                )
                validation_results['compliant'] = False
        
        # Check 3: Components have regime engine injected
        for component_id, component in operational_components.items():
            if isinstance(component, IRegimeAware):
                if not component.validate_regime_dependency():
                    validation_results['warnings'].append(
                        f"Component {component.__class__.__name__} has invalid regime dependency"
                    )
        
        # Check 4: Regime context distribution is active
        if regime_component:
            distributor = getattr(regime_component, 'context_distributor', None)
            if not distributor or len(distributor.subscribers) == 0:
                validation_results['violations'].append(
                    "No components subscribed to regime context distribution"
                )
                validation_results['compliant'] = False
        
        return validation_results
```

This Regime-First Principle ensures that **market regime detection is the foundational context** for ALL system operations, providing **regime-aware signal generation**, **adaptive risk management**, and **optimized execution** across all market conditions.
