## 3. Regime Context Distribution Pattern

### Regime Context Interface
ALL components that depend on market regime MUST implement the `IRegimeAware` interface:

```python
from abc import ABC, abstractmethod
from typing import Dict, Any, Optional
from datetime import datetime
from dataclasses import dataclass
from enum import Enum

@dataclass
class RegimeContext:
    """Comprehensive regime context for system-wide distribution"""
    
    # Primary Regime Classification
    primary_regime: str  # Current market regime
    regime_confidence: float  # Confidence in classification (0-1)
    regime_start_time: datetime  # When current regime began
    regime_duration_minutes: float  # How long in current regime
    
    # Multi-Timeframe Regime Analysis
    timeframe_regimes: Dict[str, str]  # {'5min': 'bull_low_vol', '1H': 'trending', ...}
    timeframe_confidences: Dict[str, float]  # Confidence per timeframe
    regime_alignment_score: float  # Cross-timeframe regime consistency (0-1)
    
    # Market Conditions
    volatility_regime: str  # 'low_vol', 'normal_vol', 'high_vol', 'extreme_vol'
    liquidity_regime: str  # 'high_liquidity', 'normal', 'low_liquidity', 'crisis'
    trend_regime: str  # 'strong_up', 'weak_up', 'sideways', 'weak_down', 'strong_down'
    
    # Predictive Indicators
    regime_transition_probability: float  # Probability of regime change (0-1)
    expected_next_regime: Optional[str]  # Most likely next regime
    transition_timeframe: Optional[str]  # Expected time to transition
    
    # Strategy Implications
    optimal_strategies: Dict[str, float]  # {'momentum': 0.8, 'mean_reversion': 0.3, ...}
    strategy_adjustments: Dict[str, Dict[str, Any]]  # Strategy-specific parameters
    
    # Risk Implications
    risk_multiplier: float  # Risk scaling factor for current regime
    max_position_size_adjustment: float  # Position size adjustment (0.5 = 50% of normal)
    leverage_adjustment: float  # Leverage adjustment factor
    
    # Execution Implications
    execution_urgency: str  # 'low', 'normal', 'high', 'urgent'
    recommended_execution_style: str  # 'TWAP', 'VWAP', 'ADAPTIVE', etc.
    market_impact_multiplier: float  # Expected impact vs normal conditions
    
    # Metadata
    last_update: datetime
    analysis_version: str
    
    def is_high_confidence(self, threshold: float = 0.7) -> bool:
        """Check if regime classification is high confidence"""
        return self.regime_confidence >= threshold
    
    def is_stable_regime(self, max_transition_prob: float = 0.3) -> bool:
        """Check if regime is stable (low transition probability)"""
        return self.regime_transition_probability <= max_transition_prob
    
    def get_strategy_weight(self, strategy_type: str) -> float:
        """Get optimal weight for strategy type in current regime"""
        return self.optimal_strategies.get(strategy_type, 0.5)

class IRegimeAware(ABC):
    """Interface for components that require regime awareness"""
    
    @abstractmethod
    def set_regime_engine(self, regime_engine: 'EnhancedRegimeEngine') -> None:
        """Inject regime engine dependency"""
        pass
    
    @abstractmethod
    async def on_regime_change(self, new_regime_context: RegimeContext) -> None:
        """Handle regime change event"""
        pass
    
    @abstractmethod
    def get_current_regime_context(self) -> Optional[RegimeContext]:
        """Get current regime context"""
        pass
    
    @abstractmethod
    async def adapt_to_regime(self, regime_context: RegimeContext) -> Dict[str, Any]:
        """Adapt component behavior to current regime"""
        pass
    
    @abstractmethod
    def validate_regime_dependency(self) -> bool:
        """Validate regime engine is properly configured"""
        pass
```

### Regime Context Distribution
The EnhancedRegimeEngine distributes regime context to all subscribers:

```python
from typing import List, Callable, Awaitable
import asyncio

class RegimeContextDistributor:
    """Distributes regime context updates to all system components"""
    
    def __init__(self, regime_engine: EnhancedRegimeEngine):
        self.regime_engine = regime_engine
        self.subscribers: List[IRegimeAware] = []
        self.callback_subscribers: List[Callable[[RegimeContext], Awaitable[None]]] = []
        self.distribution_history: List[Dict[str, Any]] = []
        
    def subscribe(self, component: IRegimeAware) -> str:
        """Subscribe component to regime context updates"""
        if component not in self.subscribers:
            self.subscribers.append(component)
            logger.info(f"✅ Component {component.__class__.__name__} subscribed to regime updates")
        
        return f"subscription_{len(self.subscribers)}"
    
    def subscribe_callback(self, callback: Callable[[RegimeContext], Awaitable[None]]) -> str:
        """Subscribe callback function to regime updates"""
        if callback not in self.callback_subscribers:
            self.callback_subscribers.append(callback)
            logger.info(f"✅ Callback subscribed to regime updates")
        
        return f"callback_{len(self.callback_subscribers)}"
    
    async def distribute_regime_context(self, regime_context: RegimeContext) -> Dict[str, Any]:
        """Distribute regime context to all subscribers"""
        
        distribution_start = datetime.now()
        distribution_results = {
            'timestamp': distribution_start,
            'regime': regime_context.primary_regime,
            'subscriber_count': len(self.subscribers) + len(self.callback_subscribers),
            'successful_distributions': 0,
            'failed_distributions': 0,
            'distribution_errors': []
        }
        
        # Distribute to component subscribers
        for subscriber in self.subscribers:
            try:
                await subscriber.on_regime_change(regime_context)
                distribution_results['successful_distributions'] += 1
                
            except Exception as e:
                logger.error(f"❌ Regime distribution failed for {subscriber.__class__.__name__}: {e}")
                distribution_results['failed_distributions'] += 1
                distribution_results['distribution_errors'].append({
                    'component': subscriber.__class__.__name__,
                    'error': str(e)
                })
        
        # Distribute to callback subscribers
        for callback in self.callback_subscribers:
            try:
                await callback(regime_context)
                distribution_results['successful_distributions'] += 1
                
            except Exception as e:
                logger.error(f"❌ Regime distribution failed for callback: {e}")
                distribution_results['failed_distributions'] += 1
                distribution_results['distribution_errors'].append({
                    'component': 'callback',
                    'error': str(e)
                })
        
        distribution_duration = (datetime.now() - distribution_start).total_seconds()
        distribution_results['distribution_duration_ms'] = distribution_duration * 1000
        
        # Record distribution history
        self.distribution_history.append(distribution_results)
        
        logger.info(f"📡 Regime context distributed to {distribution_results['successful_distributions']} subscribers "
                   f"in {distribution_results['distribution_duration_ms']:.2f}ms")
        
        return distribution_results
```

## 4. Regime-Aware Signal Processing

### Signal Generation with Regime Context
ALL signal generation MUST incorporate regime context BEFORE generating signals:

```python
from core_engine.processing.signals.generator import EnhancedSignalGenerator
from core_engine.regime.engine import EnhancedRegimeEngine, RegimeContext

class RegimeAwareSignalGenerator(EnhancedSignalGenerator, IRegimeAware):
    """Signal generator with mandatory regime awareness"""
    
    def __init__(self, config: Dict[str, Any], regime_engine: EnhancedRegimeEngine):
        super().__init__(config)
        self.regime_engine = regime_engine
        self.current_regime_context: Optional[RegimeContext] = None
        self.regime_signal_cache: Dict[str, List[Any]] = {}
        
    def set_regime_engine(self, regime_engine: EnhancedRegimeEngine) -> None:
        """Inject regime engine dependency"""
        self.regime_engine = regime_engine
        logger.info("✅ Regime engine injected into signal generator")
    
    async def on_regime_change(self, new_regime_context: RegimeContext) -> None:
        """Handle regime change event"""
        previous_regime = self.current_regime_context.primary_regime if self.current_regime_context else None
        self.current_regime_context = new_regime_context
        
        logger.info(f"🔄 Signal generator adapting to regime change: {previous_regime} → {new_regime_context.primary_regime}")
        
        # Clear signal cache on regime change
        self.regime_signal_cache.clear()
        
        # Adapt signal generation parameters
        await self.adapt_to_regime(new_regime_context)
    
    async def adapt_to_regime(self, regime_context: RegimeContext) -> Dict[str, Any]:
        """Adapt signal generation parameters to current regime"""
        
        adaptations = {
            'regime': regime_context.primary_regime,
            'signal_threshold_adjustment': self._calculate_threshold_adjustment(regime_context),
            'confidence_multiplier': regime_context.regime_confidence,
            'timeframe_weights': self._calculate_timeframe_weights(regime_context)
        }
        
        # Adjust signal generation parameters based on regime
        if regime_context.volatility_regime == 'high_vol':
            adaptations['signal_threshold_adjustment'] *= 1.3  # Higher threshold in volatile conditions
        
        if regime_context.liquidity_regime == 'low_liquidity':
            adaptations['signal_threshold_adjustment'] *= 1.2  # Higher threshold in illiquid conditions
        
        logger.info(f"📊 Signal generation adapted to regime: {adaptations}")
        return adaptations
    
    async def generate_signals(self, market_data: pd.DataFrame) -> List[Signal]:
        """
        Generate signals with MANDATORY regime context
        
        CRITICAL: This method MUST retrieve current regime context BEFORE generating signals
        """
        
        # STEP 1: Retrieve current regime context (MANDATORY)
        if not self.regime_engine:
            raise RuntimeError("❌ REGIME-FIRST VIOLATION: Regime engine not configured")
        
        regime_context = await self.regime_engine.get_current_regime_context()
        
        if not regime_context:
            logger.warning("⚠️ No regime context available - using default parameters")
            regime_context = self._get_default_regime_context()
        
        # Update current context
        self.current_regime_context = regime_context
        
        # STEP 2: Validate regime confidence
        if not regime_context.is_high_confidence(threshold=0.6):
            logger.warning(f"⚠️ Low regime confidence ({regime_context.regime_confidence:.2f}) - applying conservative signal filtering")
        
        # STEP 3: Adapt signal generation to regime
        await self.adapt_to_regime(regime_context)
        
        # STEP 4: Generate raw signals using regime-adjusted parameters
        raw_signals = await self._generate_raw_signals(market_data)
        
        # STEP 5: Filter signals based on regime appropriateness
        regime_filtered_signals = await self._filter_signals_by_regime(raw_signals, regime_context)
        
        # STEP 6: Adjust signal confidence based on regime
        regime_adjusted_signals = await self._adjust_signal_confidence(regime_filtered_signals, regime_context)
        
        # STEP 7: Tag signals with regime context
        tagged_signals = self._tag_signals_with_regime(regime_adjusted_signals, regime_context)
        
        logger.info(f"✅ Generated {len(tagged_signals)} regime-aware signals "
                   f"(regime: {regime_context.primary_regime}, confidence: {regime_context.regime_confidence:.2f})")
        
        return tagged_signals
    
    async def _filter_signals_by_regime(self, signals: List[Signal], 
                                       regime_context: RegimeContext) -> List[Signal]:
        """Filter signals based on regime appropriateness"""
        
        filtered_signals = []
        
        for signal in signals:
            # Get signal's strategy type
            strategy_type = signal.metadata.get('strategy_type', 'unknown')
            
            # Get optimal weight for this strategy in current regime
            regime_weight = regime_context.get_strategy_weight(strategy_type)
            
            # Filter out signals from strategies inappropriate for current regime
            if regime_weight >= 0.3:  # Minimum threshold
                filtered_signals.append(signal)
            else:
                logger.debug(f"⚠️ Signal filtered: {strategy_type} not suitable for regime {regime_context.primary_regime} "
                           f"(weight: {regime_weight:.2f})")
        
        logger.info(f"📊 Regime filtering: {len(signals)} → {len(filtered_signals)} signals "
                   f"(regime: {regime_context.primary_regime})")
        
        return filtered_signals
    
    async def _adjust_signal_confidence(self, signals: List[Signal], 
                                       regime_context: RegimeContext) -> List[Signal]:
        """Adjust signal confidence based on regime conditions"""
        
        adjusted_signals = []
        
        for signal in signals:
            # Create adjusted signal
            adjusted_signal = signal.copy()
            
            # Base adjustment from regime confidence
            confidence_adjustment = regime_context.regime_confidence
            
            # Additional adjustments for stability
            if not regime_context.is_stable_regime():
                confidence_adjustment *= 0.9  # Reduce confidence during regime transitions
            
            # Adjust for regime alignment across timeframes
            if regime_context.regime_alignment_score < 0.7:
                confidence_adjustment *= 0.95  # Reduce confidence with conflicting timeframes
            
            # Apply adjustment
            adjusted_signal.confidence *= confidence_adjustment
            adjusted_signal.metadata['regime_adjustment_factor'] = confidence_adjustment
            adjusted_signal.metadata['original_confidence'] = signal.confidence
            
            adjusted_signals.append(adjusted_signal)
        
        return adjusted_signals
    
    def _tag_signals_with_regime(self, signals: List[Signal], 
                                regime_context: RegimeContext) -> List[Signal]:
        """Tag signals with comprehensive regime context"""
        
        for signal in signals:
            signal.metadata.update({
                'regime': regime_context.primary_regime,
                'regime_confidence': regime_context.regime_confidence,
                'volatility_regime': regime_context.volatility_regime,
                'liquidity_regime': regime_context.liquidity_regime,
                'trend_regime': regime_context.trend_regime,
                'regime_timestamp': regime_context.last_update.isoformat(),
                'regime_stable': regime_context.is_stable_regime(),
                'regime_alignment_score': regime_context.regime_alignment_score
            })
        
        return signals
    
    def validate_regime_dependency(self) -> bool:
        """Validate regime engine is properly configured"""
        if not self.regime_engine:
            logger.error("❌ REGIME-FIRST VIOLATION: Regime engine not configured")
            return False
        
        if not self.current_regime_context:
            logger.warning("⚠️ No current regime context - signals may not be regime-aware")
            return False
        
        return True
```

