### ISystemComponent Interface
```python
class MyComponent(ISystemComponent):
    async def initialize(self) -> bool:
        # Component initialization
        return True
    
    async def start(self) -> bool:
        # Start operations
        return True
    
    async def stop(self) -> bool:
        # Stop operations
        return True
    
    async def health_check(self) -> Dict[str, Any]:
        # Health status
        return {'healthy': True}
    
    def get_status(self) -> Dict[str, Any]:
        # Component status
        return {'operational': True}
```

### Authorization Request Pattern
```python
# MANDATORY for all privileged operations
authorization = await orchestrator.request_system_authorization(
    operation="market_data_access",
    component_id=self.component_id,
    details={"symbol": "NVDA", "timeframe": "1min"}
)
```

