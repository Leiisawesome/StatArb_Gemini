from dataclasses import dataclass
from typing import Dict, List, Optional
import numpy as np

@dataclass
class ExecutionQuality:
    """Professional execution quality metrics for institutional trading"""
    
    # Core Execution Metrics
    implementation_shortfall: float  # Actual vs theoretical cost
    vwap_slippage: float            # VWAP slippage (bps)
    market_impact: float            # Market impact cost (bps)
    timing_cost: float              # Timing cost (bps)
