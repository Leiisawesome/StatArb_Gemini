async def validate_live_trading_system(orchestrator) -> Dict[str, Any]:
    """Comprehensive validation of live trading system"""
    
    validation_results = {
        'data_connectivity': await validate_data_connectivity(orchestrator),
        'execution_connectivity': await validate_execution_connectivity(orchestrator),
        'risk_controls': await validate_risk_controls(orchestrator),
        'system_performance': await validate_system_performance(orchestrator),
        'overall_status': 'unknown'
    }
    
    # Calculate overall status
    all_validations_passed = all(
        result.get('status') == 'passed' 
        for result in validation_results.values() 
        if isinstance(result, dict)
    )
    
    validation_results['overall_status'] = 'passed' if all_validations_passed else 'failed'
    
    return validation_results

async def validate_data_connectivity(orchestrator) -> Dict:
    """Validate real-time data connectivity"""
    
    live_data_manager = orchestrator.get_component("LiveDataManager")
    
    # Test data stream
    test_start = datetime.now()
    data_received = False
    
    try:
        async with asyncio.timeout(10):  # 10 second timeout
            async for data_batch in live_data_manager.get_data_stream():
                if data_batch:
                    data_received = True
                    break
    except asyncio.TimeoutError:
        pass
    
    latency = (datetime.now() - test_start).total_seconds() * 1000  # ms
    
    return {
        'status': 'passed' if data_received and latency < 1000 else 'failed',
        'data_received': data_received,
        'latency_ms': latency,
        'timestamp': datetime.now()
    }
