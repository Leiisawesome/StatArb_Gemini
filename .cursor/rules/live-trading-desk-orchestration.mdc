    logger.info("🚀 Enhanced live trading loop starting...")
    
    while orchestrator.is_operational:
        try:
            # ═══════════════════════════════════════════════════════
            # STEP 1: Check Regime Context FIRST (Rule 13)
            # ═══════════════════════════════════════════════════════
            regime_context = await regime_engine.get_current_regime_context()
            
            if regime_context.regime_changed:
                logger.info(f"🔄 Regime changed: {regime_context.previous_regime} → "
                           f"{regime_context.primary_regime} (confidence: {regime_context.regime_confidence:.2f})")
                
                # Distribute regime change to all components
                await regime_engine.distribute_regime_context(regime_context)
                
                # Adjust risk limits for new regime
                await risk_manager.adjust_limits_for_regime(regime_context)
                
                # Rebalance strategy weights
                await strategy_manager.rebalance_for_regime(regime_context)
                
                # Adjust liquidity thresholds
                await liquidity_engine.adjust_for_regime(regime_context)
            
            # ═══════════════════════════════════════════════════════
            # STEP 2: Get Market Data with Regime Context
            # ═══════════════════════════════════════════════════════
            market_data = await data_manager.get_real_time_data()
            
            # ═══════════════════════════════════════════════════════
            # STEP 3: Assess Real-Time Liquidity (Rule 12)
            # ═══════════════════════════════════════════════════════
            liquidity_scores = {}
            orderbook_analyses = {}
            
            for symbol in market_data.symbols:
                # Assess liquidity
                liquidity_score = await liquidity_engine.assess_liquidity_score(
                    symbol, 
                    quantity=None  # General assessment
                )
                liquidity_scores[symbol] = liquidity_score
                
                # Analyze order book
                orderbook_analysis = await orderbook_analyzer.analyze_order_book(
                    symbol,
                    depth=10
                )
                orderbook_analyses[symbol] = orderbook_analysis
                
                # Log liquidity alerts
                if liquidity_score.overall_score < 50:
                    logger.warning(f"⚠️ Low liquidity for {symbol}: "
                                 f"score={liquidity_score.overall_score:.1f}, "
                                 f"regime={liquidity_score.liquidity_regime}")
                
                # Log order book imbalances
                if abs(orderbook_analysis.imbalance_ratio - 1.0) > 0.5:
                    logger.info(f"📊 Order book imbalance for {symbol}: "
                              f"ratio={orderbook_analysis.imbalance_ratio:.2f}")
            
            # ═══════════════════════════════════════════════════════
            # STEP 4: Generate Regime-Aware Signals (Rules 12 & 13)
            # ═══════════════════════════════════════════════════════
            raw_signals = await strategy_manager.generate_signals(
                market_data,
                regime_context=regime_context  # Pass regime context
            )
            
            # Filter signals by regime appropriateness and liquidity
            regime_filtered_signals = []
            for signal in raw_signals:
                # Check regime appropriateness
                strategy_weight = regime_context.get_strategy_weight(signal.strategy_type)
                if strategy_weight < 0.3:
                    logger.debug(f"⚠️ Signal filtered: {signal.strategy_type} "
                               f"not suitable for regime {regime_context.primary_regime}")
                    continue
                
                # Check liquidity
                liquidity_score = liquidity_scores.get(signal.symbol)
                if liquidity_score and liquidity_score.overall_score < 30:
                    logger.warning(f"⚠️ Signal filtered: {signal.symbol} "
                                 f"insufficient liquidity (score: {liquidity_score.overall_score:.1f})")
                    continue
                
                regime_filtered_signals.append(signal)
            
            logger.info(f"📊 Signals: {len(raw_signals)} generated, "
                       f"{len(regime_filtered_signals)} passed regime/liquidity filter")
            
            # ═══════════════════════════════════════════════════════
            # STEP 5: Liquidity-Aware Position Sizing (Rule 12)
            # ═══════════════════════════════════════════════════════
            for signal in regime_filtered_signals:
                liquidity_score = liquidity_scores[signal.symbol]
                orderbook = orderbook_analyses[signal.symbol]
                
                # Estimate market impact
                impact_estimate = await impact_model.estimate_market_impact(
                    signal.symbol,
                    signal.quantity,
                    signal.side,
                    urgency='normal'
                )
                
                # Adjust quantity if impact too high
                if impact_estimate.total_impact_bps > 15:
                    original_qty = signal.quantity
                    
                    # Optimize size for acceptable impact
                    optimized = await impact_model.optimize_execution_size(
                        signal.symbol,
                        signal.quantity,
                        max_impact_bps=15
                    )
                    
                    signal.quantity = optimized['recommended_quantity']
                    logger.info(f"📉 Reduced order size for {signal.symbol}: "
                              f"{original_qty:.0f} → {signal.quantity:.0f} "
                              f"(impact: {impact_estimate.total_impact_bps:.1f} bps)")
                
                # Add liquidity metadata to signal
                signal.metadata['liquidity_score'] = liquidity_score.overall_score
                signal.metadata['liquidity_regime'] = liquidity_score.liquidity_regime
                signal.metadata['estimated_impact_bps'] = impact_estimate.total_impact_bps
                signal.metadata['orderbook_imbalance'] = orderbook.imbalance_ratio
            
            # ═══════════════════════════════════════════════════════
            # STEP 6: Regime-Adjusted Risk Authorization (Rule 13)
            # ═══════════════════════════════════════════════════════
            authorized_trades = []
            
            for signal in regime_filtered_signals:
                # Create authorization request with regime context
                request = TradingDecisionRequest(
                    decision_type=TradingDecisionType.POSITION_ENTRY,
                    symbol=signal.symbol,
                    side=signal.side,
                    quantity=signal.quantity,
                    strategy_id=signal.strategy_id,
                    confidence=signal.confidence,
                    market_regime=regime_context.primary_regime,
                    regime_confidence=regime_context.regime_confidence,
                    metadata=signal.metadata
                )
                
                # Risk manager uses regime-adjusted limits
                authorization = await risk_manager.authorize_trading_decision(request)
                
                if authorization.authorization_level != AuthorizationLevel.REJECTED:
                    authorized_trades.append((signal, authorization))
                    logger.info(f"✅ Trade authorized: {signal.symbol} {signal.side} "
                              f"{authorization.quantity:.0f} @ confidence {signal.confidence:.2f}")
                else:
                    logger.warning(f"❌ Trade rejected: {signal.symbol} - "
                                 f"{authorization.rejection_reason}")
            
            # ═══════════════════════════════════════════════════════
            # STEP 7: Smart Order Routing & Execution (Rule 12)
            # ═══════════════════════════════════════════════════════
            execution_results = []
            
            for signal, authorization in authorized_trades:
                # Determine optimal routing
