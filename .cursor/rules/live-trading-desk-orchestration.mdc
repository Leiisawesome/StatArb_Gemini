## Live Trading Orchestration Workflow

### Phase 1: Live System Initialization (Regime-First - Rule 13)
```python
async def initialize_live_trading_system():
    """
    Initialize live trading desk with REGIME-FIRST principle (Rule 13)
    
    CRITICAL: RegimeEngine MUST initialize FIRST (order=5) to provide
    foundational market context to all other components.
    """
    
    # 1. Create orchestrator with live monitoring
    orchestrator = HierarchicalSystemOrchestrator(
        monitoring_interval=1,  # 1 second monitoring
        health_check_interval=10,  # 10 second health checks
        enable_real_time_alerts=True
    )
    
    # STEP 1: Register Regime Engine FIRST (order=5) - Rule 13
    # This is the foundational Layer 0 component
    live_regime_engine = EnhancedRegimeEngine({
        **regime_config,
        'real_time_mode': True,
        'update_frequency': 60,              # Update every minute
        'enable_regime_distribution': True,  # Enable context distribution
        'enable_ml_prediction': True,        # ML-based regime prediction
        'enable_transition_detection': True  # Detect regime transitions
    })
    
    orchestrator.register_component(
        name="EnhancedRegimeEngine",
        component=live_regime_engine,
        layer=ComponentLayer.SUPPORT,
        authority_level=AuthorityLevel.OPERATIONAL,
        initialization_order=5,  # CRITICAL: First to initialize (Layer 0)
        critical=True
    )
    
    # Initialize regime engine immediately
    await live_regime_engine.initialize()
    await live_regime_engine.start()
    
    logger.info("✅ Regime Engine initialized (Layer 0 - Foundation)")
    
    # 2. Register live data management (order=10) with regime context
    live_data_manager = ClickHouseDataManager(live_data_config)
    live_data_manager.set_regime_engine(live_regime_engine)  # Inject regime context
    
    # Subscribe to regime changes
    await live_regime_engine.subscribe_component(
        live_data_manager,
        callback=live_data_manager.on_regime_change
    )
    
    orchestrator.register_component(
        name="LiveDataManager",
        component=live_data_manager,
        layer=ComponentLayer.SUPPORT,
        authority_level=AuthorityLevel.OPERATIONAL,
        initialization_order=10,  # After regime engine
        critical=True  # Critical for live trading
    )
    
    logger.info("✅ Data Manager registered with regime awareness")
    
    # 4. Register streaming processing pipeline
    streaming_indicators = StreamingTechnicalIndicators(
        update_frequency=5,  # 5 second updates
        enable_real_time_calculation=True
    )
    adaptive_features = AdaptiveFeatureEngine(
        adaptation_interval=300,  # 5 minute adaptation
        enable_online_learning=True
    )
    live_signals = LiveSignalGenerator(
        signal_frequency=10,  # 10 second signal generation
        confidence_threshold=0.65  # Higher threshold for live trading
    )
    
    orchestrator.register_component("StreamingIndicators", streaming_indicators, ComponentLayer.SUPPORT, initialization_order=3)
    orchestrator.register_component("AdaptiveFeatures", adaptive_features, ComponentLayer.SUPPORT, initialization_order=4)
    orchestrator.register_component("LiveSignals", live_signals, ComponentLayer.SUPPORT, initialization_order=5)
    
    # 5. Register live risk management (CRITICAL)
    live_risk_manager = CentralRiskManager(live_risk_config)
    orchestrator.register_component(
        name="LiveRiskManager",
        component=live_risk_manager,
        layer=ComponentLayer.GOVERNANCE,
        authority_level=AuthorityLevel.GOVERNANCE_CONTROL,
        initialization_order=6,
        critical=True  # CRITICAL - No trading without risk management
    )
    
    # 6. Register live execution layer
    live_strategy_manager = StrategyManager({
        **strategy_config,
        'live_mode': True,
        'position_sizing_mode': 'dynamic',
        'regime_adaptation': True
    })
    
    real_time_trading_engine = RealTimeTradingEngine(live_execution_config)
    unified_execution_engine = UnifiedExecutionEngine({
        **live_execution_config,
        'enable_position_tracking': True,
        'risk_manager_callback': live_risk_manager
    })
    
    live_portfolio_manager = LivePortfolioManager(
        update_frequency=1,  # 1 second position updates
        enable_real_time_pnl=True,
        enable_risk_attribution=True
    )
    
    orchestrator.register_component("LiveStrategyManager", live_strategy_manager, ComponentLayer.EXECUTION, initialization_order=7)
    orchestrator.register_component("RealTimeTradingEngine", real_time_trading_engine, ComponentLayer.EXECUTION, initialization_order=8)
    orchestrator.register_component("UnifiedExecutionEngine", unified_execution_engine, ComponentLayer.EXECUTION, initialization_order=9)
    orchestrator.register_component("LivePortfolioManager", live_portfolio_manager, ComponentLayer.EXECUTION, initialization_order=10)
    
    # 7. Register monitoring and alerting
    risk_monitor = RealTimeRiskMonitor(
        monitoring_frequency=1,  # 1 second monitoring
        alert_thresholds=live_risk_config.alert_thresholds,
        enable_automated_responses=True
    )
    orchestrator.register_component("RiskMonitor", risk_monitor, ComponentLayer.GOVERNANCE, initialization_order=11)
    
    # 8. Initialize all components with dependency checking
    initialization_success = await orchestrator.initialize_all_components()
    if not initialization_success:
        raise RuntimeError("Critical component initialization failed")
    
    # 9. Start all components
    startup_success = await orchestrator.start_all_components()
    if not startup_success:
        raise RuntimeError("Critical component startup failed")
    
    # 10. Verify system health before trading
    system_health = await orchestrator.system_health_check()
    if not system_health['overall_healthy']:
        raise RuntimeError(f"System health check failed: {system_health}")
    
    logger.info("🚀 Live trading system initialized and operational")
    return orchestrator
```

### Phase 2: Real-Time Market Data Processing
```python
async def start_live_data_processing(orchestrator):
    """Start real-time market data processing pipeline"""
    
    live_data_manager = orchestrator.get_component("LiveDataManager")
    streaming_indicators = orchestrator.get_component("StreamingIndicators")
    adaptive_features = orchestrator.get_component("AdaptiveFeatures")
    live_signals = orchestrator.get_component("LiveSignals")
    live_regime_engine = orchestrator.get_component("LiveRegimeEngine")
    
    # Start data streaming
    await live_data_manager.start_streaming()
    
    # Set up real-time processing pipeline
    async def process_market_data_stream():
        """Process incoming market data in real-time"""
        
        async for market_data_batch in live_data_manager.get_data_stream():
            try:
                # 1. Update regime analysis
                await live_regime_engine.update_regime_analysis(market_data_batch)
                
                # 2. Calculate streaming indicators
                indicators = await streaming_indicators.update_indicators(market_data_batch)
                
                # 3. Engineer features adaptively
                features = await adaptive_features.update_features(indicators)
                
                # 4. Generate live trading signals
                signals = await live_signals.generate_signals(features)
                
                # 5. Publish signals for strategy consumption
                if signals:
                    await orchestrator.publish_event(
                        event_type="live_signals_generated",
                        event_data={"signals": signals, "timestamp": datetime.now()}
                    )
                
            except Exception as e:
                logger.error(f"Error in live data processing: {e}")
                # Continue processing - don't stop the stream
    
    # Start processing task
    processing_task = asyncio.create_task(process_market_data_stream())
    
    return processing_task
```

### Phase 3: Live Strategy Execution
```python
async def run_live_strategy_execution(orchestrator):
    """Execute live trading strategies with real-time risk management"""
    
    live_strategy_manager = orchestrator.get_component("LiveStrategyManager")
    live_risk_manager = orchestrator.get_component("LiveRiskManager")
    real_time_trading_engine = orchestrator.get_component("RealTimeTradingEngine")
    unified_execution_engine = orchestrator.get_component("UnifiedExecutionEngine")
    
    # Subscribe to live signals
    async def handle_live_signals(event_data):
        """Handle incoming live trading signals"""
        
        signals = event_data["signals"]
        current_regime = await orchestrator.get_component("LiveRegimeEngine").get_current_regime()
        
        for signal in signals:
            try:
                # 1. Strategy manager evaluates signal
                strategy_decision = await live_strategy_manager.evaluate_signal(
                    signal, current_regime
                )
                
                if not strategy_decision.should_trade:
                    continue
                
                # 2. Create trading decision request
                request = TradingDecisionRequest(
                    decision_type=TradingDecisionType.POSITION_ENTRY,
                    symbol=signal.symbol,
                    side=signal.signal_type.value,
                    quantity=strategy_decision.quantity,
                    strategy_id=strategy_decision.strategy_id,
                    confidence=signal.confidence,
                    market_regime=current_regime.primary_regime.value,
                    urgency=ExecutionUrgency.NORMAL,
                    requesting_component="LiveStrategyManager"
                )
                
                # 3. Request authorization from risk manager (MANDATORY)
                authorization = await live_risk_manager.authorize_trading_decision(request)
                
                if authorization.authorization_level == AuthorizationLevel.REJECTED:
                    logger.warning(f"Trade rejected: {authorization.rejection_reason}")
                    continue
                
                # 4. Create execution plan
                execution_plan = await real_time_trading_engine.create_execution_plan(
                    authorization, current_market_conditions=signal.metadata
                )
                
                # 5. Execute trade
                execution_result = await unified_execution_engine.execute_authorized_trade(
                    execution_plan
                )
                
                # 6. Log execution result
                logger.info(f"Live trade executed: {execution_result.status} - "
                           f"{signal.symbol} {signal.signal_type} {execution_result.filled_quantity}")
                
            except Exception as e:
                logger.error(f"Error executing live signal: {e}")
                # Continue with next signal
    
    # Subscribe to live signals
    await orchestrator.subscribe_to_event("live_signals_generated", handle_live_signals)
```

### Phase 4: Real-Time Risk Monitoring
```python
async def start_real_time_risk_monitoring(orchestrator):
    """Start continuous risk monitoring and alerting"""
    
    risk_monitor = orchestrator.get_component("RiskMonitor")
    live_risk_manager = orchestrator.get_component("LiveRiskManager")
    live_portfolio_manager = orchestrator.get_component("LivePortfolioManager")
    
    async def continuous_risk_monitoring():
        """Continuous risk monitoring loop"""
        
        while orchestrator.is_operational:
            try:
                # 1. Get current portfolio state
                portfolio_state = await live_portfolio_manager.get_current_state()
                
                # 2. Calculate real-time risk metrics
                risk_metrics = await live_risk_manager.calculate_real_time_risk(portfolio_state)
                
                # 3. Check for risk limit breaches
                risk_violations = await risk_monitor.check_risk_violations(risk_metrics)
                
                # 4. Handle violations
                if risk_violations:
                    await handle_risk_violations(orchestrator, risk_violations)
                
                # 5. Update risk dashboard
                await orchestrator.publish_event(
                    event_type="risk_metrics_updated",
                    event_data={
                        "risk_metrics": risk_metrics,
                        "violations": risk_violations,
                        "timestamp": datetime.now()
                    }
                )
                
                # Wait before next check
                await asyncio.sleep(live_risk_config.risk_check_interval)
                
            except Exception as e:
                logger.error(f"Error in risk monitoring: {e}")
                await asyncio.sleep(5)  # Brief pause before retry
    
    # Start monitoring task
    monitoring_task = asyncio.create_task(continuous_risk_monitoring())
    return monitoring_task

async def handle_risk_violations(orchestrator, violations):
    """Handle risk limit violations with automated responses"""
    
    live_risk_manager = orchestrator.get_component("LiveRiskManager")
    
    for violation in violations:
        if violation.severity == "CRITICAL":
            # Emergency shutdown
            logger.critical(f"CRITICAL risk violation: {violation.description}")
            await live_risk_manager.emergency_shutdown()
            
        elif violation.severity == "HIGH":
            # Reduce positions
            logger.error(f"HIGH risk violation: {violation.description}")
            await live_risk_manager.reduce_positions(violation.affected_positions)
            
        elif violation.severity == "MEDIUM":
            # Alert and monitor
            logger.warning(f"MEDIUM risk violation: {violation.description}")
            await send_risk_alert(violation)
