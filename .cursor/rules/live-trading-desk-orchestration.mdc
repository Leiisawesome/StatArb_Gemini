                    signal.symbol,
                    authorization.quantity,
                    signal.side,
                    urgency='normal'
                )
                
                logger.info(f"🎯 Routing {signal.symbol}: {len(routing_plan['routing_plan'])} venues")
                
                # Execute with routing plan
                execution_result = await execution_engine.execute_with_routing(
                    authorization,
                    routing_plan,
                    regime_context=regime_context  # Pass regime context
                )
                
                execution_results.append((signal, execution_result))
                
                logger.info(f"✅ Executed: {signal.symbol} {signal.side} "
                          f"{execution_result.filled_quantity:.0f} @ "
                          f"${execution_result.avg_fill_price:.2f}")
            
            # ═══════════════════════════════════════════════════════
            # STEP 8: Real-Time Execution Quality Analysis (Rule 12)
            # ═══════════════════════════════════════════════════════
            for signal, execution_result in execution_results:
                # Analyze execution quality (TCA)
                tca_analysis = await tca_analyzer.analyze_execution_quality(
                    execution_result,
                    market_data[signal.symbol]
