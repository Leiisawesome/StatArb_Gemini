# Rule 12: Market Microstructure and Liquidity Management Standards

All trading components within the core_engine must implement **liquidity risk assessment**, **market impact modeling**, **order book analytics**, **smart order routing**, and **execution quality measurement** to ensure institutional-grade execution.

## 1. Liquidity Management Component Requirements

All liquidity management components MUST implement the `ISystemComponent` interface and provide real-time liquidity assessment:

```python
from core_engine.system.interfaces import ISystemComponent
from abc import abstractmethod
from typing import Dict, Any, List, Optional, Tuple
import pandas as pd
import numpy as np
from datetime import datetime, timedelta
from enum import Enum

class LiquidityRegime(Enum):
    HIGH_LIQUIDITY = "high_liquidity"
    NORMAL_LIQUIDITY = "normal_liquidity"
    LOW_LIQUIDITY = "low_liquidity"
    ILLIQUID = "illiquid"
    CRISIS_LIQUIDITY = "crisis_liquidity"

class ILiquidityComponent(ISystemComponent):
    """Enhanced interface for liquidity management components"""
    
    @abstractmethod
    async def assess_liquidity_score(self, symbol: str, quantity: float) -> Dict[str, Any]:
        """Assess real-time liquidity score for a symbol and quantity"""
        pass
    
    @abstractmethod
    async def estimate_market_impact(self, symbol: str, quantity: float, 
                                   side: str, urgency: str) -> Dict[str, Any]:
        """Estimate market impact for a trade"""
        pass
    
    @abstractmethod
    async def analyze_order_book(self, symbol: str, depth: int = 10) -> Dict[str, Any]:
        """Analyze order book depth and market microstructure"""
        pass
    
    @abstractmethod
    async def get_liquidity_regime(self, symbol: str) -> LiquidityRegime:
        """Determine current liquidity regime for a symbol"""
        pass
    
    @abstractmethod
    async def optimize_execution_size(self, symbol: str, target_quantity: float,
                                     max_impact_bps: float) -> Dict[str, Any]:
        """Optimize execution size based on liquidity constraints"""
        pass
```

## 2. Real-Time Liquidity Assessment

### Liquidity Scoring Framework
```python
from dataclasses import dataclass
from typing import Dict, List, Optional
import numpy as np
from datetime import datetime

@dataclass
class LiquidityScore:
    """Comprehensive liquidity scoring metrics"""
    
    # Core Liquidity Metrics
    overall_score: float  # 0-100 composite liquidity score
    liquidity_regime: LiquidityRegime
    confidence: float  # Confidence in assessment (0-1)
    
    # Volume-Based Metrics
    avg_daily_volume: float  # Average daily volume
    current_volume_ratio: float  # Current volume vs average
    volume_percentile: float  # Percentile vs historical distribution
    
    # Spread Metrics
    bid_ask_spread_bps: float  # Bid-ask spread in basis points
    effective_spread_bps: float  # Effective spread (including fees)
    spread_percentile: float  # Spread vs historical distribution
    
    # Depth Metrics
    market_depth: float  # Total depth at top 10 levels
    depth_imbalance: float  # Buy vs sell depth imbalance
    order_book_resilience: float  # How quickly book recovers
    
    # Impact Metrics
    estimated_impact_10k: float  # Impact for $10K trade (bps)
    estimated_impact_100k: float  # Impact for $100K trade (bps)
    estimated_impact_1m: float  # Impact for $1M trade (bps)
    
    # Time-Based Metrics
    time_to_execute_1pct: float  # Time to execute 1% ADV (minutes)
    intraday_liquidity_pattern: str  # Peak/normal/low liquidity period
    
    # Risk Metrics
    liquidity_risk_score: float  # Overall liquidity risk (0-100)
    slippage_risk: float  # Expected slippage risk
    
    timestamp: datetime

class LiquidityAssessmentEngine(ILiquidityComponent):
    """Real-time liquidity assessment engine"""
    
    def __init__(self, config: Dict[str, Any]):
        super().__init__()
        self.config = config
        self.liquidity_cache = {}
        self.historical_metrics = {}
        self.update_frequency = config.get('update_frequency', 60)  # seconds
        
        # Liquidity thresholds
        self.liquidity_thresholds = {
            'high_liquidity': {
                'min_adv': 1_000_000,  # $1M+ ADV
                'max_spread_bps': 5,
                'min_depth': 500_000,
                'max_impact_100k_bps': 5
            },
            'normal_liquidity': {
                'min_adv': 250_000,
                'max_spread_bps': 10,
                'min_depth': 100_000,
                'max_impact_100k_bps': 15
            },
            'low_liquidity': {
                'min_adv': 50_000,
                'max_spread_bps': 25,
                'min_depth': 20_000,
                'max_impact_100k_bps': 50
            }
        }
    
    async def assess_liquidity_score(self, symbol: str, quantity: float = None) -> LiquidityScore:
        """Comprehensive liquidity assessment"""
        
        try:
            # Gather market data
            market_data = await self._gather_market_data(symbol)
            order_book = await self._get_order_book(symbol)
            historical_metrics = await self._get_historical_metrics(symbol)
            
            # Calculate volume metrics
            volume_metrics = self._calculate_volume_metrics(
                market_data, historical_metrics
            )
            
            # Calculate spread metrics
            spread_metrics = self._calculate_spread_metrics(
                order_book, historical_metrics
            )
            
            # Calculate depth metrics
            depth_metrics = self._calculate_depth_metrics(
                order_book, historical_metrics
            )
            
            # Calculate impact metrics
            impact_metrics = self._calculate_impact_metrics(
                symbol, order_book, volume_metrics, quantity
            )
            
            # Calculate time-based metrics
            time_metrics = self._calculate_time_metrics(
                symbol, volume_metrics, market_data
            )
            
            # Determine liquidity regime
            liquidity_regime = self._determine_liquidity_regime(
                volume_metrics, spread_metrics, depth_metrics, impact_metrics
            )
            
            # Calculate composite liquidity score
            overall_score = self._calculate_composite_score(
                volume_metrics, spread_metrics, depth_metrics, 
                impact_metrics, liquidity_regime
            )
            
            # Calculate risk metrics
            risk_metrics = self._calculate_liquidity_risk(
                liquidity_regime, spread_metrics, impact_metrics
            )
            
            liquidity_score = LiquidityScore(
                overall_score=overall_score,
                liquidity_regime=liquidity_regime,
                confidence=self._calculate_confidence(market_data, historical_metrics),
                avg_daily_volume=volume_metrics['avg_daily_volume'],
                current_volume_ratio=volume_metrics['current_volume_ratio'],
                volume_percentile=volume_metrics['volume_percentile'],
                bid_ask_spread_bps=spread_metrics['bid_ask_spread_bps'],
                effective_spread_bps=spread_metrics['effective_spread_bps'],
                spread_percentile=spread_metrics['spread_percentile'],
                market_depth=depth_metrics['market_depth'],
                depth_imbalance=depth_metrics['depth_imbalance'],
                order_book_resilience=depth_metrics['order_book_resilience'],
                estimated_impact_10k=impact_metrics['impact_10k'],
                estimated_impact_100k=impact_metrics['impact_100k'],
                estimated_impact_1m=impact_metrics['impact_1m'],
                time_to_execute_1pct=time_metrics['time_to_execute_1pct'],
                intraday_liquidity_pattern=time_metrics['liquidity_pattern'],
                liquidity_risk_score=risk_metrics['liquidity_risk_score'],
                slippage_risk=risk_metrics['slippage_risk'],
                timestamp=datetime.now()
            )
            
            # Cache result
            self.liquidity_cache[symbol] = liquidity_score
            
            return liquidity_score
            
        except Exception as e:
            self.logger.error(f"Liquidity assessment failed for {symbol}: {e}")
            raise
    
    def _calculate_volume_metrics(self, market_data: Dict[str, Any],
                                  historical_metrics: Dict[str, Any]) -> Dict[str, float]:
        """Calculate volume-based liquidity metrics"""
        
        current_volume = market_data.get('volume', 0)
        historical_volumes = historical_metrics.get('volumes', [])
        
        if not historical_volumes:
            return {
                'avg_daily_volume': 0,
                'current_volume_ratio': 0,
                'volume_percentile': 0
            }
        
        avg_daily_volume = np.mean(historical_volumes)
        current_volume_ratio = current_volume / avg_daily_volume if avg_daily_volume > 0 else 0
        
        # Calculate percentile
        volume_percentile = (
            sum(1 for v in historical_volumes if v <= current_volume) / 
            len(historical_volumes) * 100
        )
        
        return {
            'avg_daily_volume': avg_daily_volume,
            'current_volume_ratio': current_volume_ratio,
            'volume_percentile': volume_percentile
        }
    
    def _calculate_spread_metrics(self, order_book: Dict[str, Any],
                                  historical_metrics: Dict[str, Any]) -> Dict[str, float]:
        """Calculate spread-based liquidity metrics"""
        
        best_bid = order_book.get('best_bid', 0)
        best_ask = order_book.get('best_ask', 0)
        mid_price = (best_bid + best_ask) / 2 if best_bid > 0 and best_ask > 0 else 0
        
        # Bid-ask spread
        if mid_price > 0:
            bid_ask_spread_bps = ((best_ask - best_bid) / mid_price) * 10000
        else:
            bid_ask_spread_bps = 0
        
        # Effective spread (including estimated fees)
        transaction_costs_bps = self.config.get('transaction_costs_bps', 2.0)
        effective_spread_bps = bid_ask_spread_bps + transaction_costs_bps
        
        # Historical spread percentile
        historical_spreads = historical_metrics.get('spreads', [])
        if historical_spreads:
            spread_percentile = (
                sum(1 for s in historical_spreads if s <= bid_ask_spread_bps) / 
                len(historical_spreads) * 100
            )
        else:
            spread_percentile = 50.0
        
        return {
            'bid_ask_spread_bps': bid_ask_spread_bps,
            'effective_spread_bps': effective_spread_bps,
            'spread_percentile': spread_percentile
        }
    
    def _calculate_depth_metrics(self, order_book: Dict[str, Any],
                                 historical_metrics: Dict[str, Any]) -> Dict[str, float]:
        """Calculate order book depth metrics"""
        
        bids = order_book.get('bids', [])
        asks = order_book.get('asks', [])
        
        # Calculate total depth (top 10 levels)
        bid_depth = sum(level['size'] * level['price'] for level in bids[:10])
        ask_depth = sum(level['size'] * level['price'] for level in asks[:10])
        market_depth = bid_depth + ask_depth
        
        # Depth imbalance
        if market_depth > 0:
            depth_imbalance = (bid_depth - ask_depth) / market_depth
        else:
            depth_imbalance = 0
        
        # Order book resilience (how quickly depth recovers after trades)
        # This would require historical order book data
        historical_resilience = historical_metrics.get('order_book_resilience', 0.5)
        order_book_resilience = historical_resilience
        
        return {
            'market_depth': market_depth,
            'depth_imbalance': depth_imbalance,
            'order_book_resilience': order_book_resilience
        }
    
    def _determine_liquidity_regime(self, volume_metrics: Dict[str, float],
                                   spread_metrics: Dict[str, float],
                                   depth_metrics: Dict[str, float],
                                   impact_metrics: Dict[str, float]) -> LiquidityRegime:
        """Determine current liquidity regime"""
        
        adv = volume_metrics['avg_daily_volume']
        spread_bps = spread_metrics['bid_ask_spread_bps']
        depth = depth_metrics['market_depth']
        impact_100k = impact_metrics['impact_100k']
        
        # High liquidity
        if (adv >= self.liquidity_thresholds['high_liquidity']['min_adv'] and
            spread_bps <= self.liquidity_thresholds['high_liquidity']['max_spread_bps'] and
            depth >= self.liquidity_thresholds['high_liquidity']['min_depth'] and
            impact_100k <= self.liquidity_thresholds['high_liquidity']['max_impact_100k_bps']):
            return LiquidityRegime.HIGH_LIQUIDITY
        
        # Normal liquidity
        elif (adv >= self.liquidity_thresholds['normal_liquidity']['min_adv'] and
              spread_bps <= self.liquidity_thresholds['normal_liquidity']['max_spread_bps'] and
              depth >= self.liquidity_thresholds['normal_liquidity']['min_depth'] and
              impact_100k <= self.liquidity_thresholds['normal_liquidity']['max_impact_100k_bps']):
            return LiquidityRegime.NORMAL_LIQUIDITY
        
        # Low liquidity
        elif (adv >= self.liquidity_thresholds['low_liquidity']['min_adv'] and
              spread_bps <= self.liquidity_thresholds['low_liquidity']['max_spread_bps']):
            return LiquidityRegime.LOW_LIQUIDITY
        
        # Crisis liquidity (extreme spreads or very low volume)
        elif spread_bps > 50 or volume_metrics['current_volume_ratio'] < 0.1:
            return LiquidityRegime.CRISIS_LIQUIDITY
        
        # Default to illiquid
        else:
            return LiquidityRegime.ILLIQUID
    
    def _calculate_composite_score(self, volume_metrics: Dict[str, float],
                                   spread_metrics: Dict[str, float],
                                   depth_metrics: Dict[str, float],
                                   impact_metrics: Dict[str, float],
                                   liquidity_regime: LiquidityRegime) -> float:
        """Calculate composite liquidity score (0-100)"""
        
        # Base score from regime
        regime_scores = {
            LiquidityRegime.HIGH_LIQUIDITY: 85,
            LiquidityRegime.NORMAL_LIQUIDITY: 65,
            LiquidityRegime.LOW_LIQUIDITY: 40,
            LiquidityRegime.ILLIQUID: 20,
            LiquidityRegime.CRISIS_LIQUIDITY: 10
        }
        base_score = regime_scores.get(liquidity_regime, 50)
        
        # Adjust based on volume percentile
        volume_adjustment = (volume_metrics['volume_percentile'] - 50) * 0.2
        
        # Adjust based on spread percentile (lower spread is better)
        spread_adjustment = (50 - spread_metrics['spread_percentile']) * 0.2
        
        # Adjust based on depth
        depth_score = min(100, depth_metrics['market_depth'] / 100000 * 10)
        depth_adjustment = (depth_score - 50) * 0.1
        
        # Calculate final score
        composite_score = base_score + volume_adjustment + spread_adjustment + depth_adjustment
        
        # Ensure score is in valid range
        return max(0, min(100, composite_score))
```

## 3. Market Impact Modeling

### Professional Market Impact Framework
```python
from dataclasses import dataclass
from typing import Dict, Any, Optional
import numpy as np

@dataclass
class MarketImpactEstimate:
    """Comprehensive market impact estimation"""
    
    # Impact Components
    permanent_impact_bps: float  # Permanent price impact
    temporary_impact_bps: float  # Temporary impact (recovers)
    total_impact_bps: float  # Total estimated impact
    
    # Cost Analysis
    execution_cost_bps: float  # Total execution cost
    opportunity_cost_bps: float  # Cost of delayed execution
    total_cost_bps: float  # Total transaction cost
    
    # Execution Recommendations
    recommended_slices: int  # Recommended order slices
    recommended_duration_minutes: float  # Recommended execution time
    max_participation_rate: float  # Max % of volume
    optimal_strategy: str  # Recommended execution strategy
    
    # Risk Metrics
    impact_risk_score: float  # Risk of higher than expected impact
    price_risk_bps: float  # Risk of adverse price movement
    
    # Model Confidence
    confidence: float  # Confidence in estimate (0-1)
    model_type: str  # Impact model used
    
    timestamp: datetime

class MarketImpactModel(ILiquidityComponent):
    """Advanced market impact modeling engine"""
    
    def __init__(self, config: Dict[str, Any]):
        super().__init__()
        self.config = config
        
        # Model parameters
        self.linear_coefficient = config.get('linear_coefficient', 0.1)
        self.sqrt_coefficient = config.get('sqrt_coefficient', 0.5)
        self.permanent_impact_factor = config.get('permanent_impact_factor', 0.3)
        self.temporary_impact_factor = config.get('temporary_impact_factor', 0.7)
    
    async def estimate_market_impact(self, symbol: str, quantity: float,
                                   side: str, urgency: str = 'normal') -> MarketImpactEstimate:
        """Estimate market impact using advanced models"""
        
        try:
            # Get market data
            market_data = await self._gather_market_data(symbol)
            liquidity_score = await self._get_liquidity_score(symbol)
            order_book = await self._get_order_book(symbol)
            
            # Calculate volume participation rate
            avg_daily_volume = liquidity_score.avg_daily_volume
            participation_rate = quantity / avg_daily_volume if avg_daily_volume > 0 else 1.0
            
            # Select impact model based on liquidity regime
            if liquidity_score.liquidity_regime == LiquidityRegime.HIGH_LIQUIDITY:
                impact_estimate = self._almgren_chriss_model(
                    quantity, market_data, liquidity_score, participation_rate
                )
            elif liquidity_score.liquidity_regime == LiquidityRegime.NORMAL_LIQUIDITY:
                impact_estimate = self._kyle_model(
                    quantity, market_data, liquidity_score, participation_rate
                )
            else:
                impact_estimate = self._simple_impact_model(
                    quantity, market_data, liquidity_score, participation_rate
                )
            
            # Adjust for urgency
            impact_estimate = self._adjust_for_urgency(impact_estimate, urgency)
            
            # Calculate execution recommendations
            recommendations = self._generate_execution_recommendations(
                quantity, market_data, liquidity_score, impact_estimate
            )
            
            # Calculate risk metrics
            risk_metrics = self._calculate_impact_risk(
                impact_estimate, liquidity_score, participation_rate
            )
            
            return MarketImpactEstimate(
                permanent_impact_bps=impact_estimate['permanent_impact_bps'],
                temporary_impact_bps=impact_estimate['temporary_impact_bps'],
                total_impact_bps=impact_estimate['total_impact_bps'],
                execution_cost_bps=impact_estimate['execution_cost_bps'],
                opportunity_cost_bps=impact_estimate['opportunity_cost_bps'],
                total_cost_bps=impact_estimate['total_cost_bps'],
                recommended_slices=recommendations['recommended_slices'],
                recommended_duration_minutes=recommendations['duration_minutes'],
                max_participation_rate=recommendations['max_participation_rate'],
                optimal_strategy=recommendations['optimal_strategy'],
                impact_risk_score=risk_metrics['impact_risk_score'],
                price_risk_bps=risk_metrics['price_risk_bps'],
                confidence=self._calculate_model_confidence(liquidity_score),
                model_type=impact_estimate['model_type'],
                timestamp=datetime.now()
            )
            
        except Exception as e:
            self.logger.error(f"Market impact estimation failed for {symbol}: {e}")
            raise
    
    def _almgren_chriss_model(self, quantity: float, market_data: Dict[str, Any],
                             liquidity_score: LiquidityScore,
                             participation_rate: float) -> Dict[str, Any]:
        """Almgren-Chriss optimal execution model"""
        
        # Model parameters
        volatility = market_data.get('volatility', 0.02)
        price = market_data.get('price', 100.0)
        
        # Permanent impact (linear in quantity)
        permanent_impact = self.linear_coefficient * participation_rate
        
        # Temporary impact (square root law)
        temporary_impact = self.sqrt_coefficient * np.sqrt(participation_rate)
        
        # Total impact in basis points
        total_impact_bps = (permanent_impact + temporary_impact) * 10000
        permanent_impact_bps = permanent_impact * 10000
        temporary_impact_bps = temporary_impact * 10000
        
        # Execution cost (spread + impact)
        spread_cost_bps = liquidity_score.bid_ask_spread_bps / 2  # Half spread
        execution_cost_bps = spread_cost_bps + total_impact_bps
        
        # Opportunity cost (risk of price moving against us)
        # Based on volatility and execution time
        execution_time_minutes = self._estimate_execution_time(participation_rate)
        daily_volatility = volatility / np.sqrt(252)  # Daily vol
        time_fraction = execution_time_minutes / (6.5 * 60)  # Fraction of trading day
        opportunity_cost_bps = daily_volatility * np.sqrt(time_fraction) * 10000
        
        return {
            'permanent_impact_bps': permanent_impact_bps,
            'temporary_impact_bps': temporary_impact_bps,
            'total_impact_bps': total_impact_bps,
            'execution_cost_bps': execution_cost_bps,
            'opportunity_cost_bps': opportunity_cost_bps,
            'total_cost_bps': execution_cost_bps + opportunity_cost_bps,
            'model_type': 'almgren_chriss'
        }
    
    def _kyle_model(self, quantity: float, market_data: Dict[str, Any],
                   liquidity_score: LiquidityScore,
                   participation_rate: float) -> Dict[str, Any]:
        """Kyle's lambda model for market impact"""
        
        volatility = market_data.get('volatility', 0.02)
        avg_volume = liquidity_score.avg_daily_volume
        
        # Kyle's lambda (price impact per unit volume)
        kyle_lambda = volatility / np.sqrt(avg_volume) if avg_volume > 0 else 0.001
        
        # Impact calculation
        total_impact = kyle_lambda * quantity
        total_impact_bps = total_impact * 10000
        
        # Split into permanent and temporary
        permanent_impact_bps = total_impact_bps * self.permanent_impact_factor
        temporary_impact_bps = total_impact_bps * self.temporary_impact_factor
        
        # Execution cost
        spread_cost_bps = liquidity_score.bid_ask_spread_bps / 2
        execution_cost_bps = spread_cost_bps + total_impact_bps
        
        # Opportunity cost
        execution_time_minutes = self._estimate_execution_time(participation_rate)
        opportunity_cost_bps = self._calculate_opportunity_cost(
            volatility, execution_time_minutes
        )
        
        return {
            'permanent_impact_bps': permanent_impact_bps,
            'temporary_impact_bps': temporary_impact_bps,
            'total_impact_bps': total_impact_bps,
            'execution_cost_bps': execution_cost_bps,
            'opportunity_cost_bps': opportunity_cost_bps,
            'total_cost_bps': execution_cost_bps + opportunity_cost_bps,
            'model_type': 'kyle_lambda'
        }
    
    def _simple_impact_model(self, quantity: float, market_data: Dict[str, Any],
                            liquidity_score: LiquidityScore,
                            participation_rate: float) -> Dict[str, Any]:
        """Simple square-root impact model for low liquidity"""
        
        # Square root scaling with liquidity adjustments
        base_impact = 10.0  # Base 10 bps for 1% participation
        liquidity_multiplier = {
            LiquidityRegime.LOW_LIQUIDITY: 2.0,
            LiquidityRegime.ILLIQUID: 3.0,
            LiquidityRegime.CRISIS_LIQUIDITY: 5.0
        }.get(liquidity_score.liquidity_regime, 1.5)
        
        total_impact_bps = base_impact * np.sqrt(participation_rate * 100) * liquidity_multiplier
        
        # Split into components
        permanent_impact_bps = total_impact_bps * 0.4
        temporary_impact_bps = total_impact_bps * 0.6
        
        # Costs
        spread_cost_bps = liquidity_score.bid_ask_spread_bps / 2
        execution_cost_bps = spread_cost_bps + total_impact_bps
        
        # Higher opportunity cost in illiquid markets
        execution_time_minutes = self._estimate_execution_time(participation_rate) * 1.5
        volatility = market_data.get('volatility', 0.03)  # Assume higher vol
        opportunity_cost_bps = self._calculate_opportunity_cost(
            volatility, execution_time_minutes
        ) * 1.5
        
        return {
            'permanent_impact_bps': permanent_impact_bps,
            'temporary_impact_bps': temporary_impact_bps,
            'total_impact_bps': total_impact_bps,
            'execution_cost_bps': execution_cost_bps,
            'opportunity_cost_bps': opportunity_cost_bps,
            'total_cost_bps': execution_cost_bps + opportunity_cost_bps,
            'model_type': 'simple_sqrt'
        }
    
    def _generate_execution_recommendations(self, quantity: float,
                                          market_data: Dict[str, Any],
                                          liquidity_score: LiquidityScore,
                                          impact_estimate: Dict[str, Any]) -> Dict[str, Any]:
        """Generate optimal execution recommendations"""
        
        avg_volume = liquidity_score.avg_daily_volume
        participation_rate = quantity / avg_volume if avg_volume > 0 else 1.0
        
        # Determine optimal slicing
        if participation_rate < 0.01:  # < 1% ADV
            recommended_slices = 1
            optimal_strategy = 'MARKET'
        elif participation_rate < 0.05:  # 1-5% ADV
            recommended_slices = max(3, int(participation_rate * 100))
            optimal_strategy = 'VWAP'
        elif participation_rate < 0.15:  # 5-15% ADV
            recommended_slices = max(10, int(participation_rate * 150))
            optimal_strategy = 'TWAP'
        else:  # > 15% ADV
            recommended_slices = max(20, int(participation_rate * 200))
            optimal_strategy = 'IS'  # Implementation Shortfall
        
        # Adjust for liquidity regime
        if liquidity_score.liquidity_regime in [LiquidityRegime.LOW_LIQUIDITY, 
                                               LiquidityRegime.ILLIQUID]:
            recommended_slices = int(recommended_slices * 1.5)
        
        # Calculate duration
        max_participation_rate = self._get_max_participation_rate(liquidity_score)
        duration_minutes = self._calculate_optimal_duration(
            quantity, avg_volume, max_participation_rate
        )
        
        return {
            'recommended_slices': recommended_slices,
            'duration_minutes': duration_minutes,
            'max_participation_rate': max_participation_rate,
            'optimal_strategy': optimal_strategy
        }
    
    def _get_max_participation_rate(self, liquidity_score: LiquidityScore) -> float:
        """Get maximum safe participation rate based on liquidity"""
        
        # Conservative participation rates by liquidity regime
        participation_limits = {
            LiquidityRegime.HIGH_LIQUIDITY: 0.20,  # 20% of volume
            LiquidityRegime.NORMAL_LIQUIDITY: 0.10,  # 10% of volume
            LiquidityRegime.LOW_LIQUIDITY: 0.05,  # 5% of volume
            LiquidityRegime.ILLIQUID: 0.02,  # 2% of volume
            LiquidityRegime.CRISIS_LIQUIDITY: 0.01  # 1% of volume
        }
        
        return participation_limits.get(
            liquidity_score.liquidity_regime, 0.10
        )
```

## 4. Order Book Analytics

### Real-Time Order Book Analysis
```python
from dataclasses import dataclass
from typing import List, Dict, Any
import numpy as np

@dataclass
class OrderBookLevel:
    """Order book level data"""
    price: float
    size: float
    num_orders: int
    side: str  # 'bid' or 'ask'

@dataclass
class OrderBookAnalysis:
    """Comprehensive order book analytics"""
    
    # Book Imbalance Metrics
    imbalance_ratio: float  # Bid/ask volume ratio
    weighted_imbalance: float  # Price-weighted imbalance
    depth_imbalance: float  # Cumulative depth imbalance
    
    # Liquidity Metrics
    total_bid_liquidity: float  # Total $ on bid side
    total_ask_liquidity: float  # Total $ on ask side
    liquidity_at_touch: float  # Liquidity at best bid/ask
    
    # Spread Metrics
    bid_ask_spread_bps: float  # Current spread
    effective_spread_bps: float  # Effective spread
    micro_price: float  # Liquidity-weighted mid price
    
    # Pressure Metrics
    buy_pressure_score: float  # 0-100 buy pressure
    sell_pressure_score: float  # 0-100 sell pressure
    order_flow_toxicity: float  # Informed trading indicator
    
    # Market Making Metrics
    market_maker_activity: float  # MM participation score
    quote_stability: float  # How stable are quotes
    
    timestamp: datetime

class OrderBookAnalyzer(ILiquidityComponent):
    """Real-time order book analytics engine"""
    
    def __init__(self, config: Dict[str, Any]):
        super().__init__()
        self.config = config
        self.depth_levels = config.get('depth_levels', 10)
    
    async def analyze_order_book(self, symbol: str, depth: int = 10) -> OrderBookAnalysis:
        """Analyze order book microstructure"""
        
        try:
            # Get order book snapshot
            order_book = await self._get_order_book_snapshot(symbol, depth)
            
            bids = order_book.get('bids', [])
            asks = order_book.get('asks', [])
            
            if not bids or not asks:
                raise ValueError(f"Insufficient order book data for {symbol}")
            
            # Calculate imbalance metrics
            imbalance_metrics = self._calculate_imbalance_metrics(bids, asks)
            
            # Calculate liquidity metrics
            liquidity_metrics = self._calculate_liquidity_metrics(bids, asks)
            
            # Calculate spread metrics
            spread_metrics = self._calculate_spread_metrics(bids, asks)
            
            # Calculate pressure metrics
            pressure_metrics = self._calculate_pressure_metrics(bids, asks)
            
            # Calculate market making metrics
            mm_metrics = self._calculate_market_maker_metrics(bids, asks)
            
            return OrderBookAnalysis(
                imbalance_ratio=imbalance_metrics['imbalance_ratio'],
                weighted_imbalance=imbalance_metrics['weighted_imbalance'],
                depth_imbalance=imbalance_metrics['depth_imbalance'],
                total_bid_liquidity=liquidity_metrics['total_bid_liquidity'],
                total_ask_liquidity=liquidity_metrics['total_ask_liquidity'],
                liquidity_at_touch=liquidity_metrics['liquidity_at_touch'],
                bid_ask_spread_bps=spread_metrics['bid_ask_spread_bps'],
                effective_spread_bps=spread_metrics['effective_spread_bps'],
                micro_price=spread_metrics['micro_price'],
                buy_pressure_score=pressure_metrics['buy_pressure_score'],
                sell_pressure_score=pressure_metrics['sell_pressure_score'],
                order_flow_toxicity=pressure_metrics['order_flow_toxicity'],
                market_maker_activity=mm_metrics['market_maker_activity'],
                quote_stability=mm_metrics['quote_stability'],
                timestamp=datetime.now()
            )
            
        except Exception as e:
            self.logger.error(f"Order book analysis failed for {symbol}: {e}")
            raise
    
    def _calculate_imbalance_metrics(self, bids: List[OrderBookLevel],
                                    asks: List[OrderBookLevel]) -> Dict[str, float]:
        """Calculate order book imbalance metrics"""
        
        # Volume imbalance
        total_bid_volume = sum(level['size'] for level in bids)
        total_ask_volume = sum(level['size'] for level in asks)
        
        if total_ask_volume > 0:
            imbalance_ratio = total_bid_volume / total_ask_volume
        else:
            imbalance_ratio = float('inf') if total_bid_volume > 0 else 1.0
        
        # Price-weighted imbalance
        bid_value = sum(level['size'] * level['price'] for level in bids)
        ask_value = sum(level['size'] * level['price'] for level in asks)
        total_value = bid_value + ask_value
        
        if total_value > 0:
            weighted_imbalance = (bid_value - ask_value) / total_value
        else:
            weighted_imbalance = 0.0
        
        # Depth imbalance (cumulative)
        depth_imbalance = weighted_imbalance  # Simplified
        
        return {
            'imbalance_ratio': imbalance_ratio,
            'weighted_imbalance': weighted_imbalance,
            'depth_imbalance': depth_imbalance
        }
    
    def _calculate_pressure_metrics(self, bids: List[OrderBookLevel],
                                   asks: List[OrderBookLevel]) -> Dict[str, float]:
        """Calculate buy/sell pressure metrics"""
        
        # Calculate imbalance ratio
        imbalance = self._calculate_imbalance_metrics(bids, asks)
        imbalance_ratio = imbalance['imbalance_ratio']
        
        # Buy pressure (based on imbalance)
        if imbalance_ratio > 1.0:
            buy_pressure_score = min(100, 50 + (imbalance_ratio - 1.0) * 50)
        else:
            buy_pressure_score = max(0, 50 * imbalance_ratio)
        
        # Sell pressure (inverse)
        sell_pressure_score = 100 - buy_pressure_score
        
        # Order flow toxicity (informed trading indicator)
        # High toxicity indicates informed traders
        # Based on quote updates and trade imbalances
        # Simplified version here
        toxicity = abs(imbalance['weighted_imbalance'])
        order_flow_toxicity = min(1.0, toxicity * 2)
        
        return {
            'buy_pressure_score': buy_pressure_score,
            'sell_pressure_score': sell_pressure_score,
            'order_flow_toxicity': order_flow_toxicity
        }
```

## 5. Smart Order Routing (SOR)

### Venue Selection and Routing Optimization
```python
from dataclasses import dataclass
from typing import List, Dict, Any, Optional
from enum import Enum

class VenueType(Enum):
    PRIMARY_EXCHANGE = "primary_exchange"
    ALTERNATIVE_EXCHANGE = "alternative_exchange"
    DARK_POOL = "dark_pool"
    ELECTRONIC_BROKER = "electronic_broker"

@dataclass
class VenueMetrics:
    """Venue performance metrics"""
    
    venue_name: str
    venue_type: VenueType
    
    # Liquidity Metrics
    available_liquidity: float  # $ available
    fill_rate: float  # Historical fill rate
    average_size: float  # Average trade size
    
    # Cost Metrics
    fee_per_share: float  # Fee in cents per share
    effective_spread_bps: float  # Effective spread
    price_improvement_bps: float  # Average price improvement
    
    # Performance Metrics
    latency_ms: float  # Average latency
    reject_rate: float  # Order reject rate
    market_impact_bps: float  # Historical impact
    
    # Quality Metrics
    execution_quality_score: float  # 0-100 quality score
    reliability_score: float  # 0-100 reliability
    
    # Current State
    is_available: bool
    congestion_level: str  # 'low', 'medium', 'high'
    
    timestamp: datetime

class SmartOrderRouter(ILiquidityComponent):
    """Institutional smart order routing engine"""
    
    def __init__(self, config: Dict[str, Any]):
        super().__init__()
        self.config = config
        self.venue_registry = {}
        self.venue_performance_history = {}
    
    async def route_order(self, symbol: str, quantity: float, side: str,
                         urgency: str = 'normal') -> Dict[str, Any]:
        """Route order to optimal venues"""
        
        try:
            # Analyze all available venues
            venue_analyses = await self._analyze_all_venues(symbol, quantity)
            
            # Filter available venues
            available_venues = [
                v for v in venue_analyses 
                if v.is_available and v.congestion_level != 'high'
            ]
            
            if not available_venues:
                raise ValueError(f"No available venues for {symbol}")
            
            # Score and rank venues
            venue_scores = self._score_venues(
                available_venues, quantity, side, urgency
            )
            
            # Optimize routing across venues
            routing_plan = self._optimize_venue_allocation(
                venue_scores, quantity, urgency
            )
            
            return {
                'routing_plan': routing_plan,
                'primary_venue': routing_plan[0] if routing_plan else None,
                'total_venues': len(routing_plan),
                'expected_fill_rate': self._calculate_expected_fill_rate(routing_plan),
                'expected_cost_bps': self._calculate_expected_cost(routing_plan),
                'estimated_latency_ms': self._calculate_expected_latency(routing_plan),
                'timestamp': datetime.now()
            }
            
        except Exception as e:
            self.logger.error(f"Order routing failed for {symbol}: {e}")
            raise
    
    def _score_venues(self, venues: List[VenueMetrics], quantity: float,
                     side: str, urgency: str) -> List[Dict[str, Any]]:
        """Score venues based on multiple factors"""
        
        venue_scores = []
        
        for venue in venues:
            # Calculate component scores
            liquidity_score = self._calculate_liquidity_score(venue, quantity)
            cost_score = self._calculate_cost_score(venue)
            performance_score = self._calculate_performance_score(venue)
            quality_score = venue.execution_quality_score
            
            # Urgency-based weighting
            if urgency == 'urgent':
                weights = {
                    'liquidity': 0.4,
                    'performance': 0.4,
                    'cost': 0.1,
                    'quality': 0.1
                }
            else:
                weights = {
                    'liquidity': 0.3,
                    'performance': 0.2,
                    'cost': 0.3,
                    'quality': 0.2
                }
            
            # Calculate weighted score
            composite_score = (
                liquidity_score * weights['liquidity'] +
                performance_score * weights['performance'] +
                cost_score * weights['cost'] +
                quality_score * weights['quality']
            )
            
            venue_scores.append({
                'venue': venue,
                'composite_score': composite_score,
                'component_scores': {
                    'liquidity': liquidity_score,
                    'cost': cost_score,
                    'performance': performance_score,
                    'quality': quality_score
                }
            })
        
        # Sort by composite score (descending)
        venue_scores.sort(key=lambda x: x['composite_score'], reverse=True)
        
        return venue_scores
    
    def _optimize_venue_allocation(self, venue_scores: List[Dict[str, Any]],
                                  quantity: float, urgency: str) -> List[Dict[str, Any]]:
        """Optimize order allocation across venues"""
        
        routing_plan = []
        remaining_quantity = quantity
        
        # For urgent orders, use top venue
        if urgency == 'urgent':
            routing_plan.append({
                'venue': venue_scores[0]['venue'].venue_name,
                'quantity': quantity,
                'percentage': 100.0
            })
            return routing_plan
        
        # For normal orders, split across top venues
        # Use liquidity-weighted allocation
        top_venues = venue_scores[:3]  # Top 3 venues
        total_liquidity = sum(v['venue'].available_liquidity for v in top_venues)
        
        for venue_score in top_venues:
            venue = venue_score['venue']
            
            # Calculate allocation based on available liquidity
            if total_liquidity > 0:
                allocation_pct = venue.available_liquidity / total_liquidity
            else:
                allocation_pct = 1.0 / len(top_venues)
            
            # Cap individual venue allocation
            allocation_pct = min(allocation_pct, 0.5)  # Max 50% per venue
            
            allocated_quantity = remaining_quantity * allocation_pct
            
            # Only allocate if meaningful size
            if allocated_quantity >= 100:  # Min 100 shares per venue
                routing_plan.append({
                    'venue': venue.venue_name,
                    'venue_type': venue.venue_type.value,
                    'quantity': allocated_quantity,
                    'percentage': allocation_pct * 100,
                    'expected_fill_rate': venue.fill_rate,
                    'expected_cost_bps': venue.effective_spread_bps + venue.fee_per_share * 10000 / 100,
                    'latency_ms': venue.latency_ms
                })
                
                remaining_quantity -= allocated_quantity
        
        # Allocate any remaining to best venue
        if remaining_quantity > 0 and routing_plan:
            routing_plan[0]['quantity'] += remaining_quantity
            routing_plan[0]['percentage'] = (routing_plan[0]['quantity'] / quantity) * 100
        
        return routing_plan
```

