{
    "data": {
        "training_start": "2023-01-01",
        "training_end": "2023-12-31",
        "testing_start": "2024-01-01",
        "testing_end": "2024-12-31",
        "symbols": ["TSLA", "NVDA", "VNET", "GDS"],
        "max_symbols": 4
    },
    "backtesting": {
        "initial_capital": 100000.0
    },
    "strategy": {
        "momentum_type": "risk_adjusted",
        "momentum_window": 20,
        "min_periods": 10,
        "volatility_window": 20,
        "risk_adjustment": true,
        "vol_scaling": true,
        "top_n_long": 2,
        "top_n_short": 1,
        "rebalance_frequency": "daily",
        "transaction_costs": 0.001,
        "max_turnover": 2.0
    },
    "risk_management": {
        "vol_target": 0.15,
        "max_leverage": 2.0,
        "stop_loss": 0.05,
        "position_concentration": 0.4
    },
    "logging": {
        "level": "INFO"
    },
    "output": {
        "results_directory": "results/modern_momentum_backtest",
        "save_trades": true,
        "save_positions": true,
        "save_performance": true
    }
}
