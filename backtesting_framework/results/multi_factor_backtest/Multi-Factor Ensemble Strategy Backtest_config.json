{
  "name": "Multi-Factor Ensemble Strategy Backtest",
  "description": "Advanced multi-factor ensemble with dynamic weighting and regime detection",
  "version": "1.0.0",
  "symbols": [
    "AAPL",
    "MSFT",
    "GOOGL"
  ],
  "start_date": "2023-01-01",
  "end_date": "2025-06-30",
  "strategy_class": "MultiFactorEnsembleStrategy",
  "strategy_params": {
    "universe_size": 30,
    "min_market_cap": 2000000000.0,
    "min_avg_volume": 1000000.0,
    "training_start": "2023-01-01",
    "training_end": "2024-12-31",
    "trading_start": "2025-01-01",
    "trading_end": "2025-01-31",
    "initial_capital": 100000,
    "commission_rate": 0.0005,
    "benchmark_symbol": "SPY",
    "ensemble_method": "adaptive_weighting",
    "signal_threshold": 0.15,
    "max_factors_per_asset": 5,
    "factors": [
      {
        "factor_type": "momentum",
        "lookback_period": 252,
        "threshold": 0.1,
        "weight": 0.25,
        "momentum_type": "risk_adjusted"
      },
      {
        "factor_type": "mean_reversion",
        "lookback_period": 60,
        "threshold": 0.2,
        "weight": 0.2,
        "mean_reversion_threshold": 0.5
      },
      {
        "factor_type": "quality",
        "lookback_period": 120,
        "threshold": 0.15,
        "weight": 0.2,
        "quality_metrics": [
          "roe",
          "debt_to_equity"
        ]
      },
      {
        "factor_type": "risk",
        "lookback_period": 90,
        "threshold": 0.25,
        "weight": 0.15,
        "risk_metrics": [
          "beta",
          "volatility"
        ]
      },
      {
        "factor_type": "regime",
        "lookback_period": 30,
        "threshold": 0.3,
        "weight": 0.2,
        "regime_detection_method": "volatility_regime"
      }
    ],
    "ml_ensemble_enabled": true,
    "ensemble_learning_rate": 0.01,
    "ensemble_memory_period": 252,
    "ensemble_regularization": 0.001,
    "regime_detection_enabled": true,
    "regime_lookback": 60,
    "regime_threshold": 0.6,
    "regime_smoothing": 0.1,
    "target_volatility": 0.15,
    "max_weight_per_asset": 0.08,
    "sector_neutrality": true,
    "factor_correlation_limit": 0.7,
    "rebalancing_frequency": "daily"
  },
  "initial_capital": 100000,
  "commission_rate": 0.001,
  "slippage_rate": 0.0005,
  "max_position_size": 0.2,
  "stop_loss": null,
  "take_profit": null,
  "benchmark_symbol": null,
  "risk_free_rate": 0.02
}